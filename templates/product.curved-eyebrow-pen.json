und":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","gradient_background":"","padding_top":36,"padding_bottom":36}},"scrolling_promotion_pD6Mdt":{"type":"scrolling-promotion","blocks":{"announcement_CR4hbT":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_CR4hbT"],"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"custom_liquid_kYPMYP":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"testimonials_yzCmrJ":{"type":"testimonials","blocks":{"testimonial_ai9x6n":{"type":"testimonial","settings":{"icon":"5","text":"<p>I love how sleek it looks! I can add my favorite charms inside without it feeling bulky or cluttered. It’s like a tiny memory capsule I wear every day.<\/p>","author":"Celine ghamloush"}},"testimonial_CRPdFk":{"type":"testimonial","settings":{"icon":"5","text":"<p>This solves the problem I always had with charm necklaces — no tangling, no messy clasps. Just open the locket, place the charms, and it looks perfect.<\/p>","author":"Line Darwish"}},"testimonial_Ag34fd":{"type":"testimonial","settings":{"icon":"5","text":"<p>I change the charms depending on my mood or outfit. Sometimes I keep it minimal with one or two, other times I fill it up for a bold look. So versatile!<\/p>","author":"Maya khoury"}}},"block_order":["testimonial_ai9x6n","testimonial_CRPdFk","testimonial_Ag34fd"],"disabled":true,"name":"t:sections.testimonials.presets.name","settings":{"autorotate":false,"autorotate_speed":5,"hide_images":true,"show_divider":false,"heading":"Testimonials","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","padding_top":36,"padding_bottom":36}},"custom_liquid_gX9LTQ":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n.jolie-section { padding: 2.5rem 0; text-align: center; }\n.jolie-label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #c4a882; font-weight: 500; margin-bottom: 10px; }\n.jolie-title { font-size: 26px; font-weight: 700; color: #000; margin: 0 0 6px; font-family: Georgia, serif; }\n.jolie-sub { font-size: 14px; color: #666; margin: 0 0 2rem; }\n.stars { color: #c4a882; font-size: 13px; letter-spacing: 2px; margin-bottom: 10px; }\n.cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; text-align: left; }\n.card { background: #fff; border: 0.5px solid #e8e0d8; border-radius: 14px; padding: 1.1rem 1.2rem; }\n.card.hidden { display: none; }\n.card-text { font-size: 13.5px; color: #222; line-height: 1.65; margin: 0 0 14px; font-style: italic; }\n.card-footer { display: flex; align-items: center; gap: 10px; border-top: 0.5px solid #f0e8df; padding-top: 12px; }\n.avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; flex-shrink: 0; background: #f5ede3; color: #9a7355; }\n.name { font-size: 13px; font-weight: 500; color: #111; margin: 0; }\n.verified { font-size: 11px; color: #c4a882; margin: 0; }\n.badge { display: inline-block; background: #fdf5ee; color: #9a7355; font-size: 11px; font-weight: 500; padding: 4px 12px; border-radius: 20px; border: 0.5px solid #e8d5c0; margin-bottom: 2rem; letter-spacing: 0.04em; }\n.show-more-btn { margin-top: 1.5rem; background: none; border: 1px solid #c4a882; color: #9a7355; font-size: 13px; font-weight: 500; padding: 10px 28px; border-radius: 30px; cursor: pointer; letter-spacing: 0.05em; transition: background 0.2s, color 0.2s; }\n.show-more-btn:hover { background: #fdf5ee; }\n<\/style>\n\n<div class=\"jolie-section\">\n  <div class=\"jolie-label\">What our girls are saying<\/div>\n  <h2 class=\"jolie-title\">Real results. Real love.<\/h2>\n  <p class=\"jolie-sub\">Over 10,000 happy brows and counting<\/p>\n  <div class=\"badge\">★ 4.9 out of 5 — verified reviews<\/div>\n\n  <div class=\"cards\" id=\"cards\">\n\n    <div class=\"card\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"I've tried every brow pen out there. This one actually makes my brows look like I was born with them. The curved tip is a game changer.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">S<\/div><div><p class=\"name\">Sara M.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"My brows survived a full day at the beach. I'm obsessed. Never going back to my old pencil.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">L<\/div><div><p class=\"name\">Lina K.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"Finally both brows match! I used to struggle so much. This pen basically does the work for you.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">N<\/div><div><p class=\"name\">Nour R.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"I got so many compliments asking if I got microblading. It's just this pen. Worth every penny.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">D<\/div><div><p class=\"name\">Dana H.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card hidden\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"The brush end is everything. I blend it out and it looks so natural. My morning routine is cut in half.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">R<\/div><div><p class=\"name\">Rania T.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card hidden\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"I have really sparse brows and I was always insecure. This pen genuinely changed how I feel about my face every morning.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">M<\/div><div><p class=\"name\">Maya S.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card hidden\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"Bought the dark brown shade and it matches my hair perfectly. Stays on through gym, work, everything.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">J<\/div><div><p class=\"name\">Jana B.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card hidden\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"My mom saw my brows and immediately asked me to order her one. That says it all honestly.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">T<\/div><div><p class=\"name\">Tala F.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card hidden\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"I was so skeptical but the before\/after is insane. Looks like real hair strokes, not a drawn line at all.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">H<\/div><div><p class=\"name\">Hana W.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card hidden\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"As a beginner with zero makeup skills — this is literally foolproof. I look put together with no effort.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">C<\/div><div><p class=\"name\">Chloe A.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card hidden\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"The light brown shade is so perfect for fair skin. Very natural. People genuinely think these are my real brows.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">E<\/div><div><p class=\"name\">Elena P.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n    <div class=\"card hidden\">\n      <div class=\"stars\">★★★★★<\/div>\n      <p class=\"card-text\">\"Wore it on a 12-hour flight and it still looked fresh when I landed. Not kidding. Completely waterproof.\"<\/p>\n      <div class=\"card-footer\"><div class=\"avatar\">A<\/div><div><p class=\"name\">Amira Z.<\/p><p class=\"verified\">Verified buyer<\/p><\/div><\/div>\n    <\/div>\n\n  <\/div>\n\n  <br>\n  <button class=\"show-more-btn\" id=\"showBtn\" onclick=\"showMore()\">Show more reviews<\/button>\n<\/div>\n\n<script>\nfunction showMore() {\n  const hidden = document.querySelectorAll('.card.hidden');\n  let shown = 0;\n  hidden.forEach(card => {\n    if (shown < 4) { card.classList.remove('hidden'); shown++; }\n  });\n  if (document.querySelectorAll('.card.hidden').length === 0) {\n    document.getElementById('showBtn').style.display = 'none';\n  }\n}\n<\/script>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}}},"order":["empty-space","main","product-recommendations","image_with_text_EcxpFh","scrolling_promotion_6Xj9FQ","image_with_text_X6KRyA","scrolling_promotion_pD6Mdt","custom_liquid_kYPMYP","testimonials_yzCmrJ","custom_liquid_gX9LTQ"]}