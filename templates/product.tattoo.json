\"#1a1a1a\" stroke-width=\"1.6\"/>\n          <line x1=\"8\" y1=\"17\" x2=\"36\" y2=\"17\" stroke=\"#1a1a1a\" stroke-width=\"1.6\"/>\n          <line x1=\"14\" y1=\"6\" x2=\"14\" y2=\"12\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n          <line x1=\"30\" y1=\"6\" x2=\"30\" y2=\"12\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n          <circle cx=\"15\" cy=\"23\" r=\"1.4\" fill=\"#1a1a1a\"/>\n          <circle cx=\"22\" cy=\"23\" r=\"1.4\" fill=\"#1a1a1a\"/>\n          <circle cx=\"29\" cy=\"23\" r=\"1.4\" fill=\"#1a1a1a\"/>\n          <circle cx=\"15\" cy=\"29\" r=\"1.4\" fill=\"#1a1a1a\"/>\n          <circle cx=\"22\" cy=\"29\" r=\"1.4\" fill=\"#1a1a1a\"/>\n        </svg>\n      </div>\n      <span class=\"tt-label\">Lasts Up To<br>14 Days</span>\n    </div>\n\n    <!-- Waterproof -->\n    <div class=\"tt-feat\">\n      <div class=\"tt-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Water droplet icon -->\n          <path d=\"M22 6s10 11.5 10 19a10 10 0 0 1-20 0c0-7.5 10-19 10-19z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linejoin=\"round\"/>\n          <path d=\"M16 27c0 3 2.5 5.5 5.5 5.8\" stroke=\"#1a1a1a\" stroke-width=\"1.2\" stroke-linecap=\"round\" opacity=\"0.4\"/>\n        </svg>\n      </div>\n      <span class=\"tt-label\">100%<br>Waterproof</span>\n    </div>\n\n    <!-- Easy Application -->\n    <div class=\"tt-feat\">\n      <div class=\"tt-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Hand / apply icon -->\n          <path d=\"M14 24V12.5a2 2 0 0 1 4 0V22\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <path d=\"M18 22v-9a2 2 0 0 1 4 0v9\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <path d=\"M22 22v-7a2 2 0 0 1 4 0v8\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <path d=\"M26 23v-4a2 2 0 0 1 4 0v9c0 5-3.5 9-9 9h-2c-3.2 0-5-1-7-3l-6-6.3c-1-1-1-2.6.2-3.4 1-.8 2.4-.6 3.3.3L14 28\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </div>\n      <span class=\"tt-label\">Easy 30-Second<br>Application</span>\n    </div>\n\n    <!-- Skin-Safe Ink -->\n    <div class=\"tt-feat\">\n      <div class=\"tt-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Shield check icon -->\n          <path d=\"M22 6 8 11v10c0 8.8 5.9 14.6 14 17 8.1-2.4 14-8.2 14-17V11L22 6z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linejoin=\"round\"/>\n          <path d=\"M16.5 22.5l4 4 7-8.5\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </div>\n      <span class=\"tt-label\">Skin-Safe<br>Ink</span>\n    </div>\n\n  </div>\n</div>\n\n</body>\n</html>"
