er":false,"heading":"Testimonials","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","padding_top":36,"padding_bottom":36}},"custom_liquid_LWEg3f":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\"\/>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\/>\n<title>JOLIE — Where Beauty Is Crafted<\/title>\n<link rel=\"preconnect\" href=\"https:\/\/fonts.googleapis.com\"\/>\n<link rel=\"preconnect\" href=\"https:\/\/fonts.gstatic.com\" crossorigin\/>\n<link href=\"https:\/\/fonts.googleapis.com\/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@300;400;500&family=Cormorant:ital,wght@0,300;0,400;1,300;1,400&display=swap\" rel=\"stylesheet\"\/>\n<style>\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\n:root{\n  --cream:#FAF6F1;\n  --warm-white:#FDF9F5;\n  --blush:#E8C4B0;\n  --rose:#C9836A;\n  --charcoal:#1C1915;\n  --mid:#6B5C52;\n  --gold:#C9A96E;\n  --gold-light:#E8D5A8;\n  --magenta:#FF2D7A;\n  --off-white:#F5EFE8;\n}\nhtml{scroll-behavior:smooth}\nbody{background:var(--cream);color:var(--charcoal);font-family:'DM Sans',sans-serif;overflow-x:hidden}\n\n\/* ─── HERO ─── *\/\n.hero{\n  position:relative;\n  height:100vh;min-height:640px;\n  display:flex;align-items:center;\n  overflow:hidden;\n}\n\n\/* image is z-index:0 *\/\n.hero-img{\n  position:absolute;inset:0;\n  width:100%;height:100%;\n  object-fit:cover;object-position:center top;\n  z-index:0;\n  filter:brightness(0.45);\n}\n\n\/* overlay sits on top of image, below content *\/\n.hero-overlay{\n  position:absolute;\n  top:0;left:0;right:0;bottom:0;\n  z-index:1;\n  background:rgba(10,8,6,0.78) !important;\n}\n\n\/* content above everything *\/\n.hero-content{\n  position:relative;\n  z-index:2;\n  padding:0 90px;\n  max-width:700px;\n}\n\n.hero-eyebrow{\n  font-size:10px;letter-spacing:0.45em;text-transform:uppercase;\n  color:var(--gold);margin-bottom:24px;display:block;\n  opacity:0;transform:translateY(20px);\n  animation:up 0.7s ease forwards 0.4s;\n}\n.hero-title{\n  font-family:'Playfair Display',serif;\n  font-size:clamp(3.2rem,6vw,5.5rem);\n  font-weight:400;color:#fff;line-height:1.05;\n  margin-bottom:28px;\n  opacity:0;transform:translateY(30px);\n  animation:up 0.8s ease forwards 0.65s;\n}\n.hero-title em{font-style:italic;color:var(--gold-light)}\n.hero-sub{\n  font-size:16px;color:rgba(255,255,255,0.65);\n  line-height:1.75;margin-bottom:48px;font-weight:300;max-width:440px;\n  opacity:0;transform:translateY(20px);\n  animation:up 0.7s ease forwards 0.9s;\n}\n.hero-cta{\n  display:inline-block;\n  background:var(--gold);color:var(--charcoal);\n  padding:16px 42px;font-size:11px;letter-spacing:0.25em;\n  text-transform:uppercase;font-weight:500;text-decoration:none;\n  position:relative;overflow:hidden;\n  opacity:0;transform:translateY(20px);\n  animation:up 0.7s ease forwards 1.1s;\n  transition:color 0.35s;\n}\n.hero-cta::before{\n  content:'';position:absolute;inset:0;\n  background:var(--charcoal);\n  transform:scaleX(0);transform-origin:left;\n  transition:transform 0.38s ease;z-index:0;\n}\n.hero-cta:hover::before{transform:scaleX(1)}\n.hero-cta:hover{color:#fff}\n.hero-cta span{position:relative;z-index:1}\n\n\/* 30% badge *\/\n.hero-badge{\n  position:absolute;right:100px;top:50%;\n  transform:translateY(-50%);\n  width:115px;height:115px;border-radius:50%;\n  background:var(--magenta);\n  display:flex;flex-direction:column;align-items:center;justify-content:center;\n  text-align:center;z-index:2;\n  opacity:0;\n  animation:popIn 0.6s cubic-bezier(0.34,1.56,0.64,1) forwards 1.4s;\n}\n.hero-badge .pct{font-size:32px;font-weight:700;color:#fff;line-height:1}\n.hero-badge .off{font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.85);margin-top:4px}\n\n\/* scroll indicator *\/\n.hero-scroll{\n  position:absolute;bottom:40px;left:50%;transform:translateX(-50%);\n  z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px;\n  opacity:0;animation:fadein 1s ease forwards 1.8s;\n}\n.hero-scroll span{font-size:9px;letter-spacing:0.32em;text-transform:uppercase;color:rgba(255,255,255,0.4)}\n.scroll-line{\n  width:1px;height:40px;\n  background:linear-gradient(to bottom,rgba(255,255,255,0.4),transparent);\n  animation:scrollPulse 1.8s ease infinite;\n}\n\n@keyframes up{to{opacity:1;transform:translateY(0)}}\n@keyframes fadein{to{opacity:1}}\n@keyframes popIn{\n  0%{opacity:0;transform:translateY(-50%) scale(0.4)}\n  100%{opacity:1;transform:translateY(-50%) scale(1)}\n}\n@keyframes scrollPulse{\n  0%{transform:scaleY(0);transform-origin:top;opacity:0}\n  40%{transform:scaleY(1);transform-origin:top;opacity:1}\n  41%{transform-origin:bottom}\n  100%{transform:scaleY(0);transform-origin:bottom;opacity:0}\n}\n\n\/* ─── MARQUEE ─── *\/\n.marquee-wrap{\n  background:var(--charcoal);\n  overflow:hidden;padding:16px 0;\n  border-top:1px solid rgba(255,255,255,0.05);\n}\n.marquee-track{\n  display:flex;\n  width:max-content;\n  will-change:transform;\n}\n.marquee-item{\n  font-family:'Cormorant',serif;font-style:italic;font-size:18px;\n  color:rgba(255,255,255,0.52);\n  padding:0 38px;\n  display:flex;align-items:center;gap:20px;\n  flex-shrink:0;\n}\n.marquee-dot{width:4px;height:4px;border-radius:50%;background:var(--gold);flex-shrink:0}\n\n\/* ─── SHARED ─── *\/\n.section-label{\n  font-size:10px;letter-spacing:0.44em;text-transform:uppercase;\n  color:var(--rose);font-weight:500;margin-bottom:12px;display:block;\n}\n.section-title{\n  font-family:'Playfair Display',serif;\n  font-size:clamp(2rem,3.5vw,2.9rem);\n  font-weight:400;line-height:1.2;color:var(--charcoal);\n}\n.section-title em{font-style:italic;color:var(--rose)}\n\n\/* scroll reveal base *\/\n.reveal{opacity:0;transform:translateY(40px);transition:opacity 0.7s ease,transform 0.7s ease}\n.reveal.visible{opacity:1;transform:translateY(0)}\n.reveal.d1{transition-delay:.1s}.reveal.d2{transition-delay:.2s}.reveal.d3{transition-delay:.3s}\n\n\/* ─── PRODUCTS ─── *\/\n.products-section{padding:100px 80px;background:var(--warm-white)}\n.products-header{\n  display:flex;justify-content:space-between;align-items:flex-end;\n  margin-bottom:58px;\n}\n.view-all{\n  font-size:11px;letter-spacing:0.2em;text-transform:uppercase;\n  color:var(--charcoal);text-decoration:none;\n  border-bottom:1px solid var(--charcoal);padding-bottom:2px;\n  transition:color .3s,border-color .3s;\n}\n.view-all:hover{color:var(--rose);border-color:var(--rose)}\n\n.products-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px}\n\n.product-card{\n  display:block;text-decoration:none;color:inherit;\n  opacity:0;transform:translateY(40px);\n  transition:opacity .65s ease,transform .65s ease;\n}\n.product-card.visible{opacity:1;transform:translateY(0)}\n.product-card:nth-child(2){transition-delay:.12s}\n.product-card:nth-child(3){transition-delay:.24s}\n.product-card:nth-child(4){transition-delay:.36s}\n\n.product-img-wrap{\n  position:relative;aspect-ratio:3\/4;\n  overflow:hidden;background:var(--off-white);margin-bottom:16px;\n}\n.product-img-wrap img{\n  width:100%;height:100%;object-fit:cover;\n  transition:transform 0.65s ease;\n  display:block;\n}\n.product-card:hover .product-img-wrap img{transform:scale(1.07)}\n\n.product-badge{\n  position:absolute;top:12px;left:12px;\n  font-size:9px;letter-spacing:0.14em;text-transform:uppercase;\n  font-weight:500;padding:4px 10px;z-index:2;\n}\n.badge-sale{background:var(--magenta);color:#fff}\n.badge-pct{background:var(--charcoal);color:#fff}\n\n.product-name{\n  font-family:'Playfair Display',serif;\n  font-size:14.5px;font-weight:400;\n  color:var(--charcoal);margin-bottom:7px;line-height:1.3;\n}\n.product-price{display:flex;gap:9px;align-items:center}\n.price-old{font-size:12px;color:var(--mid);text-decoration:line-through}\n.price-new{font-size:14px;color:var(--rose);font-weight:500}\n\n\/* ─── TRUST STRIP ─── *\/\n.trust-strip{\n  background:var(--magenta);padding:20px 80px;\n  display:flex;\n}\n.trust-item{\n  flex:1;display:flex;align-items:center;justify-content:center;gap:10px;\n  padding:0 16px;border-right:1px solid rgba(255,255,255,0.22);\n}\n.trust-item:last-child{border-right:none}\n.trust-item span{\n  font-size:11px;letter-spacing:0.1em;text-transform:uppercase;\n  color:#fff;white-space:nowrap;\n}\n\n\/* ─── ABOUT ─── *\/\n.about-section{display:grid;grid-template-columns:1fr 1fr;min-height:560px}\n\n.about-visual{\n  background:linear-gradient(150deg,#241A16 0%,#3D2820 55%,#5C3425 100%);\n  display:flex;align-items:center;justify-content:center;\n  position:relative;overflow:hidden;padding:60px 50px;\n}\n.about-visual::before{\n  content:'';position:absolute;\n  width:400px;height:400px;border-radius:50%;\n  background:radial-gradient(circle,rgba(201,163,110,0.14) 0%,transparent 70%);\n  top:-80px;left:-80px;\n}\n.about-stats{position:relative;z-index:1;width:100%;display:flex;flex-direction:column}\n.about-stat-row{\n  padding:30px 0;border-bottom:1px solid rgba(255,255,255,0.07);\n  display:flex;align-items:center;justify-content:space-between;\n}\n.about-stat-row:last-child{border-bottom:none}\n.stat-num{\n  font-family:'Playfair Display',serif;\n  font-size:clamp(2rem,3.8vw,3rem);font-weight:400;\n  color:var(--gold-light);line-height:1;\n}\n.stat-label{\n  font-size:10px;letter-spacing:0.24em;text-transform:uppercase;\n  color:rgba(255,255,255,0.38);text-align:right;max-width:130px;line-height:1.55;\n}\n\n.about-content{\n  background:var(--off-white);\n  display:flex;flex-direction:column;justify-content:center;\n  padding:80px;\n}\n.about-content .section-label{margin-bottom:14px}\n.about-content .section-title{margin-bottom:26px}\n.about-body{\n  font-size:15px;line-height:1.85;color:var(--mid);\n  margin-bottom:34px;font-weight:300;\n}\n.about-values{display:flex;flex-direction:column;gap:14px}\n.value-item{display:flex;gap:14px;align-items:flex-start}\n.value-dot{width:5px;height:5px;border-radius:50%;background:var(--rose);flex-shrink:0;margin-top:7px}\n.value-text{font-size:13px;color:var(--mid);line-height:1.55}\n.value-text strong{display:block;color:var(--charcoal);font-weight:500;font-size:13px;margin-bottom:1px}\n\n\/* ─── WHY JOLIE ─── *\/\n.why-section{\n  padding:100px 80px;background:var(--charcoal);\n  position:relative;overflow:hidden;\n}\n.why-section::before{\n  content:'';position:absolute;\n  top:-100px;right:-80px;width:500px;height:500px;border-radius:50%;\n  background:radial-gradient(circle,rgba(201,163,110,0.06) 0%,transparent 70%);\n}\n.why-header{text-align:center;margin-bottom:68px}\n.why-header .section-label{color:var(--gold);justify-content:center;display:flex}\n.why-header .section-title{color:#fff}\n.why-header .section-title em{color:var(--gold-light)}\n.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}\n.why-item{\n  background:rgba(255,255,255,0.03);\n  border:1px solid rgba(255,255,255,0.05);\n  padding:50px 38px;position:relative;\n  transition:background 0.35s,transform 0.35s;\n}\n.why-item:hover{background:rgba(255,255,255,0.07);transform:translateY(-4px)}\n.why-num{\n  font-family:'Playfair Display',serif;font-size:80px;font-weight:400;\n  color:rgba(255,255,255,0.04);line-height:1;\n  position:absolute;top:16px;right:20px;\n}\n.why-icon{\n  width:52px;height:52px;border-radius:50%;\n  background:rgba(201,163,110,0.09);border:1px solid rgba(201,163,110,0.2);\n  display:flex;align-items:center;justify-content:center;\n  font-size:22px;margin-bottom:24px;\n}\n.why-name{\n  font-family:'Playfair Display',serif;\n  font-size:20px;font-weight:400;color:#fff;margin-bottom:14px;\n}\n.why-desc{font-size:13px;line-height:1.8;color:rgba(255,255,255,0.42);font-weight:300}\n\n\/* ─── REVIEWS ─── *\/\n.reviews-section{padding:100px 80px;background:var(--warm-white)}\n.reviews-header{\n  display:flex;justify-content:space-between;align-items:flex-end;\n  margin-bottom:56px;\n}\n.rating-summary{display:flex;flex-direction:column;align-items:flex-end;gap:4px}\n.rating-big{\n  font-family:'Playfair Display',serif;\n  font-size:48px;font-weight:400;color:var(--charcoal);line-height:1;\n}\n.rating-stars{color:var(--gold);font-size:16px;letter-spacing:2px}\n.rating-count{font-size:12px;color:var(--mid)}\n\n.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}\n.review-card{\n  background:#fff;padding:32px;\n  border:1px solid rgba(0,0,0,0.05);\n  opacity:0;transform:translateY(32px);\n  transition:opacity .6s ease,transform .6s ease,box-shadow .3s;\n}\n.review-card:hover{box-shadow:0 12px 40px rgba(0,0,0,0.08)}\n.review-card.visible{opacity:1;transform:translateY(0)}\n.review-card:nth-child(2){transition-delay:.12s}\n.review-card:nth-child(3){transition-delay:.24s}\n.review-quote{\n  font-family:'Playfair Display',serif;font-size:34px;\n  color:var(--gold-light);line-height:1;margin-bottom:10px;\n}\n.review-stars{color:var(--gold);font-size:12px;letter-spacing:1px;margin-bottom:14px}\n.review-text{\n  font-size:13.5px;line-height:1.78;color:var(--mid);\n  font-style:italic;margin-bottom:22px;font-weight:300;\n}\n.review-footer{\n  display:flex;align-items:center;gap:11px;\n  padding-top:18px;border-top:1px solid rgba(0,0,0,0.05);\n}\n.review-avatar{\n  width:36px;height:36px;border-radius:50%;\n  background:linear-gradient(135deg,var(--blush),var(--rose));\n  display:flex;align-items:center;justify-content:center;\n  font-size:13px;font-weight:500;color:#fff;flex-shrink:0;\n}\n.review-name{font-size:13px;font-weight:500;color:var(--charcoal);margin-bottom:1px}\n.review-meta{font-size:11px;color:var(--mid)}\n.verified{\n  margin-left:auto;background:rgba(201,131,106,0.08);\n  color:var(--rose);font-size:9px;letter-spacing:0.1em;\n  text-transform:uppercase;padding:3px 8px;font-weight:500;\n}\n\n\/* ─── NEWSLETTER ─── *\/\n.nl-section{\n  background:linear-gradient(135deg,#1C1915 0%,#3A2820 60%,#4A2E24 100%);\n  padding:100px 80px;\n  display:grid;grid-template-columns:1fr 1fr;gap:90px;align-items:center;\n  position:relative;overflow:hidden;\n}\n.nl-section::before{\n  content:'JOLIE';position:absolute;\n  font-family:'Playfair Display',serif;font-size:240px;font-weight:700;\n  color:rgba(255,255,255,0.025);right:-10px;top:50%;\n  transform:translateY(-50%);\n  white-space:nowrap;pointer-events:none;\n}\n.nl-info .section-label{color:var(--gold)}\n.nl-info .section-title{color:#fff;margin-bottom:18px}\n.nl-info p{font-size:14px;color:rgba(255,255,255,0.48);line-height:1.8;font-weight:300}\n.nl-perks{margin-top:28px;display:flex;flex-direction:column;gap:11px}\n.perk{display:flex;gap:12px;align-items:center;font-size:13px;color:rgba(255,255,255,0.55)}\n.perk-check{\n  width:18px;height:18px;border-radius:50%;\n  background:rgba(201,163,110,0.12);border:1px solid rgba(201,163,110,0.25);\n  display:flex;align-items:center;justify-content:center;\n  font-size:8px;color:var(--gold);flex-shrink:0;\n}\n.nl-eyebrow{\n  font-size:10px;letter-spacing:0.32em;text-transform:uppercase;\n  color:rgba(255,255,255,0.35);margin-bottom:22px;\n}\n.nl-inputs{display:flex;flex-direction:column;gap:12px}\n.nl-input{\n  background:rgba(255,255,255,0.05);\n  border:1px solid rgba(255,255,255,0.1);\n  color:#fff;padding:15px 18px;\n  font-size:14px;font-family:'DM Sans',sans-serif;\n  outline:none;width:100%;transition:border-color .3s;\n}\n.nl-input::placeholder{color:rgba(255,255,255,0.28)}\n.nl-input:focus{border-color:rgba(201,163,110,0.5)}\n.nl-btn{\n  background:var(--gold);color:var(--charcoal);\n  padding:15px;font-size:11px;letter-spacing:0.22em;\n  text-transform:uppercase;font-weight:500;border:none;\n  cursor:pointer;font-family:'DM Sans',sans-serif;\n  transition:background .3s;\n}\n.nl-btn:hover{background:var(--gold-light)}\n.nl-note{font-size:11px;color:rgba(255,255,255,0.24);margin-top:10px}\n\n\/* ─── RESPONSIVE ─── *\/