2.5\" stroke=\"#1a1a1a\" stroke-width=\"1.3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </div>\n      <span class=\"pp-label\">Chew-Proof<br>Durability</span>\n    </div>\n\n    <!-- Anti-Slip Base -->\n    <div class=\"pp-feat\">\n      <div class=\"pp-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Pad with grip texture -->\n          <rect x=\"10\" y=\"13\" width=\"24\" height=\"18\" rx=\"4\" stroke=\"#1a1a1a\" stroke-width=\"1.6\"/>\n          <line x1=\"14\" y1=\"19\" x2=\"17\" y2=\"19\" stroke=\"#1a1a1a\" stroke-width=\"1.3\" stroke-linecap=\"round\" opacity=\"0.45\"/>\n          <line x1=\"20\" y1=\"19\" x2=\"23\" y2=\"19\" stroke=\"#1a1a1a\" stroke-width=\"1.3\" stroke-linecap=\"round\" opacity=\"0.45\"/>\n          <line x1=\"26\" y1=\"19\" x2=\"29\" y2=\"19\" stroke=\"#1a1a1a\" stroke-width=\"1.3\" stroke-linecap=\"round\" opacity=\"0.45\"/>\n          <line x1=\"14\" y1=\"25\" x2=\"17\" y2=\"25\" stroke=\"#1a1a1a\" stroke-width=\"1.3\" stroke-linecap=\"round\" opacity=\"0.45\"/>\n          <line x1=\"20\" y1=\"25\" x2=\"23\" y2=\"25\" stroke=\"#1a1a1a\" stroke-width=\"1.3\" stroke-linecap=\"round\" opacity=\"0.45\"/>\n          <line x1=\"26\" y1=\"25\" x2=\"29\" y2=\"25\" stroke=\"#1a1a1a\" stroke-width=\"1.3\" stroke-linecap=\"round\" opacity=\"0.45\"/>\n        </svg>\n      </div>\n      <span class=\"pp-label\">Anti-Slip<br>Grip Base</span>\n    </div>\n\n  </div>\n</div>\n\n</body>\n</html>"
