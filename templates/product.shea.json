,"swipe_on_mobile":true,"image_ratio":"portrait","image_position":"center center","enable_image_fill":true,"show_secondary_image":true,"show_vendor":true,"show_rating":true,"show_quick_buy":true,"enable_quick_view":true,"enable_color_swatches":true,"enable_countdown":true,"padding_top":36,"padding_bottom":36}},"custom_liquid_cqKTNy":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  * { box-sizing: border-box; }\n  .mms-section {\n    background: #FFFDF9;\n    padding: 48px 24px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n  }\n  .mms-inner {\n    display: flex;\n    flex-direction: column;\n    gap: 36px;\n    align-items: center;\n    max-width: 720px;\n    margin: 0 auto;\n  }\n  .mms-content {\n    display: flex;\n    flex-direction: column;\n    gap: 24px;\n    width: 100%;\n  }\n  .mms-heading {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(28px, 4vw, 46px);\n    color: #c9836a;\n    line-height: 1.2;\n    margin: 0;\n    text-align: center;\n  }\n  .mms-block {\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n  }\n  .mms-block-title {\n    font-size: clamp(14px, 1.6vw, 16px);\n    font-weight: 700;\n    color: #5C4033;\n    margin: 0;\n  }\n  .mms-block-desc {\n    font-size: clamp(13px, 1.4vw, 15px);\n    color: #444;\n    line-height: 1.7;\n    margin: 0;\n  }\n  .mms-block-desc em {\n    font-style: italic;\n  }\n  .mms-icons {\n    display: flex;\n    gap: 32px;\n    align-items: center;\n    justify-content: center;\n    margin-top: 8px;\n    flex-wrap: wrap;\n  }\n  .mms-icon-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 10px;\n  }\n  .mms-icon-circle {\n    width: 72px;\n    height: 72px;\n    border-radius: 50%;\n    background: #F3E7DC;\n    border: 1.5px solid #c9836a;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .mms-icon-circle svg {\n    width: 34px;\n    height: 34px;\n  }\n  .mms-icon-label {\n    font-size: 13px;\n    color: #5C4033;\n    text-align: center;\n    font-weight: 500;\n  }\n  @media (max-width: 700px) {\n    .mms-icon-circle {\n      width: 60px;\n      height: 60px;\n    }\n    .mms-icon-circle svg {\n      width: 28px;\n      height: 28px;\n    }\n  }\n<\/style>\n\n<div class=\"mms-section\">\n  <div class=\"mms-inner\">\n    <div class=\"mms-content\">\n\n      <h2 class=\"mms-heading\">Clear Your Back.<br>Reclaim Your Confidence.<\/h2>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">Targets stubborn back & body acne at the source.<\/p>\n        <p class=\"mms-block-desc\">Our cold-pressed turmeric formula penetrates deep into clogged pores — breaking down excess oil, bacteria, and buildup that cause painful breakouts on your back, chest, and shoulders. Clearer skin, wash after wash.<\/p>\n      <\/div>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">Fades acne scars & dark spots left behind.<\/p>\n        <p class=\"mms-block-desc\">Bacne leaves marks. Our natural brightening actives work to visibly reduce post-acne hyperpigmentation and discoloration — so your skin looks even, smooth, and genuinely healthy again.<\/p>\n      <\/div>\n\n      <div class=\"mms-icons\">\n\n        <!-- Anti-Inflammatory -->\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M18 28 C18 28 8 22 8 14 C8 10 12 7 16 8 C17 8 18 9 18 9 C18 9 19 8 20 8 C24 7 28 10 28 14 C28 22 18 28 18 28Z\" stroke=\"#c47a50\" stroke-width=\"1.5\" fill=\"none\"\/>\n              <path d=\"M18 28 L18 14\" stroke=\"#c47a50\" stroke-width=\"1.2\" stroke-linecap=\"round\"\/>\n              <path d=\"M18 19 C18 19 14 16 12 13\" stroke=\"#c47a50\" stroke-width=\"1.2\" stroke-linecap=\"round\"\/>\n              <path d=\"M18 22 C18 22 22 19 24 16\" stroke=\"#c47a50\" stroke-width=\"1.2\" stroke-linecap=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">Anti-Inflammatory<\/span>\n        <\/div>\n\n        <!-- Brightening -->\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <circle cx=\"18\" cy=\"18\" r=\"7\" stroke=\"#c47a50\" stroke-width=\"1.5\"\/>\n              <path d=\"M18 6 L18 4M18 32 L18 34M6 18 L4 18M32 18 L34 18\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\"\/>\n              <path d=\"M10 10 L8.5 8.5M27.5 27.5 L26 26M26 10 L27.5 8.5M8.5 27.5 L10 26\" stroke=\"#c47a50\" stroke-width=\"1.3\" stroke-linecap=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">Scar Fading<\/span>\n        <\/div>\n\n        <!-- Deep Cleansing -->\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M18 8 C18 8 11 16 11 21 C11 25 14 28 18 28 C22 28 25 25 25 21 C25 16 18 8 18 8Z\" stroke=\"#c47a50\" stroke-width=\"1.5\" fill=\"none\"\/>\n              <path d=\"M14 22 C14 24 16 26 18 26\" stroke=\"#c47a50\" stroke-width=\"1.3\" stroke-linecap=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">Pore Clearing<\/span>\n        <\/div>\n\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"scrolling_promotion_6Xj9FQ":{"type":"scrolling-promotion","blocks":{"announcement_QJYrYr":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_QJYrYr"],"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"image_with_text_X6KRyA":{"type":"image-with-text","blocks":{"heading_Y6bCpT":{"type":"heading","settings":{"heading":"Natural-Looking Freckles (No Skill, No Effort)","heading_size":"h1","heading_tag":"h2"}},"text_fXwrbU":{"type":"text","settings":{"text":"<p>Tired of <strong>uneven <\/strong>dots, streaky pencils, or freckles that look fake by lunchtime? This multi-point freckle stamp was built for real <strong>humans <\/strong>— not makeup artists.<\/p>","text_size":"typeset2","secondary_color":false}}},"block_order":["heading_Y6bCpT","text_fXwrbU"],"disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/73869677-F4A8-4401-8032-7FD4C16C25BD_1060x_0331b5a5-d549-4c42-aed4-bc24160e24f9.png","image_position":"center center","layout":"image_first","text_box_position":"middle","text_alignment":"left","image_ratio":"650px","enlarge_content":false,"full_width":false,"show_divider":false,"image_behavior":"none","mobile_layout":"image_first","mobile_text_alignment":"left","mobile_image_ratio":"auto","enable_video_looping":false,"video_url":"","use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","gradient_background":"","padding_top":36,"padding_bottom":36}},"scrolling_promotion_pD6Mdt":{"type":"scrolling-promotion","blocks":{"announcement_CR4hbT":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_CR4hbT"],"disabled":true,"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"custom_liquid_QWbLRi":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .faq-section {\n    background: #FFFDF9;\n    padding: 48px 24px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    max-width: 800px;\n    margin: 0 auto;\n    box-sizing: border-box;\n  }\n  .faq-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 38px);\n    color: #c9836a;\n    text-align: center;\n    margin: 0 0 36px;\n  }\n  .faq-list {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .faq-item {\n    background: #F3E7DC;\n    border-radius: 12px;\n    overflow: hidden;\n  }\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 20px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    cursor: pointer;\n    text-align: left;\n    gap: 16px;\n  }\n  .faq-question span {\n    font-size: 15px;\n    font-weight: 600;\n    color: #5C4033;\n    line-height: 1.4;\n  }\n  .faq-icon {\n    font-size: 22px;\n    color: #c9836a;\n    font-weight: 300;\n    flex-shrink: 0;\n    transition: transform 0.25s ease;\n    line-height: 1;\n  }\n  .faq-item.open .faq-icon {\n    transform: rotate(45deg);\n    color: #5C4033;\n  }\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease, padding 0.3s ease;\n    padding: 0 20px;\n  }\n  .faq-item.open .faq-answer {\n    max-height: 400px;\n    padding: 0 20px 18px;\n  }\n  .faq-answer p {\n    font-size: 14px;\n    color: #5C4033;\n    line-height: 1.7;\n    margin: 0;\n  }\n<\/style>\n\n<div class=\"faq-section\">\n  <h2 class=\"faq-title\">frequently asked questions<\/h2>\n  <div class=\"faq-list\">\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Can I use the Bacne Out Bar on my face?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>The Bacne Out Bar was originally formulated for body and back acne. However, many customers have used it on their faces with great results! We recommend performing a patch test first, as facial skin is more sensitive.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Will it make my skin oily?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Nope! The Bacne Out Bar is designed to brighten and hydrate your skin without making it feel oily. It cleanses deeply while keeping your skin balanced.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Is it suitable for all skin types?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Yes! The Bacne Out Bar is designed for all skin types and works effectively for both men and women — whether you have oily, dry, combination, or sensitive skin.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How long does one bar last?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>A single bar typically lasts 4–6 weeks with daily use, but this can vary depending on the individual. To extend its life, store it on a dry soap dish between uses so it doesn't sit in water.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>What does it smell like?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Our Bacne Out Bar has a pleasant, fresh lemony scent — clean and light, nothing overpowering.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<script>\n  function toggleFaq(btn) {\n    const item = btn.closest('.faq-item');\n    const isOpen = item.classList.contains('open');\n    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));\n    if (!isOpen) item.classList.add('open');\n  }\n<\/script>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"custom_liquid_PyWqQE":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .reviews-section {\n    background: #FFFDF9;\n    padding: 48px 20px 60px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    text-align: center;\n    box-sizing: border-box;\n    width: 100%;\n    overflow-x: hidden;\n  }\n\n  .reviews-hearts {\n    color: #c9836a;\n    font-size: 18px;\n    letter-spacing: 6px;\n    margin-bottom: 12px;\n  }\n\n  .reviews-rating-bar {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 10px;\n    margin-bottom: 8px;\n  }\n\n  .reviews-rating-stars {\n    color: #c9836a;\n    font-size: 20px;\n    letter-spacing: 2px;\n  }\n\n  .reviews-rating-text {\n    font-size: 14px;\n    color: #5C4033;\n    font-weight: 600;\n  }\n\n  .reviews-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 40px);\n    color: #c9836a;\n    margin: 0 0 36px;\n  }\n\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    max-width: 1200px;\n    margin: 0 auto;\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .review-card {\n    background: #ffffff;\n    border: 1.5px solid #E8D8C9;\n    border-radius: 12px;\n    overflow: hidden;\n    text-align: left;\n    display: flex;\n    flex-direction: column;\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .review-body {\n    padding: 24px 20px 28px;\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    box-sizing: border-box;\n    flex: 1;\n  }\n\n  .review-verified {\n    font-size: 11px;\n    font-weight: 700;\n    color: #c9836a;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .review-stars {\n    color: #c9836a;\n    font-size: 16px;\n    letter-spacing: 2px;\n    margin-bottom: 4px;\n  }\n\n  .review-title {\n    font-size: 15px;\n    font-weight: 800;\n    color: #5C4033;\n    line-height: 1.3;\n    margin: 0;\n    word-break: break-word;\n  }\n\n  .review-text {\n    font-size: 13px;\n    color: #5C4033;\n    line-height: 1.6;\n    margin: 0;\n    word-break: break-word;\n    white-space: normal;\n  }\n\n  .review-reviewer {\n    font-size: 12px;\n    color: #a07060;\n    font-weight: 600;\n    margin-top: 6px;\n  }\n\n  .reviews-toggle {\n    margin-top: 32px;\n    background: none;\n    border: 2px solid #c9836a;\n    color: #c9836a;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    padding: 12px 32px;\n    border-radius: 100px;\n    cursor: pointer;\n    transition: background 0.2s, color 0.2s;\n  }\n\n  .reviews-toggle:hover {\n    background: #c9836a;\n    color: #ffffff;\n  }\n\n  @media (max-width: 900px) {\n    .reviews-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 500px) {\n    .reviews-section {\n      padding: 36px 16px 48px;\n    }\n    .reviews-grid {\n      grid-template-columns: 1fr;\n      width: 100%;\n    }\n    .review-card {\n      width: 100%;\n      max-width: 100%;\n    }\n    .reviews-title {\n      font-size: clamp(22px, 6vw, 32px);\n    }\n  }\n<\/style>\n\n<section class=\"reviews-section\">\n\n  <div class=\"reviews-hearts\">♥ ♥ ♥ ♥ ♥<\/div>\n\n\n\n  <h2 class=\"reviews-title\">Real People. Real Bacne. Real Results.<\/h2>\n\n  <div class=\"reviews-grid\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Nothing worked until this<\/p>\n        <p class=\"review-text\">I've struggled with bacne for years and tried everything — nothing worked until I found the Bacne Out Bar. Within a few weeks, my skin was noticeably clearer and my confidence skyrocketed. I'll never go without it. So happy I found this before summer.<\/p>\n        <span class=\"review-reviewer\">— Sarah M.<\/span>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Finally cleared after years of trying<\/p>\n        <p class=\"review-text\">I've had back acne since my teenage years. No matter what I tried — body washes, scrubs, even prescription creams — nothing fully cleared it. After three weeks with the Bacne Out Bar, the redness and inflammation went down and I stopped getting those painful deep breakouts.<\/p>\n        <span class=\"review-reviewer\">— James R.<\/span>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Works magic — and fast<\/p>\n        <p class=\"review-text\">I took the plunge and I'm so glad I did. Been after a product for my bacne especially with summer coming and this is perfect. Been using for a week and it's really working its magic on my back.<\/p>\n        <span class=\"review-reviewer\">— Priya K.<\/span>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <div class=\"reviews-grid\" id=\"extraReviews\" style=\"display:none; margin-top: 16px;\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">My confidence is back for summer<\/p>\n        <p class=\"review-text\">My back acne cleared just in time for summer. Within days my flare-ups calmed down and within 3 weeks my back was visibly clear. No more hiding for this girl!<\/p>\n        <span class=\"review-reviewer\">— Megan T.<\/span>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Didn't dry my skin out at all<\/p>\n        <p class=\"review-text\">I was worried about my skin drying out, as has been the case with other products. But the Bacne Out Bar improved my back so much without irritating it or leaving it feeling tight. I'm over the moon!<\/p>\n        <span class=\"review-reviewer\">— Lauren B.<\/span>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Shocked after just one week<\/p>\n        <p class=\"review-text\">I honestly wasn't sure if it was working after a couple of days, so I kept using it — and good thing too. After one week my boyfriend saw my back and was totally shocked. It does indeed work, and fast.<\/p>\n        <span class=\"review-reviewer\">— Chloe D.<\/span>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <button class=\"reviews-toggle\" id=\"reviewsToggle\" onclick=\"toggleReviews()\">\n    See More Reviews ▾\n  <\/button>\n\n<\/section>\n\n<script>\n  function toggleReviews() {\n    var extra = document.getElementById('extraReviews');\n    var btn = document.getElementById('reviewsToggle');\n    if (extra.style.display === 'none') {\n      extra.style.display = 'grid';\n      btn.textContent = 'Show Less ▴';\n    } else {\n      extra.style.display = 'none';\n      btn.textContent = 'See More Reviews ▾';\n    }\n  }\n<\/script>","full_width":true,"show_divider":false,"padding_top":36,"padding_bottom":36}}},"order":["empty-space","main","product-recommendations","custom_liquid_cqKTNy","scrolling_promotion_6Xj9FQ","image_with_text_X6KRyA","scrolling_promotion_pD6Mdt","custom_liquid_QWbLRi","custom_liquid_PyWqQE"]}