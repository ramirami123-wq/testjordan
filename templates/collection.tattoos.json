    "custom_liquid_YUHDFM": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<section class=\"faq-section\">\n  <div class=\"faq-inner\">\n    <h2 class=\"faq-heading\">Frequently asked questions</h2>\n\n    <div class=\"faq-list\">\n\n      <details class=\"faq-item\" open>\n        <summary class=\"faq-question\">\n          How long do the tattoos actually last?\n          <span class=\"faq-icon\">+</span>\n        </summary>\n        <div class=\"faq-answer\">\n          <p>Up to 14 days with normal wear, depending on your skin type and how much the area is exposed to water and friction. They'll fade gradually, just like a real tattoo would.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary class=\"faq-question\">\n          How do I apply and remove it?\n          <span class=\"faq-icon\">+</span>\n        </summary>\n        <div class=\"faq-answer\">\n          <p>Clean and dry the skin, peel off the clear film, press the design on face-down, and hold a wet cloth over it for 20-30 seconds before peeling the paper backing away. To remove it early, rub gently with baby oil, alcohol, or a makeup wipe.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary class=\"faq-question\">\n          Is it safe for sensitive skin?\n          <span class=\"faq-icon\">+</span>\n        </summary>\n        <div class=\"faq-answer\">\n          <p>Yes, our tattoos use skin-safe, dermatologically tested ink. As with any temporary tattoo, we recommend a small patch test first if you have particularly sensitive or reactive skin.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary class=\"faq-question\">\n          How fast is delivery in Lebanon?\n          <span class=\"faq-icon\">+</span>\n        </summary>\n        <div class=\"faq-answer\">\n          <p>Orders within Lebanon are delivered free of charge and typically arrive within 1-3 business days, depending on your area.</p>\n        </div>\n      </details>\n\n    </div>\n  </div>\n</section>\n\n<style>\n  .faq-section {\n    background: #ffffff;\n    color: #000000;\n    padding: 56px 24px;\n  }\n\n  .faq-inner {\n    max-width: 720px;\n    margin: 0 auto;\n  }\n\n  .faq-heading {\n    font-family: -apple-system, BlinkMacSystemFont, \"Helvetica Neue\", Arial, sans-serif;\n    font-size: 26px;\n    font-weight: 600;\n    letter-spacing: -0.01em;\n    color: #000000;\n    margin: 0 0 28px;\n    text-align: center;\n  }\n\n  .faq-list {\n    display: flex;\n    flex-direction: column;\n  }\n\n  .faq-item {\n    border-bottom: 1px solid #e2e2e2;\n    padding: 18px 0;\n  }\n\n  .faq-item:first-child {\n    border-top: 1px solid #e2e2e2;\n  }\n\n  .faq-question {\n    list-style: none;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    cursor: pointer;\n    font-family: -apple-system, BlinkMacSystemFont, \"Helvetica Neue\", Arial, sans-serif;\n    font-size: 16px;\n    font-weight: 500;\n    color: #000000;\n    line-height: 1.4;\n  }\n\n  .faq-question::-webkit-details-marker {\n    display: none;\n  }\n\n  .faq-icon {\n    flex-shrink: 0;\n    width: 22px;\n    height: 22px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 18px;\n    font-weight: 400;\n    color: #000000;\n    transition: transform 0.2s ease;\n  }\n\n  .faq-item[open] .faq-icon {\n    transform: rotate(45deg);\n  }\n\n  .faq-answer {\n    padding-top: 10px;\n  }\n\n  .faq-answer p {\n    margin: 0;\n    font-family: -apple-system, BlinkMacSystemFont, \"Helvetica Neue\", Arial, sans-serif;\n    font-size: 14px;\n    line-height: 1.6;\n    color: #3a3a3a;\n    max-width: 620px;\n  }\n\n  @media (max-width: 480px) {\n    .faq-heading { font-size: 22px; }\n    .faq-question { font-size: 15px; }\n  }\n</style>",
