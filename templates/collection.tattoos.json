    "custom_liquid_PKJrP8": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<title>Reviews Section</title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body { font-family: -apple-system, BlinkMacSystemFont, \"Helvetica Neue\", Arial, sans-serif; background: #fff; }\n\n  .rv-section {\n    background: #ffffff;\n    color: #000000;\n    padding: 48px 0 56px;\n  }\n\n  .rv-heading {\n    font-size: 26px;\n    font-weight: 600;\n    letter-spacing: -0.01em;\n    color: #000000;\n    margin: 0 0 4px;\n    text-align: center;\n    padding: 0 24px;\n  }\n\n  .rv-subheading {\n    font-size: 14px;\n    color: #666;\n    text-align: center;\n    margin-bottom: 28px;\n    padding: 0 24px;\n  }\n\n  .rv-scroller-wrap {\n    position: relative;\n    padding: 0 24px;\n  }\n\n  .rv-scroller {\n    display: flex;\n    gap: 16px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    padding: 4px 4px 12px;\n    cursor: grab;\n    scrollbar-width: thin;\n    scrollbar-color: #cfcfcf transparent;\n  }\n\n  .rv-scroller.dragging { cursor: grabbing; scroll-snap-type: none; }\n\n  .rv-scroller::-webkit-scrollbar { height: 6px; }\n  .rv-scroller::-webkit-scrollbar-track { background: transparent; }\n  .rv-scroller::-webkit-scrollbar-thumb { background: #d8d8d8; border-radius: 10px; }\n\n  .rv-card {\n    flex: 0 0 auto;\n    width: 260px;\n    scroll-snap-align: start;\n    border: 1px solid #e6e6e6;\n    border-radius: 10px;\n    overflow: hidden;\n    background: #fff;\n    display: flex;\n    flex-direction: column;\n    user-select: none;\n  }\n\n  .rv-img-wrap {\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    overflow: hidden;\n    background: #f4f4f4;\n  }\n\n  .rv-img-wrap img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    -webkit-user-drag: none;\n  }\n\n  .rv-body {\n    padding: 16px;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    flex-grow: 1;\n  }\n\n  .rv-stars {\n    color: #000;\n    font-size: 14px;\n    letter-spacing: 2px;\n  }\n\n  .rv-text {\n    font-size: 13.5px;\n    line-height: 1.55;\n    color: #2a2a2a;\n    flex-grow: 1;\n  }\n\n  .rv-author {\n    font-size: 12.5px;\n    font-weight: 600;\n    color: #000;\n  }\n\n  .rv-nav {\n    display: flex;\n    justify-content: center;\n    gap: 10px;\n    margin-top: 16px;\n  }\n\n  .rv-nav-btn {\n    width: 36px;\n    height: 36px;\n    border-radius: 50%;\n    border: 1px solid #ddd;\n    background: #fff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    transition: background 0.15s ease;\n  }\n\n  .rv-nav-btn:hover { background: #f4f4f4; }\n\n  .rv-nav-btn svg { width: 16px; height: 16px; }\n\n  @media (max-width: 480px) {\n    .rv-heading { font-size: 22px; }\n    .rv-card { width: 220px; }\n    .rv-scroller-wrap { padding: 0 16px; }\n  }\n</style>\n</head>\n<body>\n\n<section class=\"rv-section\">\n  <h2 class=\"rv-heading\">What people are saying</h2>\n  <p class=\"rv-subheading\">All 4 &amp; 5 star reviews from real customers · Swipe to see more</p>\n\n  <div class=\"rv-scroller-wrap\">\n    <div class=\"rv-scroller\" id=\"rvScroller\">\n\n      <div class=\"rv-card\">\n        <div class=\"rv-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0742/4068/8311/files/hf_20260326_071114_5e29cd29-6e63-44bd-8130-6631509658da_1.webp?v=1782981747\" alt=\"Customer photo of tattoo\" loading=\"lazy\" draggable=\"false\" />\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-stars\">★★★★★</div>\n          <p class=\"rv-text\">Survived the beach and a whole week of sunscreen. Looked so real people kept asking where I got it done.</p>\n          <p class=\"rv-author\">— Layla H.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0742/4068/8311/files/hf_20260330_020551_cbbd6806-60dc-475e-96cb-fb56106344f8_1.webp?v=1782981748\" alt=\"Customer photo of tattoo\" loading=\"lazy\" draggable=\"false\" />\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-stars\">★★★★★</div>\n          <p class=\"rv-text\">Application was way easier than expected, on in under a minute. Held up through the gym and showers for almost two weeks.</p>\n          <p class=\"rv-author\">— Karim S.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0742/4068/8311/files/hf_20260329_042518_3f544cb7-62c5-4828-9947-b6dbe90473be_1.webp?v=1782981748\" alt=\"Customer photo of tattoo\" loading=\"lazy\" draggable=\"false\" />\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-stars\">★★★★☆</div>\n          <p class=\"rv-text\">Great detail on the design and it lasted exactly as long as promised. Wish it came with a bit more ink for touch ups.</p>\n          <p class=\"rv-author\">— Maya D.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0742/4068/8311/files/hf_20260330_021038_e0f664d9-5904-4373-a2bb-b6e371c1bcba_1.webp?v=1782981749\" alt=\"Customer photo of tattoo\" loading=\"lazy\" draggable=\"false\" />\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-stars\">★★★★★</div>\n          <p class=\"rv-text\">Ordered for a friend's bachelorette and everyone wanted their own after. Delivery was quick and it looked professional.</p>\n          <p class=\"rv-author\">— Sarah A.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0742/4068/8311/files/hf_20260330_014505_11f01e47-e6f8-49f5-ba18-2e3c7a3bd4b6_1.webp?v=1782981803\" alt=\"Customer photo of tattoo\" loading=\"lazy\" draggable=\"false\" />\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-stars\">★★★★☆</div>\n          <p class=\"rv-text\">Skin felt totally fine the whole time, zero irritation. Took a little longer than 14 days to fully fade on me but still great value.</p>\n          <p class=\"rv-author\">— Tarek N.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0742/4068/8311/files/hf_20260330_015257_2b8ddc37-8075-47ef-85a5-79212ab9082b_1.webp?v=1782981804\" alt=\"Customer photo of tattoo\" loading=\"lazy\" draggable=\"false\" />\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-stars\">★★★★★</div>\n          <p class=\"rv-text\">This is my third order. The placement guide made it easy to center and it genuinely fooled my coworkers for a week straight.</p>\n          <p class=\"rv-author\">— Rana K.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0742/4068/8311/files/hf_20260330_021443_e58582c4-2f58-4d5f-8ed2-efb3cdca226c_1.webp?v=1782981804\" alt=\"Customer photo of tattoo\" loading=\"lazy\" draggable=\"false\" />\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-stars\">★★★★★</div>\n          <p class=\"rv-text\">Way more detailed than I expected for the price. Stayed crisp through a full week of daily workouts and showers.</p>\n          <p class=\"rv-author\">— Noor F.</p>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"rv-nav\">\n      <button class=\"rv-nav-btn\" id=\"rvPrev\" aria-label=\"Scroll left\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M15 18l-6-6 6-6\"/></svg>\n      </button>\n      <button class=\"rv-nav-btn\" id=\"rvNext\" aria-label=\"Scroll right\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 18l6-6-6-6\"/></svg>\n      </button>\n    </div>\n  </div>\n</section>\n\n<script>\n  (function () {\n    const scroller = document.getElementById('rvScroller');\n    const prevBtn = document.getElementById('rvPrev');\n    const nextBtn = document.getElementById('rvNext');\n\n    function cardStep() {\n      const card = scroller.querySelector('.rv-card');\n      if (!card) return 260;\n      const style = getComputedStyle(scroller);\n      const gap = parseFloat(style.columnGap || style.gap || 16);\n      return card.offsetWidth + gap;\n    }\n\n    prevBtn.addEventListener('click', () => {\n      scroller.scrollBy({ left: -cardStep(), behavior: 'smooth' });\n    });\n    nextBtn.addEventListener('click', () => {\n      scroller.scrollBy({ left: cardStep(), behavior: 'smooth' });\n    });\n\n    // Click-and-drag support for desktop mouse users\n    let isDown = false;\n    let startX = 0;\n    let scrollStart = 0;\n\n    scroller.addEventListener('mousedown', (e) => {\n      isDown = true;\n      scroller.classList.add('dragging');\n      startX = e.pageX;\n      scrollStart = scroller.scrollLeft;\n    });\n\n    window.addEventListener('mouseup', () => {\n      isDown = false;\n      scroller.classList.remove('dragging');\n    });\n\n    window.addEventListener('mousemove', (e) => {\n      if (!isDown) return;\n      e.preventDefault();\n      const dx = e.pageX - startX;\n      scroller.scrollLeft = scrollStart - dx;\n    });\n  })();\n</script>\n\n</body>\n</html>",
