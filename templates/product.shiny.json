      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<title>Shiny Bath™ Drying Towel</title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --black: #1c2733;\n    --white: #ffffff;\n    --gray-light: #f5f6f7;\n    --gray-mid: #e0e0e0;\n    --gray-text: #666;\n    --accent: #c9836a;\n    --accent-dark: #a9654e;\n    --green: #1a7f5a;\n    --gold: #e0a800;\n    --font: 'Helvetica Neue', Arial, sans-serif;\n  }\n\n  body { font-family: var(--font); color: var(--black); background: var(--white); line-height: 1.6; }\n\n  /* ── CUSTOMER BANNER ── */\n  .customer-banner {\n    background: var(--black);\n    color: var(--white);\n    padding: 14px 20px;\n    text-align: center;\n    font-size: 14px;\n    font-weight: 600;\n    letter-spacing: 0.5px;\n    width: 100%;\n  }\n  .customer-banner span { color: var(--gold); }\n\n  /* ── SECTION TITLES ── */\n  .section-title {\n    font-size: 30px; font-weight: 800; text-align: center;\n    margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;\n  }\n  .section-subtitle {\n    text-align: center; color: var(--gray-text); font-size: 16px;\n    margin-bottom: 50px; max-width: 680px; margin-left: auto; margin-right: auto;\n  }\n\n  /* ── FEEL BETTER ── */\n  .feel-section { padding: 80px 5%; background: var(--white); }\n  .feel-inner {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;\n  }\n  .feel-img img { width: 100%; border-radius: 14px; object-fit: cover; height: 520px; }\n  .feel-text h2 { font-size: 32px; font-weight: 800; margin-bottom: 20px; line-height: 1.2; }\n  .feel-text p { font-size: 16px; color: #444; margin-bottom: 20px; line-height: 1.7; }\n  .feel-text ul { list-style: none; padding: 0; }\n  .feel-text ul li {\n    padding: 10px 0; font-size: 15px; border-bottom: 1px solid var(--gray-mid);\n    display: flex; align-items: flex-start; gap: 10px;\n  }\n  .feel-text ul li::before {\n    content: \"✓\"; color: var(--green); font-weight: 900; font-size: 17px;\n    flex-shrink: 0; margin-top: 1px;\n  }\n\n  /* ── TESTIMONIAL QUOTE ── */\n  .quote-box {\n    background: var(--gray-light); border-left: 5px solid var(--accent);\n    padding: 24px 28px; border-radius: 0 12px 12px 0; margin-top: 32px;\n  }\n  .quote-box p { font-style: italic; font-size: 16px; color: #333; margin-bottom: 12px; }\n  .quote-author { display: flex; align-items: center; gap: 12px; }\n  .avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; background: var(--accent); }\n  .author-info strong { display: block; font-size: 14px; font-weight: 700; }\n  .author-info span { font-size: 12px; color: var(--gray-text); }\n  .stars { color: var(--gold); font-size: 14px; letter-spacing: 2px; }\n\n  /* ── HOW IT WORKS (dark) ── */\n  .how-section { background: var(--black); padding: 80px 5%; color: var(--white); }\n  .how-section .section-title { color: var(--white); }\n  .how-section .section-subtitle { color: rgba(255,255,255,0.6); }\n  .how-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 28px; }\n  .how-card {\n    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);\n    border-radius: 14px; padding: 32px 24px; text-align: center;\n  }\n  .how-card .icon-wrap {\n    width: 64px; height: 64px; background: var(--accent); border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    margin: 0 auto 20px; font-size: 28px;\n  }\n  .how-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 10px; color: var(--white); text-transform: uppercase; letter-spacing: 0.5px; }\n  .how-card p { font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.6; }\n\n  /* ── TOWEL vs SQUEEGEE ── */\n  .upgrade-section { background: var(--gray-light); padding: 80px 5%; }\n  .upgrade-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 40px; }\n  .upgrade-card { background: var(--white); border-radius: 14px; overflow: hidden; border: 2px solid var(--gray-mid); }\n  .upgrade-card.winner { border-color: var(--black); }\n  .upgrade-card-header { padding: 18px 24px; font-size: 18px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; background: var(--gray-mid); color: var(--black); }\n  .upgrade-card.winner .upgrade-card-header { background: var(--black); color: var(--white); }\n  .upgrade-card img { width: 100%; height: 220px; object-fit: contain; padding: 16px; background: #fafafa; display: block; }\n  .upgrade-list { list-style: none; padding: 20px 24px; }\n  .upgrade-list li { padding: 9px 0; font-size: 14px; border-bottom: 1px solid #f0f0f0; display: flex; align-items: center; gap: 10px; }\n  .upgrade-list li:last-child { border-bottom: none; }\n  .check-green { color: var(--green); font-weight: 900; font-size: 16px; }\n  .check-red   { color: var(--accent); font-weight: 900; font-size: 16px; }\n\n  /* ── RESULTS ── */\n  .results-section { padding: 80px 5%; background: var(--white); }\n  .results-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }\n  .results-img img { width: 100%; border-radius: 14px; height: 500px; object-fit: cover; }\n  .stats-list { display: flex; flex-direction: column; gap: 28px; }\n  .stat-item { display: flex; align-items: flex-start; gap: 20px; }\n  .stat-number { font-size: 52px; font-weight: 900; color: var(--accent); line-height: 1; flex-shrink: 0; min-width: 90px; }\n  .stat-desc { font-size: 15px; color: #444; padding-top: 10px; line-height: 1.5; }\n  .stat-note { font-size: 12px; color: var(--gray-text); margin-top: 24px; font-style: italic; }\n\n  /* ── EXPERT TRUST ── */\n  .expert-section { background: var(--gray-light); padding: 80px 5%; text-align: center; }\n  .expert-img { border-radius: 16px; overflow: hidden; }\n  .expert-img img { width: 100%; display: block; }\n\n  /* ── GUARANTEE ── */\n  .guarantee-section { background: var(--black); color: var(--white); padding: 80px 5%; text-align: center; }\n  .guarantee-section h2 { font-size: 30px; font-weight: 800; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px; }\n  .guarantee-section > p { font-size: 17px; color: rgba(255,255,255,0.75); max-width: 680px; margin: 0 auto 48px; line-height: 1.7; }\n  .trust-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }\n  .trust-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; padding: 24px 16px; }\n  .trust-card .trust-icon { font-size: 32px; margin-bottom: 12px; }\n  .trust-card h4 { font-size: 14px; font-weight: 700; color: var(--white); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.3px; }\n  .trust-card p { font-size: 12px; color: rgba(255,255,255,0.5); margin: 0; }\n\n  /* ── RESPONSIVE ── */\n  @media (max-width: 900px) {\n    .feel-inner, .results-inner, .upgrade-grid { grid-template-columns: 1fr; }\n    .feel-img img, .results-img img { height: 320px; }\n    .how-grid { grid-template-columns: 1fr; }\n    .trust-grid { grid-template-columns: 1fr 1fr; gap: 14px; }\n    .section-title { font-size: 24px; }\n    .stat-number { font-size: 40px; }\n  }\n\n  @media (max-width: 480px) {\n    .feel-section, .how-section, .upgrade-section,\n    .results-section, .expert-section, .guarantee-section { padding: 50px 4%; }\n    .trust-grid { grid-template-columns: 1fr 1fr; gap: 12px; }\n    .trust-card { padding: 18px 12px; }\n    .trust-card .trust-icon { font-size: 26px; }\n    .trust-card h4 { font-size: 12px; }\n    .trust-card p { font-size: 11px; }\n    .guarantee-section h2 { font-size: 22px; }\n    .guarantee-section > p { font-size: 15px; }\n    .feel-text h2 { font-size: 24px; }\n    .stat-number { font-size: 36px; min-width: 72px; }\n  }\n</style>\n</head>\n<body>\n\n<!-- ── BANNER ── -->\n<div class=\"customer-banner\">✨ Trusted By Over <span>105,000+</span> Homeowners — Streak-Free, Guaranteed</div>\n\n<!-- ── FEEL BETTER AGAIN ── -->\n<section class=\"feel-section\">\n  <div class=\"feel-inner\">\n    <div class=\"feel-img\">\n      <img src=\"https://shiny-wipes.com/cdn/shop/files/Reason_1_50335847-3bff-489c-8fd9-21b1fcc359a0.jpg?v=1772111249&width=1500\" alt=\"Shiny Bath Drying Towel in use\" />\n    </div>\n    <div class=\"feel-text\">\n      <h2>A Spotless Bathroom In Under 2 Minutes</h2>\n      <p>Squeegee, scrub, wipe — and by the next morning the white film is already creeping back. The problem was never you. It's the tools. The Shiny Bath™ Drying Towel removes water completely instead of just pushing it around, so there's nothing left behind to dry into spots or harden into scale.</p>\n      <p>Its <strong>dual-fiber construction</strong> pairs a textured side that pulls moisture out of glass, tiles and fixtures with a smooth side that leaves a light barrier so water beads off for hours — the same method professional hotel cleaners have used for years.</p>\n      <ul>\n        <li><div><strong>Streak-free in one pass</strong> — Dries glass, tiles and taps completely so nothing dries into spots or streaks.</div></li>\n        <li><div><strong>Stops limescale at the source</strong> — Removes the water minerals need to build into that stubborn white film.</div></li>\n        <li><div><strong>Holds 5x more water</strong> — Nearly two full cups, so you dry the whole bathroom without stopping to wring it out.</div></li>\n        <li><div><strong>Works on every surface</strong> — Shower glass, tiles, grout, fixtures, mirrors, even car windows and paintwork.</div></li>\n        <li><div><strong>No chemicals needed</strong> — Just the towel and water. Machine washable, lasts 2–3 years with proper care.</div></li>\n      </ul>\n      <div class=\"quote-box\">\n        <p>\"After 12 years cleaning hotel suites, I thought I'd seen every product on the market. Nothing has come close. Streak-free glass in under a minute — that's not something I say lightly.\"</p>\n        <div class=\"quote-author\">\n          <img class=\"avatar\" src=\"https://shiny-wipes.com/cdn/shop/files/Lifestyle3.jpg?v=1776138681&width=100\" alt=\"Linda K.\" />\n          <div class=\"author-info\">\n            <strong>Linda K.</strong>\n            <span>Florida — Professional Housekeeper</span>\n            <div class=\"stars\">★ ★ ★ ★ ★</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ── HOW IT WORKS ── -->\n<section class=\"how-section\">\n  <p class=\"section-title\">How Shiny Bath Works</p>\n  <p class=\"section-subtitle\">One towel, engineered to remove water completely — not just move it around.</p>\n  <div class=\"how-grid\">\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">💧</div>\n      <h3>Absorbs Completely</h3>\n      <p>The textured fiber side pulls moisture out of glass, tiles and fixtures in a single pass, holding nearly two full cups before it needs wringing.</p>\n    </div>\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">✨</div>\n      <h3>Leaves A Barrier</h3>\n      <p>The smooth side leaves a light protective layer so water beads off the surface for hours, instead of settling into the white haze you scrub away.</p>\n    </div>\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">🛡️</div>\n      <h3>Stops Limescale</h3>\n      <p>By eliminating moisture after every shower, minerals never get the chance to dry and build into scale — you're stopping the problem at the source.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── TOWEL vs SQUEEGEE ── -->\n<section class=\"upgrade-section\">\n  <p class=\"section-title\">Shiny Bath™ vs. A Squeegee</p>\n  <p class=\"section-subtitle\">A squeegee just moves water into the corners and grout — exactly where limescale forms. Here's the difference.</p>\n  <div class=\"upgrade-grid\">\n    <div class=\"upgrade-card winner\">\n      <div class=\"upgrade-card-header\">✅ The Shiny Bath™ Towel</div>\n      <img src=\"https://shiny-wipes.com/cdn/shop/files/1erGrau30x40.jpg?v=1773923441&width=1000\" alt=\"Shiny Bath Towel\" />\n      <ul class=\"upgrade-list\">\n        <li><span class=\"check-green\">✓</span> Absorbs water completely in one pass</li>\n        <li><span class=\"check-green\">✓</span> Reaches grout, corners & curved fixtures</li>\n        <li><span class=\"check-green\">✓</span> Leaves a streak-free, spotless finish</li>\n        <li><span class=\"check-green\">✓</span> Stops limescale before it forms</li>\n        <li><span class=\"check-green\">✓</span> Reusable — lasts 2–3 years, machine washable</li>\n        <li><span class=\"check-green\">✓</span> 30-day money-back guarantee</li>\n      </ul>\n    </div>\n    <div class=\"upgrade-card\">\n      <div class=\"upgrade-card-header\">❌ A Standard Squeegee</div>\n      <img src=\"https://shiny-wipes.com/cdn/shop/files/ShinyBathXLDryingTowelcleansyourshowerinunder2minutes.jpg?v=1768832586&width=1000\" alt=\"Squeegee comparison\" style=\"filter:grayscale(0.4);\" />\n      <ul class=\"upgrade-list\">\n        <li><span class=\"check-red\">✗</span> Pushes water around, never removes it</li>\n        <li><span class=\"check-red\">✗</span> Skips grout lines, corners & fixtures</li>\n        <li><span class=\"check-red\">✗</span> Leaves streaks and water marks behind</li>\n        <li><span class=\"check-red\">✗</span> Drives minerals into the exact spots scale forms</li>\n        <li><span class=\"check-red\">✗</span> Constant re-scrubbing every week</li>\n        <li><span class=\"check-red\">✗</span> Still fighting the same white film</li>\n      </ul>\n    </div>\n  </div>\n</section>\n\n<!-- ── RESULTS ── -->\n<section class=\"results-section\">\n  <div class=\"results-inner\">\n    <div class=\"results-img\">\n      <img src=\"https://shiny-wipes.com/cdn/shop/files/3_855d96fd-d481-49d3-949a-54348da7f3da.jpg?v=1774353431&width=1500\" alt=\"Shiny Bath results\" />\n    </div>\n    <div>\n      <h2 style=\"font-size:30px;font-weight:800;margin-bottom:36px;text-transform:uppercase;letter-spacing:1px;\">Results From Day One</h2>\n      <div class=\"stats-list\">\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">2 min</div>\n          <p class=\"stat-desc\">Average time to dry a complete bathroom — shower glass, tiles, fixtures and mirror, one pass each.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">5x</div>\n          <p class=\"stat-desc\">More absorbent than a standard microfiber cloth, holding nearly two full cups of water at once.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">0</div>\n          <p class=\"stat-desc\">Chemicals needed to achieve a perfect, streak-free result. Just the towel and water.</p>\n        </div>\n      </div>\n      <p class=\"stat-note\">*Based on manufacturer testing and customer-reported results. Individual results may vary.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── TRUSTED BY PROS ── -->\n<section class=\"expert-section\">\n  <p class=\"section-title\" style=\"margin-bottom:16px;\">Professionals Swear By It</p>\n  <p class=\"section-subtitle\">Trusted by professional housekeepers and independent cleaning businesses who need streak-free, limescale-free results, fast — every single day.</p>\n  <div class=\"expert-img\">\n    <img src=\"https://shiny-wipes.com/cdn/shop/files/collage_2ae0e925-82bc-4406-820b-6bed002956d3.jpg?v=1776138681&width=1500\" alt=\"Trusted by cleaning professionals\" />\n  </div>\n</section>\n\n<!-- ── GUARANTEE ── -->\n<section class=\"guarantee-section\">\n  <h2>Our Shining Promise To You</h2>\n  <p>We're so confident the Shiny Bath™ Drying Towel will change the way you clean that we take all the risk. Try it in your own bathroom for a full 30 days — your glass, your tiles, your mirrors, your fixtures. If you don't see streak-free, limescale-free results, we'll refund every penny. No questions asked.</p>\n  <div class=\"trust-grid\">\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">🛡️</div>\n      <h4>30-Day Guarantee</h4>\n      <p>Full money-back guarantee if you're not completely satisfied within 30 days.</p>\n    </div>\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">🏨</div>\n      <h4>Pro-Approved</h4>\n      <p>Built on the moisture-elimination method professional hotel cleaners rely on.</p>\n    </div>\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">💬</div>\n      <h4>Friendly Support</h4>\n      <p>Our team is here to help at contact@shiny-wipes.com, Monday through Saturday.</p>\n    </div>\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">♻️</div>\n      <h4>Reusable</h4>\n      <p>One towel replaces bottles of spray and years of disposable cloths.</p>\n    </div>\n  </div>\n</section>\n\n</body>\n</html>",
