" stroke-linejoin=\"round\" opacity=\"0.5\"/>\n          <path d=\"M10 28l12 6 12-6\" stroke=\"#1a1a1a\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.35\"/>\n        </svg>\n      </div>\n      <span class=\"lv-label\">Works On<br>Every Surface</span>\n    </div>\n\n  </div>\n</div>\n\n</body>\n</html>"
