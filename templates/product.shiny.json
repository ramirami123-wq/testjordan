            "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<title>Shiny Bath Features Bar</title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    background: #fff;\n  }\n\n  .lv-features-wrap {\n    padding: 28px 20px 24px;\n    background: #fff;\n    border-bottom: 1px solid #e8e8e8;\n  }\n\n  .lv-tagline {\n    font-size: 15px;\n    color: #333;\n    line-height: 1.55;\n    margin-bottom: 24px;\n    max-width: 520px;\n  }\n\n  .lv-features {\n    display: flex;\n    gap: 0;\n    flex-wrap: nowrap;\n  }\n\n  .lv-feat {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 10px;\n    padding-right: 12px;\n  }\n  .lv-feat:last-child { padding-right: 0; }\n\n  .lv-icon {\n    width: 44px;\n    height: 44px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .lv-icon svg {\n    width: 100%;\n    height: 100%;\n  }\n\n  .lv-label {\n    font-size: 13px;\n    color: #1a1a1a;\n    line-height: 1.35;\n    font-weight: 400;\n  }\n\n  @media (max-width: 480px) {\n    .lv-tagline { font-size: 14px; margin-bottom: 20px; }\n    .lv-feat { padding-right: 8px; }\n    .lv-icon { width: 36px; height: 36px; }\n    .lv-label { font-size: 12px; }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"lv-features-wrap\">\n  <p class=\"lv-tagline\">The dual-fiber drying towel that wipes glass, tiles, and taps streak-free in one pass — holding 5x more water than a regular towel to dry a full bathroom in about 2 minutes.</p>\n  <div class=\"lv-features\">\n\n    <!-- Streak-Free Drying -->\n    <div class=\"lv-feat\">\n      <div class=\"lv-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Sparkle / shine icon -->\n         