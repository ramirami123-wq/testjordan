        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<title>Cleaner, Proven, More Effective</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;1,500&family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;\n    background: #fff;\n  }\n\n  .cp-wrap {\n    padding: 72px 20px 64px;\n    background: linear-gradient(180deg, #FBF6F8 0%, #FBF6F8 40%, #ffffff 100%);\n  }\n\n  .cp-inner { max-width: 760px; margin: 0 auto; }\n\n  .cp-eyebrow {\n    font-size: 12px;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: #A8577A;\n    font-weight: 600;\n    text-align: center;\n    margin-bottom: 14px;\n  }\n\n  .cp-heading {\n    font-family: 'Fraunces', Georgia, serif;\n    font-weight: 500;\n    font-style: italic;\n    font-size: clamp(28px, 4vw, 40px);\n    color: #2B1B26;\n    text-align: center;\n    line-height: 1.15;\n    margin-bottom: 44px;\n  }\n\n  .cp-cards {\n    display: grid;\n    grid-template-columns: 1.15fr 1fr;\n    gap: 20px;\n    align-items: stretch;\n  }\n\n  .cp-card {\n    border-radius: 20px;\n    padding: 28px 24px;\n    opacity: 0;\n    transform: translateY(16px);\n    transition: opacity 0.6s ease, transform 0.6s ease;\n  }\n\n  .cp-card.cp-in { opacity: 1; transform: translateY(0); }\n\n  .cp-card-brand {\n    background: #FFFFFF;\n    border: 1.5px solid #EFD9E3;\n    box-shadow: 0 18px 40px -18px rgba(139, 58, 98, 0.35);\n    position: relative;\n  }\n\n  .cp-badge {\n    position: absolute;\n    top: -13px;\n    left: 24px;\n    background: #8B3A62;\n    color: #fff;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    padding: 5px 12px;\n    border-radius: 100px;\n  }\n\n  .cp-card-other {\n    background: #F7F5F4;\n    border: 1.5px solid #ECEAE8;\n  }\n\n  .cp-card-title {\n    font-size: 17px;\n    font-weight: 700;\n    margin-bottom: 2px;\n  }\n\n  .cp-card-brand .cp-card-title { color: #6B1F45; }\n  .cp-card-other .cp-card-title { color: #8A8582; }\n\n  .cp-card-sub {\n    font-size: 12.5px;\n    color: #9C9793;\n    margin-bottom: 22px;\n  }\n\n  .cp-row {\n    display: flex;\n    align-items: flex-start;\n    gap: 10px;\n    padding: 12px 0;\n    border-top: 1px solid rgba(0,0,0,0.06);\n  }\n\n  .cp-row:first-of-type { border-top: none; }\n\n  .cp-icon {\n    width: 20px;\n    height: 20px;\n    flex-shrink: 0;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-top: 1px;\n  }\n\n  .cp-card-brand .cp-icon { background: #E9F5EE; }\n  .cp-card-other .cp-icon { background: #F0EEEC; }\n\n  .cp-icon svg { width: 11px; height: 11px; }\n\n  .cp-row-text { font-size: 13.5px; line-height: 1.4; }\n\n  .cp-row-label {\n    display: block;\n    font-size: 11px;\n    color: #A39C9C;\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n    margin-bottom: 2px;\n  }\n\n  .cp-card-brand .cp-row-value { color: #2B1B26; font-weight: 600; }\n  .cp-card-other .cp-row-value { color: #918C89; font-weight: 500; }\n\n  @media (max-width: 620px) {\n    .cp-cards { grid-template-columns: 1fr; }\n    .cp-card-other { order: 2; }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"cp-wrap\">\n  <div class=\"cp-inner\">\n    <p class=\"cp-eyebrow\">The Difference</p>\n    <h2 class=\"cp-heading\">Cleaner, Proven,<br>More Effective</h2>\n\n    <div class=\"cp-cards\">\n\n      <div class=\"cp-card cp-card-brand\">\n        <span class=\"cp-badge\">goPure</span>\n        <p class=\"cp-card-title\">Instant Lift Eye Gel</p>\n        <p class=\"cp-card-sub\">What you actually get</p>\n\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6.5L4.5 9L10 3\" stroke=\"#4CAF82\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Price</span><span class=\"cp-row-value\">As low as $23.99</span></span>\n        </div>\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6.5L4.5 9L10 3\" stroke=\"#4CAF82\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Quick visible results</span><span class=\"cp-row-value\">In 5 minutes</span></span>\n        </div>\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6.5L4.5 9L10 3\" stroke=\"#4CAF82\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Long-term benefits</span><span class=\"cp-row-value\">Depuffs, tightens, lifts</span></span>\n        </div>\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6.5L4.5 9L10 3\" stroke=\"#4CAF82\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Technology</span><span class=\"cp-row-value\">MaxLift3 Biotech&trade;</span></span>\n        </div>\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6.5L4.5 9L10 3\" stroke=\"#4CAF82\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Guarantee</span><span class=\"cp-row-value\">60-day money-back</span></span>\n        </div>\n      </div>\n\n      <div class=\"cp-card cp-card-other\">\n        <p class=\"cp-card-title\">Luxury Eye Serum</p>\n        <p class=\"cp-card-sub\">The typical alternative</p>\n\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 3L9 9M9 3L3 9\" stroke=\"#B7AFAC\" stroke-width=\"1.8\" stroke-linecap=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Price</span><span class=\"cp-row-value\">$60+</span></span>\n        </div>\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 3L9 9M9 3L3 9\" stroke=\"#B7AFAC\" stroke-width=\"1.8\" stroke-linecap=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Quick visible results</span><span class=\"cp-row-value\">In 10 minutes</span></span>\n        </div>\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 3L9 9M9 3L3 9\" stroke=\"#B7AFAC\" stroke-width=\"1.8\" stroke-linecap=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Long-term benefits</span><span class=\"cp-row-value\">None</span></span>\n        </div>\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 3L9 9M9 3L3 9\" stroke=\"#B7AFAC\" stroke-width=\"1.8\" stroke-linecap=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Technology</span><span class=\"cp-row-value\">Generic formula</span></span>\n        </div>\n        <div class=\"cp-row\">\n          <span class=\"cp-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 3L9 9M9 3L3 9\" stroke=\"#B7AFAC\" stroke-width=\"1.8\" stroke-linecap=\"round\"/></svg></span>\n          <span class=\"cp-row-text\"><span class=\"cp-row-label\">Guarantee</span><span class=\"cp-row-value\">No guarantee</span></span>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n  const cards = document.querySelectorAll('.cp-card');\n  const observer = new IntersectionObserver((entries) => {\n    entries.forEach((entry, i) => {\n      if (entry.isIntersecting) {\n        const idx = Array.from(cards).indexOf(entry.target);\n        setTimeout(() => entry.target.classList.add('cp-in'), idx * 150);\n        observer.unobserve(entry.target);\n      }\n    });\n  }, { threshold: 0.25 });\n\n  cards.forEach(card => observer.observe(card));\n</script>\n\n</body>\n</html>",
