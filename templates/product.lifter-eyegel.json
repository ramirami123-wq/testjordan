      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<title>Consumer Approved</title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    background: #fff;\n  }\n\n  .ca-wrap {\n    padding: 60px 20px 56px;\n    background: #fff;\n    text-align: center;\n  }\n\n  .ca-heading {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-size: 34px;\n    color: #1a1a1a;\n    margin-bottom: 44px;\n  }\n\n  .ca-stats {\n    display: flex;\n    justify-content: center;\n    gap: 48px;\n    max-width: 900px;\n    margin: 0 auto;\n    flex-wrap: wrap;\n  }\n\n  .ca-stat {\n    flex: 1;\n    min-width: 220px;\n    max-width: 260px;\n    opacity: 0;\n    transform: translateY(18px);\n    transition: opacity 0.7s ease, transform 0.7s ease;\n  }\n\n  .ca-stat.ca-in {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .ca-ring {\n    width: 140px;\n    height: 140px;\n    margin: 0 auto 20px;\n    position: relative;\n  }\n\n  .ca-ring svg { width: 100%; height: 100%; transform: rotate(-90deg); }\n\n  .ca-ring-bg { fill: none; stroke: #f0e9f5; stroke-width: 8; }\n\n  .ca-ring-fg {\n    fill: none;\n    stroke: #7a3fa0;\n    stroke-width: 8;\n    stroke-linecap: round;\n    stroke-dasharray: 377;\n    stroke-dashoffset: 377;\n    transition: stroke-dashoffset 1.6s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n\n  .ca-pct {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    font-size: 30px;\n    font-weight: 700;\n    color: #1a1a1a;\n  }\n\n  .ca-desc {\n    font-size: 14.5px;\n    color: #333;\n    line-height: 1.45;\n    max-width: 220px;\n    margin: 0 auto;\n  }\n\n  .ca-footnotes {\n    max-width: 700px;\n    margin: 40px auto 0;\n    font-size: 11.5px;\n    color: #888;\n    line-height: 1.6;\n    text-align: center;\n  }\n\n  @media (max-width: 640px) {\n    .ca-heading { font-size: 26px; margin-bottom: 32px; }\n    .ca-stats { gap: 28px; }\n    .ca-ring { width: 110px; height: 110px; }\n    .ca-pct { font-size: 24px; }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"ca-wrap\">\n  <h2 class=\"ca-heading\">Consumer Approved</h2>\n\n  <div class=\"ca-stats\">\n\n    <div class=\"ca-stat\" data-pct=\"95\">\n      <div class=\"ca-ring\">\n        <svg viewBox=\"0 0 130 130\">\n          <circle class=\"ca-ring-bg\" cx=\"65\" cy=\"65\" r=\"60\"/>\n          <circle class=\"ca-ring-fg\" cx=\"65\" cy=\"65\" r=\"60\"/>\n        </svg>\n        <span class=\"ca-pct\">0%</span>\n      </div>\n      <p class=\"ca-desc\">Said their under eyes looked less tired and fatigued<sup>1</sup></p>\n    </div>\n\n    <div class=\"ca-stat\" data-pct=\"93\">\n      <div class=\"ca-ring\">\n        <svg viewBox=\"0 0 130 130\">\n          <circle class=\"ca-ring-bg\" cx=\"65\" cy=\"65\" r=\"60\"/>\n          <circle class=\"ca-ring-fg\" cx=\"65\" cy=\"65\" r=\"60\"/>\n        </svg>\n        <span class=\"ca-pct\">0%</span>\n      </div>\n      <p class=\"ca-desc\">Said their eyes look less puffy<sup>1</sup></p>\n    </div>\n\n    <div class=\"ca-stat\" data-pct=\"90\">\n      <div class=\"ca-ring\">\n        <svg viewBox=\"0 0 130 130\">\n          <circle class=\"ca-ring-bg\" cx=\"65\" cy=\"65\" r=\"60\"/>\n          <circle class=\"ca-ring-fg\" cx=\"65\" cy=\"65\" r=\"60\"/>\n        </svg>\n        <span class=\"ca-pct\">0%</span>\n      </div>\n      <p class=\"ca-desc\">Said it tightens sagging under eye bags<sup>2</sup></p>\n    </div>\n\n  </div>\n\n  <p class=\"ca-footnotes\">\n    ¹ Based on consumer perception questionnaire of 31 participants after 5 minutes<br>\n    ² Based on consumer perception questionnaire of 31 participants after 4 weeks\n  </p>\n</div>\n\n<script>\n  const circumference = 377; // 2 * PI * r(60)\n\n  function animateStat(el) {\n    const pct = parseInt(el.dataset.pct, 10);\n    const ring = el.querySelector('.ca-ring-fg');\n    const label = el.querySelector('.ca-pct');\n\n    el.classList.add('ca-in');\n    ring.style.strokeDashoffset = circumference - (circumference * pct / 100);\n\n    const duration = 1600;\n    const start = performance.now();\n\n    function tick(now) {\n      const progress = Math.min((now - start) / duration, 1);\n      const eased = 1 - Math.pow(1 - progress, 3);\n      label.textContent = Math.round(eased * pct) + '%';\n      if (progress < 1) requestAnimationFrame(tick);\n    }\n    requestAnimationFrame(tick);\n  }\n\n  const stats = document.querySelectorAll('.ca-stat');\n  const observer = new IntersectionObserver((entries) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        animateStat(entry.target);\n        observer.unobserve(entry.target);\n      }\n    });\n  }, { threshold: 0.4 });\n\n  stats.forEach(stat => observer.observe(stat));\n</script>\n\n</body>\n</html>",
