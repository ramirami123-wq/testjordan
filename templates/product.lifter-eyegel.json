0 30 6 22z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <circle cx=\"22\" cy=\"22\" r=\"5\" stroke=\"#1a1a1a\" stroke-width=\"1.6\"/>\n          <path d=\"M14 12l-2-3M30 12l2-3\" stroke=\"#1a1a1a\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n        </svg>\n      </div>\n      <span class=\"gp-label\">Visibly<br>Lifts Skin</span>\n    </div>\n\n    <!-- Arctic Microalgae / Cooling -->\n    <div class=\"gp-feat\">\n      <div class=\"gp-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Snowflake icon -->\n          <line x1=\"22\" y1=\"6\" x2=\"22\" y2=\"38\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n          <line x1=\"8\" y1=\"15\" x2=\"36\" y2=\"29\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n          <line x1=\"36\" y1=\"15\" x2=\"8\" y2=\"29\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n          <path d=\"M22 6l-3 4M22 6l3 4M22 38l-3-4M22 38l3-4\" stroke=\"#1a1a1a\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n          <path d=\"M8 15l1 5M8 15l5-1M36 29l-1-5M36 29l-5 1\" stroke=\"#1a1a1a\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n          <path d=\"M36 15l-5-1M36 15l-1 5M8 29l5 1M8 29l1-5\" stroke=\"#1a1a1a\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n        </svg>\n      </div>\n      <span class=\"gp-label\">Reduces<br>Puffiness</span>\n    </div>\n\n    <!-- MaxLift3 Biotech Complex -->\n    <div class=\"gp-feat\">\n      <div class=\"gp-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Molecule / biotech icon -->\n          <circle cx=\"14\" cy=\"14\" r=\"4\" stroke=\"#1a1a1a\" stroke-width=\"1.6\"/>\n          <circle cx=\"30\" cy=\"14\" r=\"4\" stroke=\"#1a1a1a\" stroke-width=\"1.6\"/>\n          <circle cx=\"22\" cy=\"30\" r=\"4\" stroke=\"#1a1a1a\" stroke-width=\"1.6\"/>