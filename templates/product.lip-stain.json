t","enable_video_looping":false,"video_url":"","use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","gradient_background":"","padding_top":36,"padding_bottom":36}},"scrolling_promotion_6Xj9FQ":{"type":"scrolling-promotion","blocks":{"announcement_QJYrYr":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_QJYrYr"],"disabled":true,"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"image_with_text_X6KRyA":{"type":"image-with-text","blocks":{"heading_Y6bCpT":{"type":"heading","settings":{"heading":"The Wings every girl dreams about","heading_size":"h1","heading_tag":"h2"}},"text_fXwrbU":{"type":"text","settings":{"text":"<p>Imagine effortlessly creating flawless, symmetrical winged eyeliner in seconds—no more <strong>shaky <\/strong>hands, <strong>uneven <\/strong>lines, or countless <strong>attempts<\/strong> to get both eyes to match.<\/p>","text_size":"typeset2","secondary_color":false}}},"block_order":["heading_Y6bCpT","text_fXwrbU"],"disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/73869677-F4A8-4401-8032-7FD4C16C25BD_1060x_0331b5a5-d549-4c42-aed4-bc24160e24f9.png","image_position":"center center","layout":"image_first","text_box_position":"middle","text_alignment":"left","image_ratio":"650px","enlarge_content":false,"full_width":false,"show_divider":false,"image_behavior":"none","mobile_layout":"image_first","mobile_text_alignment":"left","mobile_image_ratio":"auto","enable_video_looping":false,"video_url":"","use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","gradient_background":"","padding_top":36,"padding_bottom":36}},"scrolling_promotion_pD6Mdt":{"type":"scrolling-promotion","blocks":{"announcement_CR4hbT":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_CR4hbT"],"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"custom_liquid_tFpiC6":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n.faq-section{background:#fff;padding:48px 24px;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;max-width:800px;margin:0 auto;box-sizing:border-box}\n.faq-title{font-family:Georgia,'Times New Roman',serif;font-style:italic;font-weight:400;font-size:clamp(24px,4vw,38px);color:#c9836a;text-align:center;margin:0 0 36px}\n.faq-list{display:flex;flex-direction:column;gap:10px}\n.faq-item{background:#faf3ef;border-radius:12px;overflow:hidden}\n.faq-question{width:100%;background:none;border:none;padding:18px 20px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;text-align:left;gap:16px}\n.faq-question span{font-size:15px;font-weight:600;color:#222;line-height:1.4}\n.faq-icon{font-size:22px;color:#aaa;font-weight:300;flex-shrink:0;transition:transform 0.25s ease;line-height:1}\n.faq-item.open .faq-icon{transform:rotate(45deg);color:#c9836a}\n.faq-answer{max-height:0;overflow:hidden;transition:max-height 0.3s ease,padding 0.3s ease;padding:0 20px}\n.faq-item.open .faq-answer{max-height:300px;padding:0 20px 18px}\n.faq-answer p{font-size:14px;color:#555;line-height:1.7;margin:0}\n<\/style>\n\n<div class=\"faq-section\">\n  <h2 class=\"faq-title\">frequently asked questions<\/h2>\n  <div class=\"faq-list\">\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How long does the lip stain actually last?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>The Wonder Blading Lip Stain lasts up to 10 hours with the Peel & Reveal method. The stain infuses pigment directly into the top layer of your lips, so it doesn't sit on the surface — it stays put through eating, drinking, and everything in between.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Why does it go on blue?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>The blue colour is just the masque formula — it's not the final shade. Once you wipe or peel it off, the true pigment underneath is revealed on your lips. Every shade starts blue when applied; that's the magic of the Wonder Blading technology.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>What's the difference between Stain & Go and Peel & Reveal?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Stain & Go is the quick method — apply 1–2 coats, wait 10–30 seconds, then wipe off with a damp cloth. It gives a natural, everyday tint. Peel & Reveal uses the Activator Mist on top to seal the masque into a film you can peel away, delivering a more intense colour and longer wear time.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Is it safe for sensitive lips or dry skin?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Yes — the formula is vegan, cruelty-free, paraben-free, and gluten-free. It contains squalane to keep lips hydrated and comfortable throughout the day. If your lips are very dry, we recommend exfoliating beforehand for the most even result.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Can I wear gloss or balm on top?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Absolutely. Once the stain sets, you can layer any lip balm, gloss, or oil on top without affecting the colour. The stain won't transfer to whatever you apply over it — so you get all the shine with none of the smudge.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How do I remove it?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Use an oil-based makeup remover or cleanser — the same kind you'd use for waterproof mascara. Since the stain is designed to last, a quick rinse with water won't fully remove it. A few seconds with an oil-based remover does the job cleanly.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<script>\nfunction toggleFaq(btn){\n  const item = btn.closest('.faq-item');\n  const isOpen = item.classList.contains('open');\n  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));\n  if (!isOpen) item.classList.add('open');\n}\n<\/script>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"custom_liquid_WCgwGn":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n.reviews-section{background:#ffffff;padding:48px 20px 60px;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;text-align:center;box-sizing:border-box;width:100%}\n.reviews-hearts{color:#c9836a;font-size:18px;letter-spacing:6px;margin-bottom:12px}\n.reviews-title{font-family:Georgia,'Times New Roman',serif;font-style:italic;font-weight:400;font-size:clamp(24px,4vw,40px);color:#c9836a;margin:0 0 36px}\n.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:1200px;margin:0 auto;box-sizing:border-box;width:100%}\n.review-card{background:#ffffff;border:1.5px solid #e8e8e8;border-radius:12px;text-align:left;display:flex;flex-direction:column;box-sizing:border-box;width:100%;min-width:0}\n.review-body{padding:24px 20px 28px;display:flex;flex-direction:column;gap:6px;box-sizing:border-box;flex:1;min-width:0}\n.review-verified{font-size:11px;font-weight:700;color:#c9836a;letter-spacing:.06em;text-transform:uppercase}\n.review-stars{color:#c9836a;font-size:16px;letter-spacing:2px;margin-bottom:4px}\n.review-title{font-size:15px;font-weight:800;color:#111111;line-height:1.3;margin:0;white-space:normal;overflow-wrap:break-word;word-break:break-word;width:100%}\n.review-text{font-size:13px;color:#444444;line-height:1.6;margin:0;overflow-wrap:break-word;word-break:break-word;white-space:normal;width:100%}\n.review-name{font-size:12px;color:#999;margin-top:6px}\n.reviews-toggle{margin-top:32px;background:none;border:2px solid #c9836a;color:#c9836a;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;font-weight:700;letter-spacing:.04em;padding:12px 32px;border-radius:100px;cursor:pointer;transition:background .2s,color .2s}\n.reviews-toggle:hover{background:#c9836a;color:#ffffff}\n@media(max-width:900px){.reviews-grid{grid-template-columns:repeat(2,1fr)}}\n@media(max-width:540px){.reviews-section{padding:36px 16px 48px}.reviews-grid{grid-template-columns:1fr;width:100%}.review-card{width:100%}}\n<\/style>\n\n<section class=\"reviews-section\">\n  <div class=\"reviews-hearts\">♥ ♥ ♥ ♥ ♥<\/div>\n  <h2 class=\"reviews-title\">Real lips. Real results.<\/h2>\n\n  <div class=\"reviews-grid\">\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">I applied it at 8am and it was still on at 8pm<\/p>\n        <p class=\"review-text\">I was fully prepared to be disappointed — every \"long-lasting\" lip product I've tried fades within two hours. This one genuinely didn't budge. Wore it through coffee, lunch, and a workout. Absolutely obsessed.<\/p>\n        <span class=\"review-name\">— Sara M.<\/span>\n      <\/div>\n    <\/div>\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Looks like my lips, but a better version<\/p>\n        <p class=\"review-text\">The shade Whimsical is exactly my natural lip colour but more even and polished. I've had people ask if I got a lip treatment. It's that natural-looking. Zero dry feeling, which I was worried about.<\/p>\n        <span class=\"review-name\">— Nour K.<\/span>\n      <\/div>\n    <\/div>\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">No transfer — not even on my mask<\/p>\n        <p class=\"review-text\">I work in a clinic and still wear a mask for long shifts. Every lip product I own ends up all over it. This one? Nothing. Clean mask, perfect colour on my lips. That alone makes it worth every penny.<\/p>\n        <span class=\"review-name\">— Lara T.<\/span>\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <div class=\"reviews-grid\" id=\"extraReviews\" style=\"display:none;margin-top:16px\">\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">The peeling part is so satisfying<\/p>\n        <p class=\"review-text\">I was sceptical about the whole blue masque thing — looked strange going on. But peeling it off to reveal that perfect colour is genuinely one of the most satisfying things I've done in my skincare routine. And it lasts all day.<\/p>\n        <span class=\"review-name\">— Maya R.<\/span>\n      <\/div>\n    <\/div>\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">My lips feel soft, not stripped<\/p>\n        <p class=\"review-text\">Most long-wear formulas leave my lips feeling tight and dry after a few hours. This one actually feels hydrating. I added a clear gloss on top and it looked incredible — and stayed on just as long.<\/p>\n        <span class=\"review-name\">— Dina A.<\/span>\n      <\/div>\n    <\/div>\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Already on my third order<\/p>\n        <p class=\"review-text\">I've tried the dupes and nothing comes close. The colour payoff, the staying power, the way it doesn't crack or fade unevenly — it's just in a different league. XOXO is my everyday shade now and I won't go back.<\/p>\n        <span class=\"review-name\">— Joelle B.<\/span>\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <button class=\"reviews-toggle\" id=\"reviewsToggle\" onclick=\"toggleReviews()\">See More Reviews ▾<\/button>\n<\/section>\n\n<script>\nfunction toggleReviews(){\n  var e=document.getElementById('extraReviews'),b=document.getElementById('reviewsToggle');\n  if(e.style.display==='none'){e.style.display='grid';b.textContent='Show Less ▴'}\n  else{e.style.display='none';b.textContent='See More Reviews ▾'}\n}\n<\/script>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}}},"order":["empty-space","main","product-recommendations","custom_liquid_jcTmUf","custom_liquid_n9Ja7k","image_with_text_Pr7JFk","image_with_text_EcxpFh","scrolling_promotion_6Xj9FQ","image_with_text_X6KRyA","scrolling_promotion_pD6Mdt","custom_liquid_tFpiC6","custom_liquid_WCgwGn"]}