mer__colon\">:<\/div>\n      <div class=\"sale-timer__box\" id=\"st-secs\">00<\/div>\n    <\/div>\n  <\/div>\n\n  <script>\n    (function () {\n      const durationHours = 12; \/\/ change if needed\n      const endAt = Date.now() + durationHours * 60 * 60 * 1000;\n\n      const h = document.getElementById(\"st-hours\");\n      const m = document.getElementById(\"st-mins\");\n      const s = document.getElementById(\"st-secs\");\n\n      const pad = n => String(n).padStart(2, \"0\");\n\n      function update(){\n        let diff = endAt - Date.now();\n        if(diff < 0) diff = 0;\n\n        const total = Math.floor(diff \/ 1000);\n        h.textContent = pad(Math.floor(total \/ 3600));\n        m.textContent = pad(Math.floor((total % 3600) \/ 60));\n        s.textContent = pad(total % 60);\n\n        if(diff === 0) clearInterval(timer);\n      }\n\n      update();\n      const timer = setInterval(update, 1000);\n    })();\n  <\/script>\n<\/section>"}},"text_XfnRxT":{"type":"text","disabled":true,"settings":{"icon":"none","text":"Transform your face with this vegan, cruelty-free foundation designed to deliver the perfect match of your skin tone.","text_style":"body"}},"custom_liquid_H9DXEK":{"type":"custom_liquid","settings":{"custom_liquid":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" \/>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" \/>\n<title>Jolie Eyelash Serum Features Bar<\/title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    background: #fff;\n  }\n\n  .lv-features-wrap {\n    padding: 28px 20px 24px;\n    background: #fff;\n    border-bottom: 1px solid #e8e8e8;\n  }\n\n  .lv-tagline {\n    font-size: 15px;\n    color: #333;\n    line-height: 1.55;\n    margin-bottom: 24px;\n    max-width: 520px;\n  }\n\n  .lv-features {\n    display: flex;\n    gap: 0;\n    flex-wrap: nowrap;\n  }\n\n  .lv-feat {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    gap: 10px;\n    padding-right: 12px;\n  }\n  .lv-feat:last-child { padding-right: 0; }\n\n  .lv-icon {\n    width: 44px;\n    height: 44px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .lv-icon svg {\n    width: 100%;\n    height: 100%;\n  }\n\n  .lv-label {\n    font-size: 13px;\n    color: #1a1a1a;\n    line-height: 1.35;\n    font-weight: 400;\n  }\n\n  @media (max-width: 480px) {\n    .lv-tagline { font-size: 14px; margin-bottom: 20px; }\n    .lv-feat { padding-right: 8px; }\n    .lv-icon { width: 36px; height: 36px; }\n    .lv-label { font-size: 12px; }\n  }\n<\/style>\n<\/head>\n<body>\n\n<div class=\"lv-features-wrap\">\n  <p class=\"lv-tagline\">A peptide-powered lash serum that conditions lashes for a fuller, longer look — formulated with ginseng, rosemary, and biotin, and gentle enough for sensitive eyes and extensions.<\/p>\n  <div class=\"lv-features\">\n\n    <!-- Peptide Formula -->\n    <div class=\"lv-feat\">\n      <div class=\"lv-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n          <!-- Eyelash \/ eye -->\n          <path d=\"M7 26c4-6 9-9 15-9s11 3 15 9\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n          <path d=\"M22 30a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n          <path d=\"M22 30v5M14 28l-2.5 4M30 28l2.5 4M10 26l-3.5 2.5M34 26l3.5 2.5\" stroke=\"#1a1a1a\" stroke-width=\"1.5\" stroke-linecap=\"round\"\/>\n        <\/svg>\n      <\/div>\n      <span class=\"lv-label\">Fuller-Looking<br>Lashes<\/span>\n    <\/div>\n\n    <!-- Botanical \/ Natural -->\n    <div class=\"lv-feat\">\n      <div class=\"lv-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n          <!-- Leaf \/ botanical -->\n          <path d=\"M22 35V16\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\"\/>\n          <path d=\"M22 22c-1.5-5-5.5-8-10.5-8 0 5 3 9 8 10\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n          <path d=\"M22 18c1.5-5 5.5-8 10.5-8 0 5-3 9-8 10\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n        <\/svg>\n      <\/div>\n      <span class=\"lv-label\">Botanical<br>Peptide Blend<\/span>\n    <\/div>\n\n    <!-- Gentle \/ Safe -->\n    <div class=\"lv-feat\">\n      <div class=\"lv-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n          <!-- Heart \/ gentle -->\n          <path d=\"M22 33c-7-4.5-11-9-11-14a6 6 0 0 1 11-3.2A6 6 0 0 1 33 19c0 5-4 9.5-11 14z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n        <\/svg>\n      <\/div>\n      <span class=\"lv-label\">Gentle on<br>Sensitive Eyes<\/span>\n    <\/div>\n\n    <!-- Guarantee -->\n    <div class=\"lv-feat\">\n      <div class=\"lv-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n          <!-- Shield + check -->\n          <path d=\"M22 8l12 4v8c0 8-5 13-12 16-7-3-12-8-12-16v-8l12-4z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n          <path d=\"M16 22l4.5 4.5L29 18\" stroke=\"#1a1a1a\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n        <\/svg>\n      <\/div>\n      <span class=\"lv-label\">60-Night<br>Guarantee<\/span>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<\/body>\n<\/html>"}},"variant_picker":{"type":"variant_picker","disabled":true,"settings":{"show_variant_labels":true,"picker_type":"dropdown","enable_color_swatches":true,"swatches_source":"file","swatch_type":"round","enable_swatch_cross