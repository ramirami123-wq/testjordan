er: 1.5px solid #c9836a;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .mms-icon-circle svg {\n    width: 34px;\n    height: 34px;\n  }\n  .mms-icon-label {\n    font-size: 13px;\n    color: #5C4033;\n    text-align: center;\n    font-weight: 500;\n  }\n  @media (max-width: 700px) {\n    .mms-icon-circle {\n      width: 60px;\n      height: 60px;\n    }\n    .mms-icon-circle svg {\n      width: 28px;\n      height: 28px;\n    }\n  }\n<\/style>\n\n<div class=\"mms-section\">\n  <div class=\"mms-inner\">\n    <div class=\"mms-content\">\n\n      <h2 class=\"mms-heading\">Longer, Fuller<br>Looking Lashes<\/h2>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">Cares for your lashes at the root.<\/p>\n        <p class=\"mms-block-desc\">Our peptide-botanical formula works <em>with<\/em> your natural lash cycle — nourishing each lash with ginseng, rosemary, and biotin so they look fuller, stronger, and less prone to breakage. No mascara, no falsies, no covering up — just your own lashes, looking their best.<\/p>\n      <\/div>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">Gentle enough for everyday use.<\/p>\n        <p class=\"mms-block-desc\">Prostaglandin-free, fragrance-free, and oil-free, so it's safe for sensitive eyes, contact lens wearers, and lash extensions. One thin line before bed is all it takes — a 10-second step that works overnight while you sleep.<\/p>\n      <\/div>\n\n      <div class=\"mms-icons\">\n\n        <!-- Fuller Lashes -->\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M5 21c3.5-5 7.5-7.5 13-7.5S27.5 16 31 21\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n              <path d=\"M18 24.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n              <path d=\"M18 24.5v4M11 23l-2 3.5M25 23l2 3.5M8 21l-3 2M28 21l3 2\" stroke=\"#c47a50\" stroke-width=\"1.4\" stroke-linecap=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">Fuller Lashes<\/span>\n        <\/div>\n\n        <!-- Botanical Peptides -->\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M18 29V13\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\"\/>\n              <path d=\"M18 18c-1.2-4-4.5-6.5-8.5-6.5 0 4 2.5 7.5 6.5 8\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n              <path d=\"M18 15c1.2-4 4.5-6.5 8.5-6.5 0 4-2.5 7.5-6.5 8\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">Botanical Peptides<\/span>\n        <\/div>\n\n        <!-- Gentle & Safe -->\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M18 27c-5.5-3.5-9-7-9-11a5 5 0 0 1 9-2.6A5 5 0 0 1 27 16c0 4-3.5 7.5-9 11z\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">Gentle &amp; Safe<\/span>\n        <\/div>\n\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"scrolling_promotion_6Xj9FQ":{"type":"scrolling-promotion","blocks":{"announcement_QJYrYr":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_QJYrYr"],"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"image_with_text_X6KRyA":{"type":"image-with-text","blocks":{"heading_Y6bCpT":{"type":"heading","settings":{"heading":"Natural-Looking Freckles (No Skill, No Effort)","heading_size":"h1","heading_tag":"h2"}},"text_fXwrbU":{"type":"text","settings":{"text":"<p>Tired of <strong>uneven <\/strong>dots, streaky pencils, or freckles that look fake by lunchtime? This multi-point freckle stamp was built for real <strong>humans <\/strong>— not makeup artists.<\/p>","text_size":"typeset2","secondary_color":false}}},"block_order":["heading_Y6bCpT","text_fXwrbU"],"disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/73869677-F4A8-4401-8032-7FD4C16C25BD_1060x_0331b5a5-d549-4c42-aed4-bc24160e24f9.png","image_position":"center center","layout":"image_first","text_box_position":"middle","text_alignment":"left","image_ratio":"650px","enlarge_content":false,"full_width":false,"show_divider":false,"image_behavior":"none","mobile_layout":"image_first","mobile_text_alignment":"left","mobile_image_ratio":"auto","enable_video_looping":false,"video_url":"","use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","gradient_background":"","padding_top":36,"padding_bottom":36}},"scrolling_promotion_pD6Mdt":{"type":"scrolling-promotion","blocks":{"announcement_CR4hbT":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_CR4hbT"],"disabled":true,"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"custom_liquid_QWbLRi":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .faq-section {\n    background: #FFFDF9;\n    padding: 48px 24px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    max-width: 800px;\n    margin: 0 auto;\n    box-sizing: border-box;\n  }\n  .faq-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 38px);\n    color: #c9836a;\n    text-align: center;\n    margin: 0 0 36px;\n  }\n  .faq-list {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .faq-item {\n    background: #F3E7DC;\n    border-radius: 12px;\n    overflow: hidden;\n  }\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 20px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    cursor: pointer;\n    text-align: left;\n    gap: 16px;\n  }\n  .faq-question span {\n    font-size: 15px;\n    font-weight: 600;\n    color: #5C4033;\n    line-height: 1.4;\n  }\n  .faq-icon {\n    font-size: 22px;\n    color: #c9836a;\n    font-weight: 300;\n    flex-shrink: 0;\n    transition: transform 0.25s ease;\n    line-height: 1;\n  }\n  .faq-item.open .faq-icon {\n    transform: rotate(45deg);\n    color: #5C4033;\n  }\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease, padding 0.3s ease;\n    padding: 0 20px;\n  }\n  .faq-item.open .faq-answer {\n    max-height: 400px;\n    padding: 0 20px 18px;\n  }\n  .faq-answer p {\n    font-size: 14px;\n    color: #5C4033;\n    line-height: 1.7;\n    margin: 0;\n  }\n<\/style>\n\n<div class=\"faq-section\">\n  <h2 class=\"faq-title\">frequently asked questions<\/h2>\n  <div class=\"faq-list\">\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>When will I start seeing results?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Lashes have a natural growth cycle, so this takes a little patience. Most people notice their lashes feel stronger and fall out less within the first 3–4 weeks, with a visible difference in fullness and length around weeks 4–6. For the best results, use it every night and stay consistent.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How long does one bottle last?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Each bottle lasts about 2 months with daily use — one dip of the wand is enough to cover both eyes. Keep the cap closed tightly between uses so the formula stays fresh.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>What's in it, and is it safe?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>It's a blend of peptides, biotin, and botanical extracts like ginseng and rosemary that condition and care for your lashes. It's prostaglandin-free, paraben-free, fragrance-free, vegan, and cruelty-free — formulated to be gentle on the delicate eye area.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How do I apply it?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>After removing eye makeup, dip the wand once and sweep a thin line along your upper lash line — like applying liquid eyeliner, as close to the roots as you can. Let it dry for a minute or two before bed. That's it: about 10 seconds a night.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Can I use it with lash extensions or contact lenses?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Yes to both. The formula is oil-free, so it won't break down extension adhesive, and many people use it to care for their natural lashes between fills. It's also safe for contact lens wearers — just apply before bed when your lenses are out.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Will it irritate my eyes?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>It's made to be gentle on sensitive eyes, with no prostaglandins, fragrances, or harsh ingredients. Apply it only to the upper lash line, not directly in the eye. If your eyes are very sensitive, a quick patch test on your arm first is always a good idea.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>What if I miss a day?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>No problem — just apply again the next night. Don't double up to make up for it. The formula is designed for everyday life, so the occasional missed evening won't undo your progress, as long as you stay mostly consistent.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>What if it doesn't work for me?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>You're covered by our 60-night money-back guarantee. If you don't see a difference after using it consistently, just contact us for a full refund — no questions asked.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<script>\n  function toggleFaq(btn) {\n    const item = btn.closest('.faq-item');\n    const isOpen = item.classList.contains('open');\n    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));\n    if (!isOpen) item.classList.add('open');\n  }\n<\/script>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"custom_liquid_PyWqQE":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .reviews-section {\n    background: #FFFDF9;\n    padding: 48px 20px 60px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    text-align: center;\n    box-sizing: border-box;\n    width: 100%;\n    overflow-x: hidden;\n  }\n\n  .reviews-hearts {\n    color: #c9836a;\n    font-size: 18px;\n    letter-spacing: 6px;\n    margin-bottom: 12px;\n  }\n\n  .reviews-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 40px);\n    color: #c9836a;\n    margin: 0 0 36px;\n  }\n\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    max-width: 1100px;\n    margin: 0 auto;\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .review-card {\n    background: #ffffff;\n    border: 1.5px solid #E8D8C9;\n    border-radius: 12px;\n    overflow: hidden;\n    text-align: left;\n    display: flex;\n    flex-direction: column;\n    box-sizing: border-box;\n    width: 100%;\n    min-width: 0;\n  }\n\n  .review-card img {\n    width: 100%;\n    aspect-ratio: 3 \/ 4;\n    object-fit: cover;\n    display: block;\n  }\n\n  .review-body {\n    padding: 16px;\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    box-sizing: border-box;\n    min-width: 0;\n  }\n\n  .review-verified {\n    font-size: 11px;\n    font-weight: 700;\n    color: #c9836a;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .review-title {\n    font-size: 15px;\n    font-weight: 800;\n    color: #5C4033;\n    line-height: 1.3;\n    margin: 0;\n    overflow-wrap: break-word;\n  }\n\n  .review-text {\n    font-size: 13px;\n    color: #5C4033;\n    line-height: 1.6;\n    margin: 0;\n    overflow-wrap: break-word;\n    white-space: normal;\n  }\n\n  .review-name {\n    font-size: 13px;\n    font-weight: 700;\n    color: #5C4033;\n    margin: 4px 0 0;\n  }\n\n  .review-body--textonly {\n    padding: 24px 20px 28px;\n    flex: 1;\n  }\n\n  .review-stars {\n    color: #c9836a;\n    font-size: 16px;\n    letter-spacing: 2px;\n    margin-bottom: 4px;\n  }\n\n  .reviews-toggle {\n    margin-top: 32px;\n    background: none;\n    border: 2px solid #c9836a;\n    color: #c9836a;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    padding: 12px 32px;\n    border-radius: 100px;\n    cursor: pointer;\n    transition: background 0.2s, color 0.2s;\n  }\n\n  .reviews-toggle:hover {\n    background: #c9836a;\n    color: #ffffff;\n  }\n\n  @media (max-width: 900px) {\n    .reviews-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 560px) {\n    .reviews-section {\n      padding: 36px 16px 48px;\n    }\n    .reviews-grid {\n      grid-template-columns: 1fr;\n      width: 100%;\n    }\n    .review-card {\n      width: 100%;\n      max-width: 100%;\n    }\n    .reviews-title {\n      font-size: clamp(22px, 6vw, 32px);\n    }\n  }\n<\/style>\n\n<section class=\"reviews-section\">\n\n  <div class=\"reviews-hearts\">♥ ♥ ♥ ♥ ♥<\/div>\n  <h2 class=\"reviews-title\">Real Stories from Real Customers<\/h2>\n\n  <div class=\"reviews-grid\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">I rarely reach for mascara now<\/p>\n        <p class=\"review-text\">I'd tried other serums before and never saw a difference, so I was skeptical. By week five my lashes looked so much fuller that I stopped wearing mascara most days. The 10-second routine is so easy I actually stick to it.<\/p>\n        <p class=\"review-name\">— Lara H.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Finally something gentle on my eyes<\/p>\n        <p class=\"review-text\">My eyes are really sensitive and most lash products sting or make them water. This one didn't bother me at all. A few weeks in, my lashes feel stronger and they're not falling out when I take off my makeup.<\/p>\n        <p class=\"review-name\">— Nour A.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Safe with my extensions<\/p>\n        <p class=\"review-text\">I get lash extensions and was worried a serum would loosen them, but this is oil-free so it's been totally fine. My natural lashes underneath look so much healthier between fills. My lash tech even noticed.<\/p>\n        <p class=\"review-name\">— Maya S.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <div class=\"reviews-grid\" id=\"extraReviews\" style=\"display:none; margin-top: 16px;\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Patience really does pay off<\/p>\n        <p class=\"review-text\">The first couple of weeks I didn't see much and almost gave up. So glad I kept going — around week six the difference was obvious. My lashes look longer and fuller than they have in years. Just stay consistent.<\/p>\n        <p class=\"review-name\">— Rim K.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">One bottle lasted me two whole months<\/p>\n        <p class=\"review-text\">A little goes a long way — one dip really does cover both eyes. The bottle lasted exactly two months like they said, so it's great value compared to what I used to spend on falsies and lash treatments.<\/p>\n        <p class=\"review-name\">— Carla B.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Friends keep asking if they're falsies<\/p>\n        <p class=\"review-text\">I've had three people ask if I'm wearing false lashes — they're 100% mine. The serum became part of my nightly routine without even thinking about it. Already on my second bottle and not stopping.<\/p>\n        <p class=\"review-name\">— Sara D.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <button class=\"reviews-toggle\" id=\"reviewsToggle\" onclick=\"toggleReviews()\">\n    See More Reviews ▾\n  <\/button>\n\n<\/section>\n\n<script>\n  function toggleReviews() {\n    var extra = document.getElementById('extraReviews');\n    var btn = document.getElementById('reviewsToggle');\n    if (extra.style.display === 'none') {\n      extra.style.display = 'grid';\n      btn.textContent = 'Show Less ▴';\n    } else {\n      extra.style.display = 'none';\n      btn.textContent = 'See More Reviews ▾';\n    }\n  }\n<\/script>","full_width":true,"show_divider":false,"padding_top":36,"padding_bottom":36}}},"order":["empty-space","main","product-recommendations","custom_liquid_cqKTNy","scrolling_promotion_6Xj9FQ","image_with_text_X6KRyA","scrolling_promotion_pD6Mdt","custom_liquid_QWbLRi","custom_liquid_PyWqQE"]}