    "custom_liquid_PyWqQE": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .reviews-section {\n    background: #ffffff;\n    padding: 48px 20px 60px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    text-align: center;\n    box-sizing: border-box;\n  }\n\n  .reviews-hearts {\n    color: #c9836a;\n    font-size: 18px;\n    letter-spacing: 6px;\n    margin-bottom: 12px;\n  }\n\n  .reviews-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 40px);\n    color: #c9836a;\n    margin: 0 0 36px;\n  }\n\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    max-width: 1200px;\n    margin: 0 auto;\n    box-sizing: border-box;\n  }\n\n  .review-card {\n    background: #ffffff;\n    border: 1.5px solid #e8e8e8;\n    border-radius: 12px;\n    overflow: hidden;\n    text-align: left;\n    display: flex;\n    flex-direction: column;\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .review-card img {\n    width: 100%;\n    aspect-ratio: 3 / 4;\n    object-fit: cover;\n    display: block;\n  }\n\n  .review-body {\n    padding: 16px;\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    box-sizing: border-box;\n  }\n\n  .review-verified {\n    font-size: 11px;\n    font-weight: 700;\n    color: #c9836a;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .review-title {\n    font-size: 15px;\n    font-weight: 800;\n    color: #111111;\n    line-height: 1.3;\n    margin: 0;\n    word-break: break-word;\n  }\n\n  .review-text {\n    font-size: 13px;\n    color: #444444;\n    line-height: 1.6;\n    margin: 0;\n    word-break: break-word;\n    white-space: normal;\n  }\n\n  .review-body--textonly {\n    padding: 24px 20px 28px;\n    flex: 1;\n  }\n\n  .review-stars {\n    color: #c9836a;\n    font-size: 16px;\n    letter-spacing: 2px;\n    margin-bottom: 4px;\n  }\n\n  .reviews-toggle {\n    margin-top: 32px;\n    background: none;\n    border: 2px solid #c9836a;\n    color: #c9836a;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    padding: 12px 32px;\n    border-radius: 100px;\n    cursor: pointer;\n    transition: background 0.2s, color 0.2s;\n  }\n\n  .reviews-toggle:hover {\n    background: #c9836a;\n    color: #ffffff;\n  }\n\n  @media (max-width: 900px) {\n    .reviews-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 500px) {\n    .reviews-section {\n      padding: 36px 16px 48px;\n      width: 100%;\n      overflow-x: hidden;\n    }\n    .reviews-grid {\n      grid-template-columns: 1fr;\n      width: 100%;\n    }\n    .review-card {\n      width: 100%;\n      max-width: 100%;\n    }\n    .review-card img {\n      aspect-ratio: 4 / 3;\n      width: 100%;\n    }\n  }\n</style>\n\n<section class=\"reviews-section\">\n\n  <div class=\"reviews-hearts\">♥ ♥ ♥ ♥ ♥</div>\n  <h2 class=\"reviews-title\">Loved by Over 41,000 Women</h2>\n\n  <div class=\"reviews-grid\">\n\n    <div class=\"review-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/1743655494__1743655490043-6860adac-76f0-40d6-89fe-62__original.avif?v=1776413529\" alt=\"Customer review photo 1\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">My skin but better</p>\n        <p class=\"review-text\">It genuinely adapts to your skin tone — I was sceptical but it really works. Wore it for 12 hours, no touch-ups needed. My fine lines didn't look worse, which never happens with other foundations.</p>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/1762749193__img_0071__original.avif?v=1776413529\" alt=\"Customer review photo 2\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">Game changer for mature skin</p>\n        <p class=\"review-text\">I'm in my 60s and every foundation I've tried sinks into my lines. This one smooths right over them. My daughter asked what I did differently — that says it all.</p>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/1742229740__0__cOjbDcsV__-UO9bAQ-z__original.avif?v=1776413529\" alt=\"Customer review photo 3\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">No more shade matching stress</p>\n        <p class=\"review-text\">One bottle, perfect match. I used to have a drawer full of wrong shades. This just works. Lightweight, doesn't feel heavy at all, and the SPF 50 is a huge bonus.</p>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"reviews-grid\" id=\"extraReviews\" style=\"display:none; margin-top: 16px;\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">Doesn't cake — ever</p>\n        <p class=\"review-text\">I have dry, textured skin and every foundation ends up looking patchy by midday. This stays smooth and fresh from morning to night. Genuinely impressed.</p>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">Was sceptical — now obsessed</p>\n        <p class=\"review-text\">Colour-changing foundation sounded gimmicky to me. But it genuinely matches my skin. I've already ordered my third bottle and gifted it to two friends.</p>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">Feels like nothing on my skin</p>\n        <p class=\"review-text\">So lightweight I forget I'm wearing it. Covers what I need it to, doesn't look heavy or made-up. Just looks like really good skin. On my second bottle already.</p>\n      </div>\n    </div>\n\n  </div>\n\n  <button class=\"reviews-toggle\" id=\"reviewsToggle\" onclick=\"toggleReviews()\">\n    See More Reviews ▾\n  </button>\n\n</section>\n\n<script>\n  function toggleReviews() {\n    var extra = document.getElementById('extraReviews');\n    var btn = document.getElementById('reviewsToggle');\n    if (extra.style.display === 'none') {\n      extra.style.display = 'grid';\n      btn.textContent = 'Show Less ▴';\n    } else {\n      extra.style.display = 'none';\n      btn.textContent = 'See More Reviews ▾';\n    }\n  }\n</script>",
        "full_width": true,
        "show_divider": false,
        "padding_top": 36,
        "padding_bottom": 36
      }
    }
