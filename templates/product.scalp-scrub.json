      "settings": {
        "custom_liquid": "<style>\n  * { box-sizing: border-box; }\n  .mms-section {\n    background: #f2ede8;\n    padding: 48px 24px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n  }\n  .mms-inner {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 48px;\n    align-items: center;\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n  .mms-images {\n    border-radius: 16px;\n    overflow: hidden;\n    aspect-ratio: 3/2;\n  }\n  .mms-images img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n  .mms-content {\n    display: flex;\n    flex-direction: column;\n    gap: 24px;\n  }\n  .mms-heading {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(28px, 4vw, 46px);\n    color: #c9836a;\n    line-height: 1.2;\n    margin: 0;\n  }\n  .mms-block {\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n  }\n  .mms-block-title {\n    font-size: clamp(14px, 1.6vw, 16px);\n    font-weight: 700;\n    color: #222;\n    margin: 0;\n  }\n  .mms-block-desc {\n    font-size: clamp(13px, 1.4vw, 15px);\n    color: #444;\n    line-height: 1.7;\n    margin: 0;\n  }\n  .mms-block-desc em {\n    font-style: italic;\n  }\n  .mms-icons {\n    display: flex;\n    gap: 32px;\n    align-items: center;\n    margin-top: 8px;\n  }\n  .mms-icon-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 10px;\n  }\n  .mms-icon-circle {\n    width: 72px;\n    height: 72px;\n    border-radius: 50%;\n    background: #ecd9cc;\n    border: 1.5px solid #c9836a;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .mms-icon-circle svg {\n    width: 34px;\n    height: 34px;\n  }\n  .mms-icon-label {\n    font-size: 13px;\n    color: #333;\n    text-align: center;\n  }\n  @media (max-width: 700px) {\n    .mms-inner {\n      grid-template-columns: 1fr;\n      gap: 32px;\n    }\n    .mms-icon-circle {\n      width: 60px;\n      height: 60px;\n    }\n    .mms-icon-circle svg {\n      width: 28px;\n      height: 28px;\n    }\n  }\n</style>\n\n<div class=\"mms-section\">\n  <div class=\"mms-inner\">\n\n    <div class=\"mms-images\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/IMG-_04.webp?v=1776410731\" alt=\"Before and After\" />\n    </div>\n\n    <div class=\"mms-content\">\n      <h2 class=\"mms-heading\">Made for Beautifully<br>Mature Skin</h2>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">Smooths texture without settling into lines.</p>\n        <p class=\"mms-block-desc\">Lightweight, breathable formula glides over crepey areas and fine lines—never caking, creasing, or emphasizing texture. Just naturally smooth, even-toned skin.</p>\n      </div>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">Adapts to your exact tone—instantly.</p>\n        <p class=\"mms-block-desc\">As you blend, intelligent pigments warm and adjust to <em>your</em> unique complexion for a flawless shade match. Say goodbye to oxidizing, orange undertones, and drawers full of \"almost right\" shades.</p>\n      </div>\n\n      <div class=\"mms-icons\">\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <rect x=\"10\" y=\"8\" width=\"7\" height=\"18\" rx=\"2\" stroke=\"#c47a50\" stroke-width=\"1.4\"/>\n              <rect x=\"19\" y=\"8\" width=\"7\" height=\"18\" rx=\"2\" stroke=\"#c47a50\" stroke-width=\"1.4\"/>\n              <path d=\"M13 6 L13 4M22 6 L22 4\" stroke=\"#c47a50\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n              <circle cx=\"27\" cy=\"10\" r=\"1.5\" fill=\"#c47a50\"/>\n              <path d=\"M26 14 L28 14M26 17 L28 17\" stroke=\"#c47a50\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n            </svg>\n          </div>\n          <span class=\"mms-icon-label\">Hydrating Formula</span>\n        </div>\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <circle cx=\"18\" cy=\"18\" r=\"10\" stroke=\"#c47a50\" stroke-width=\"1.4\"/>\n              <path d=\"M14 14 Q16 10 20 13 Q24 16 21 20 Q18 24 14 22\" stroke=\"#c47a50\" stroke-width=\"1.4\" fill=\"none\" stroke-linecap=\"round\"/>\n              <circle cx=\"24\" cy=\"12\" r=\"1.5\" fill=\"#c47a50\"/>\n            </svg>\n          </div>\n          <span class=\"mms-icon-label\">Natural Satin Finish</span>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>",
