Effort)","heading_size":"h1","heading_tag":"h2"}},"text_fXwrbU":{"type":"text","settings":{"text":"<p>Tired of <strong>uneven <\/strong>dots, streaky pencils, or freckles that look fake by lunchtime? This multi-point freckle stamp was built for real <strong>humans <\/strong>— not makeup artists.<\/p>","text_size":"typeset2","secondary_color":false}}},"block_order":["heading_Y6bCpT","text_fXwrbU"],"disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/73869677-F4A8-4401-8032-7FD4C16C25BD_1060x_0331b5a5-d549-4c42-aed4-bc24160e24f9.png","image_position":"center center","layout":"image_first","text_box_position":"middle","text_alignment":"left","image_ratio":"650px","enlarge_content":false,"full_width":false,"show_divider":false,"image_behavior":"none","mobile_layout":"image_first","mobile_text_alignment":"left","mobile_image_ratio":"auto","enable_video_looping":false,"video_url":"","use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","gradient_background":"","padding_top":36,"padding_bottom":36}},"scrolling_promotion_pD6Mdt":{"type":"scrolling-promotion","blocks":{"announcement_CR4hbT":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_CR4hbT"],"disabled":true,"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"custom_liquid_QWbLRi":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .faq-section {\n    background: #fff;\n    padding: 48px 24px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    max-width: 800px;\n    margin: 0 auto;\n    box-sizing: border-box;\n  }\n  .faq-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 38px);\n    color: #c9836a;\n    text-align: center;\n    margin: 0 0 36px;\n  }\n  .faq-list {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .faq-item {\n    background: #faf3ef;\n    border-radius: 12px;\n    overflow: hidden;\n  }\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 20px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    cursor: pointer;\n    text-align: left;\n    gap: 16px;\n  }\n  .faq-question span {\n    font-size: 15px;\n    font-weight: 600;\n    color: #222;\n    line-height: 1.4;\n  }\n  .faq-icon {\n    font-size: 22px;\n    color: #aaa;\n    font-weight: 300;\n    flex-shrink: 0;\n    transition: transform 0.25s ease;\n    line-height: 1;\n  }\n  .faq-item.open .faq-icon {\n    transform: rotate(45deg);\n    color: #c9836a;\n  }\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease, padding 0.3s ease;\n    padding: 0 20px;\n  }\n  .faq-item.open .faq-answer {\n    max-height: 300px;\n    padding: 0 20px 18px;\n  }\n  .faq-answer p {\n    font-size: 14px;\n    color: #555;\n    line-height: 1.7;\n    margin: 0;\n  }\n<\/style>\n\n<div class=\"faq-section\">\n  <h2 class=\"faq-title\">frequently asked questions<\/h2>\n  <div class=\"faq-list\">\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How many patches come in one pack?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Each pack contains 8 nose patches. Used 1–2 times a week, one pack gives you about a month's worth of use.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How often should I use the nose patches?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>We recommend applying 1 to 2 times a week, or whenever your pores feel congested. Leave each patch on for 6 to 8 hours — overnight works perfectly — then peel away slowly.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>What happens if I stop using them?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Your skin naturally produces oil every day. If you stop, buildup will gradually return over time — that's normal with any skincare routine. The patches work best as a consistent weekly habit to keep pores clear and balanced long-term.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Are these suitable for sensitive skin?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Yes. The hydrocolloid formula is gentle and non-irritating, making it suitable for all skin types including sensitive skin. Unlike pore strips that tear and damage, these patches absorb without pulling or causing redness.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How is this different from regular pore strips?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Traditional pore strips use strong adhesives that forcefully rip out the surface of blackheads, often damaging small blood vessels and causing redness. Our hydrocolloid patches work by gently absorbing oil and debris from within the pore over 6–8 hours — no tearing, no damage, no irritation.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How do I know the patch is working?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>After 6–8 hours, the patch will turn white or cloudy — that's the hydrocolloid absorbing the oil and impurities from your pores. The more it changes, the more it's pulled out.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<script>\n  function toggleFaq(btn) {\n    const item = btn.closest('.faq-item');\n    const isOpen = item.classList.contains('open');\n    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));\n    if (!isOpen) item.classList.add('open');\n  }\n<\/script>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"custom_liquid_PyWqQE":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .reviews-section {\n    background: #ffffff;\n    padding: 48px 20px 60px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    text-align: center;\n    box-sizing: border-box;\n  }\n\n  .reviews-hearts {\n    color: #c9836a;\n    font-size: 18px;\n    letter-spacing: 6px;\n    margin-bottom: 12px;\n  }\n\n  .reviews-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 40px);\n    color: #c9836a;\n    margin: 0 0 36px;\n  }\n\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    max-width: 1200px;\n    margin: 0 auto;\n    box-sizing: border-box;\n  }\n\n  .review-card {\n    background: #ffffff;\n    border: 1.5px solid #e8e8e8;\n    border-radius: 12px;\n    overflow: hidden;\n    text-align: left;\n    display: flex;\n    flex-direction: column;\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .review-body {\n    padding: 24px 20px 28px;\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    box-sizing: border-box;\n    flex: 1;\n  }\n\n  .review-verified {\n    font-size: 11px;\n    font-weight: 700;\n    color: #c9836a;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .review-stars {\n    color: #c9836a;\n    font-size: 16px;\n    letter-spacing: 2px;\n    margin-bottom: 4px;\n  }\n\n  .review-title {\n    font-size: 15px;\n    font-weight: 800;\n    color: #111111;\n    line-height: 1.3;\n    margin: 0;\n  }\n\n  .review-text {\n    font-size: 13px;\n    color: #444444;\n    line-height: 1.7;\n    margin: 0;\n    white-space: normal;\n    word-break: break-word;\n    overflow-wrap: break-word;\n  }\n\n  .reviews-toggle {\n    margin-top: 32px;\n    background: none;\n    border: 2px solid #c9836a;\n    color: #c9836a;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    padding: 12px 32px;\n    border-radius: 100px;\n    cursor: pointer;\n    transition: background 0.2s, color 0.2s;\n  }\n\n  .reviews-toggle:hover {\n    background: #c9836a;\n    color: #ffffff;\n  }\n\n  @media (max-width: 900px) {\n    .reviews-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 500px) {\n    .reviews-section {\n      padding: 36px 16px 48px;\n      width: 100%;\n      overflow-x: hidden;\n    }\n    .reviews-grid {\n      grid-template-columns: 1fr;\n      width: 100%;\n    }\n    .review-card {\n      width: 100%;\n      max-width: 100%;\n    }\n    .review-body {\n      padding: 20px 16px 24px;\n    }\n    .review-text {\n      font-size: 14px;\n    }\n  }\n<\/style>\n\n<section class=\"reviews-section\">\n\n  <div class=\"reviews-hearts\">♥ ♥ ♥ ♥ ♥<\/div>\n  <h2 class=\"reviews-title\">Loved by Over 4,000 Women<\/h2>\n\n  <div class=\"reviews-grid\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Finally, clearer pores overnight<\/p>\n        <p class=\"review-text\">I've tried everything for my nose blackheads. These patches actually work — I woke up and my pores looked visibly smaller. No redness, no irritation. Just cleaner skin.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">So much better than pore strips<\/p>\n        <p class=\"review-text\">Pore strips always left my nose red and sensitive. These are completely different — gentle, no pulling, and the results are actually better. My skin looks smoother after just two uses.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">I can see it working<\/p>\n        <p class=\"review-text\">When I peeled it off in the morning it had turned completely white — you can literally see what it absorbed. My nose felt so clean. Already on my second pack and won't go without these.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <div class=\"reviews-grid\" id=\"extraReviews\" style=\"display:none; margin-top: 16px;\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Great for sensitive skin<\/p>\n        <p class=\"review-text\">My skin reacts to almost everything but these caused zero irritation. I use them twice a week and my nose stays clear in between. Gentle but genuinely effective.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Part of my weekly routine now<\/p>\n        <p class=\"review-text\">I put one on before bed on Sundays and Wednesdays. My pores have stayed consistently cleaner since I started. Simple, fuss-free, and it actually does what it promises.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Stopped me from squeezing<\/p>\n        <p class=\"review-text\">I used to squeeze my nose constantly which made everything worse. These give me a way to actually deal with the buildup without damaging my skin. My nose has never looked this good.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <button class=\"reviews-toggle\" id=\"reviewsToggle\" onclick=\"toggleReviews()\">\n    See More Reviews ▾\n  <\/button>\n\n<\/section>\n\n<script>\n  function toggleReviews() {\n    var extra = document.getElementById('extraReviews');\n    var btn = document.getElementById('reviewsToggle');\n    if (extra.style.display === 'none') {\n      extra.style.display = 'grid';\n      btn.textContent = 'Show Less ▴';\n    } else {\n      extra.style.display = 'none';\n      btn.textContent = 'See More Reviews ▾';\n    }\n  }\n<\/script>","full_width":true,"show_divider":false,"padding_top":36,"padding_bottom":36}}},"order":["empty-space","main","product-recommendations","custom_liquid_cqKTNy","scrolling_promotion_6Xj9FQ","custom_liquid_R7XEq3","image_with_text_X6KRyA","scrolling_promotion_pD6Mdt","custom_liquid_QWbLRi","custom_liquid_PyWqQE"]}