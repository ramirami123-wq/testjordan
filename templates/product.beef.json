    "custom_liquid_cqKTNy": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  .rv-section {\n    background: #f0efe8;\n    padding: 56px 0;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    text-align: center;\n    overflow: hidden;\n  }\n  .rv-top { padding: 0 24px 40px; }\n  .rv-badge {\n    display: inline-block;\n    background: #f5c842;\n    color: #111;\n    font-size: 12px;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    padding: 8px 20px;\n    border-radius: 999px;\n    margin-bottom: 18px;\n  }\n  .rv-heading {\n    font-size: clamp(24px, 4vw, 38px);\n    font-weight: 800;\n    color: #111;\n  }\n  .rv-track-wrap {\n    width: 100%;\n    overflow-x: scroll;\n    overflow-y: visible;\n    scrollbar-width: none;\n    -webkit-overflow-scrolling: touch;\n    cursor: grab;\n    padding: 4px 24px 16px;\n  }\n  .rv-track-wrap::-webkit-scrollbar { display: none; }\n  .rv-track {\n    display: inline-flex;\n    gap: 14px;\n    white-space: nowrap;\n  }\n  .rv-card {\n    display: inline-block;\n    vertical-align: top;\n    white-space: normal;\n    background: #fff;\n    border-radius: 16px;\n    width: 260px;\n    text-align: left;\n    overflow: hidden;\n    flex-shrink: 0;\n  }\n  .ba-wrap {\n    width: 260px;\n    height: 170px;\n    display: flex;\n    flex-direction: row;\n    overflow: hidden;\n    position: relative;\n    flex-shrink: 0;\n  }\n  .ba-wrap img {\n    width: 130px;\n    height: 170px;\n    object-fit: cover;\n    object-position: center top;\n    display: block;\n    flex-shrink: 0;\n  }\n  .ba-label {\n    position: absolute;\n    bottom: 8px;\n    font-size: 9px;\n    font-weight: 700;\n    letter-spacing: 0.07em;\n    padding: 3px 7px;\n    border-radius: 4px;\n  }\n  .ba-label.b { left: 6px; background: #111; color: #fff; }\n  .ba-label.a { right: 6px; background: #f5c842; color: #111; }\n  .rv-body { padding: 14px 14px 18px; }\n  .rv-meta {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 8px;\n  }\n  .rv-name { font-size: 14px; font-weight: 700; color: #111; }\n  .rv-stars { color: #f5c842; font-size: 12px; }\n  .rv-tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 5px;\n    margin-bottom: 10px;\n  }\n  .rv-tag {\n    font-size: 9px;\n    font-weight: 600;\n    color: #555;\n    border: 1px solid #ddd;\n    border-radius: 999px;\n    padding: 3px 8px;\n  }\n  .rv-quote {\n    font-size: 13px;\n    font-weight: 700;\n    color: #111;\n    margin-bottom: 6px;\n    line-height: 1.4;\n  }\n  .rv-text {\n    font-size: 12px;\n    color: #666;\n    line-height: 1.6;\n  }\n  .rv-dots {\n    display: flex;\n    justify-content: center;\n    gap: 6px;\n    margin-top: 8px;\n    padding: 0 24px;\n  }\n  .rv-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 999px;\n    background: #ccc;\n    border: none;\n    cursor: pointer;\n    transition: all 0.25s;\n    padding: 0;\n  }\n  .rv-dot.active { background: #111; width: 20px; }\n</style>\n\n<div class=\"rv-section\">\n  <div class=\"rv-top\">\n    <div class=\"rv-badge\">2,000+ JARS SOLD</div>\n    <h2 class=\"rv-heading\">Real Results. Real Men.</h2>\n  </div>\n\n  <div class=\"rv-track-wrap\" id=\"rvWrap\">\n    <div class=\"rv-track\" id=\"rvTrack\">\n\n      <div class=\"rv-card\">\n        <div class=\"ba-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_031212_400x400_crop_center_3c434322-5b2a-48b4-b72d-c9da23b01100.png?v=1778401018\" alt=\"before\" />\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_025654_400x400_crop_center_76519663-31c8-4951-8eb0-0573f599acf9.png?v=1778401038\" alt=\"after\" />\n          <span class=\"ba-label b\">BEFORE</span>\n          <span class=\"ba-label a\">AFTER</span>\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Karim, 34</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">WRINKLES REDUCED</span><span class=\"rv-tag\">GLOW</span></div>\n          <p class=\"rv-quote\">\"My wife thought I went to a clinic.\"</p>\n          <p class=\"rv-text\">6 weeks in and everyone at work is asking what I changed. Just this jar, twice a day.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"ba-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_082456_400x400_crop_center_02d3fa48-3b5b-4cc3-a803-1891a98deecc.png?v=1778401083\" alt=\"before\" />\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_082529_400x400_crop_center_e2e3b6b7-a83d-4061-9fb6-e95e7b0a1d11.png?v=1778401087\" alt=\"after\" />\n          <span class=\"ba-label b\">BEFORE</span>\n          <span class=\"ba-label a\">AFTER</span>\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Rami, 41</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">DRY SKIN FIXED</span><span class=\"rv-tag\">REDNESS GONE</span></div>\n          <p class=\"rv-quote\">\"Finally something that actually works.\"</p>\n          <p class=\"rv-text\">Tried everything at the pharmacy. This is the first thing that made my skin feel genuinely different.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"ba-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_030311_400x400_crop_center_aed17ca3-665c-4832-b301-f9c768ad28ca.png?v=1778401123\" alt=\"before\" />\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_030407_400x400_crop_center_ed29e7bf-8d61-4a52-bf56-7cac2e7ea6e8.png?v=1778401126\" alt=\"after\" />\n          <span class=\"ba-label b\">BEFORE</span>\n          <span class=\"ba-label a\">AFTER</span>\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Charbel, 38</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">SKIN BARRIER</span><span class=\"rv-tag\">NO MORE FLAKING</span></div>\n          <p class=\"rv-quote\">\"Sceptical at first. Not anymore.\"</p>\n          <p class=\"rv-text\">My cousin sent this from Australia. After a month the texture of my skin changed completely.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"ba-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_030100_400x400_crop_center_6ba0c06f-bde4-4a38-84c0-49b345d2fd88.png?v=1778401173\" alt=\"before\" />\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_025946_400x400_crop_center_db566d2d-bb56-4c9f-b568-bb0dc62ebe96.png?v=1778401184\" alt=\"after\" />\n          <span class=\"ba-label b\">BEFORE</span>\n          <span class=\"ba-label a\">AFTER</span>\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Georges, 45</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">SUN DAMAGE</span><span class=\"rv-tag\">EVEN TONE</span></div>\n          <p class=\"rv-quote\">\"The Beirut sun does damage. This fixed it.\"</p>\n          <p class=\"rv-text\">Years of sun exposure left my skin rough. Four weeks in and my tone is more even than it's been in years.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"ba-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_081427_400x400_crop_center_18658484-4611-495b-9502-1cf5ca76d7d3.png?v=1778401242\" alt=\"before\" />\n          <img src=\"https://cdn.shopify.com/s/files/1/0957/2981/1738/files/hf_20260424_081951_400x400_crop_center_af6d1ba5-099f-4b86-ae69-5c6ab7a5a250.png?v=1778401252\" alt=\"after\" />\n          <span class=\"ba-label b\">BEFORE</span>\n          <span class=\"ba-label a\">AFTER</span>\n        </div>\n        <div class=\"rv-body\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Elie, 29</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">ACNE REDUCED</span><span class=\"rv-tag\">LESS OILY</span></div>\n          <p class=\"rv-quote\">\"Cleared up what nothing else could.\"</p>\n          <p class=\"rv-text\">Had breakouts since I was a teenager. Two months in, clearest my skin has ever been.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-body\" style=\"padding-top:20px;\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Fadi, 52</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">ANTI-AGING</span></div>\n          <p class=\"rv-quote\">\"At my age I didn't expect results. I was wrong.\"</p>\n          <p class=\"rv-text\">My son ordered this as a joke. Three weeks later he's using it too. Skin hasn't looked this good since my 30s.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-body\" style=\"padding-top:20px;\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Tarek, 36</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">NATURAL GLOW</span></div>\n          <p class=\"rv-quote\">\"Men in Lebanon don't talk about skincare. We should.\"</p>\n          <p class=\"rv-text\">I was embarrassed to buy it. Now I tell every guy I know. The results do all the talking.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-body\" style=\"padding-top:20px;\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Jad, 31</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">REDNESS GONE</span></div>\n          <p class=\"rv-quote\">\"Razor burn gone in two weeks.\"</p>\n          <p class=\"rv-text\">I shave every day and my face was always irritated. This calmed it down completely. Nothing else came close.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-body\" style=\"padding-top:20px;\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Antoine, 44</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">WRINKLES REDUCED</span></div>\n          <p class=\"rv-quote\">\"Worth every lira.\"</p>\n          <p class=\"rv-text\">Spent a lot on skincare over the years. First time I felt the money was actually justified. Skin looks younger, feels stronger.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-body\" style=\"padding-top:20px;\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Ziad, 33</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">WINTER SKIN</span><span class=\"rv-tag\">HYDRATION</span></div>\n          <p class=\"rv-quote\">\"Survived the Beirut winter for the first time.\"</p>\n          <p class=\"rv-text\">Every winter my skin cracks and peels badly. Used this from October — face stayed smooth the whole season.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-body\" style=\"padding-top:20px;\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Nabil, 39</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">DARK CIRCLES</span><span class=\"rv-tag\">TIRED LOOK</span></div>\n          <p class=\"rv-quote\">\"I look less tired even when I am tired.\"</p>\n          <p class=\"rv-text\">The area under my eyes was always dark and puffy. After three weeks I genuinely look more awake. My team noticed at work.</p>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-body\" style=\"padding-top:20px;\">\n          <div class=\"rv-meta\"><span class=\"rv-name\">Habib, 47</span><span class=\"rv-stars\">★★★★★</span></div>\n          <div class=\"rv-tags\"><span class=\"rv-tag\">SENSITIVE SKIN</span></div>\n          <p class=\"rv-quote\">\"My skin reacts to everything. Not this.\"</p>\n          <p class=\"rv-text\">I've tried dozens of creams and always broke out. This is the first product that didn't irritate me at all. And it actually worked.</p>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"rv-dots\" id=\"rvDots\"></div>\n</div>\n\n<script>\n  const wrap = document.getElementById('rvWrap');\n  const track = document.getElementById('rvTrack');\n  const dotsEl = document.getElementById('rvDots');\n  const cards = track.querySelectorAll('.rv-card');\n  const count = cards.length;\n\n  for (let i = 0; i < count; i++) {\n    const d = document.createElement('button');\n    d.className = 'rv-dot' + (i === 0 ? ' active' : '');\n    d.addEventListener('click', () => {\n      wrap.scrollTo({ left: cards[i].offsetLeft - 24, behavior: 'smooth' });\n    });\n    dotsEl.appendChild(d);\n  }\n  const allDots = dotsEl.querySelectorAll('.rv-dot');\n\n  wrap.addEventListener('scroll', () => {\n    let closest = 0, minDist = Infinity;\n    cards.forEach((c, i) => {\n      const dist = Math.abs(c.offsetLeft - wrap.scrollLeft - 24);\n      if (dist < minDist) { minDist = dist; closest = i; }\n    });\n    allDots.forEach((d, i) => d.classList.toggle('active', i === closest));\n  });\n\n  let drag = false, startX = 0, startScroll = 0;\n  wrap.addEventListener('mousedown', e => {\n    drag = true; startX = e.pageX; startScroll = wrap.scrollLeft;\n    wrap.style.cursor = 'grabbing'; e.preventDefault();\n  });\n  window.addEventListener('mouseup', () => { drag = false; wrap.style.cursor = 'grab'; });\n  window.addEventListener('mousemove', e => {\n    if (!drag) return;\n    wrap.scrollLeft = startScroll - (e.pageX - startX);\n  });\n</script>",
