"mms-content\">\n\n      <h2 class=\"mms-heading\">Your Shade.<br>Every Single Time.<\/h2>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">No picking shades. No guessing.<\/p>\n        <p class=\"mms-block-desc\">The pH-reactive formula reads your unique lip chemistry and shifts into the exact color that suits you — so every application looks like it was made for you. Because it was.<\/p>\n      <\/div>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">Feels like a balm. Wears like a lipstick.<\/p>\n        <p class=\"mms-block-desc\">Enriched with <em>Squalane, Hyaluronic Acid & Vitamin E<\/em>, it glides on without drying, settling into fine lines, or fading unevenly. Soft, nourished lips — for up to 8 hours straight.<\/p>\n      <\/div>\n\n      <div class=\"mms-icons\">\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M18 8 C18 8 10 14 10 21 a8 8 0 0 0 16 0 C26 14 18 8 18 8Z\" stroke=\"#c47a50\" stroke-width=\"1.4\" fill=\"none\" stroke-linejoin=\"round\"\/>\n              <path d=\"M18 14 C18 14 14 18 14 22 a4 4 0 0 0 8 0 C22 18 18 14 18 14Z\" stroke=\"#c47a50\" stroke-width=\"1.2\" fill=\"none\" stroke-linejoin=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">pH Color-Adapting<\/span>\n        <\/div>\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <circle cx=\"18\" cy=\"18\" r=\"10\" stroke=\"#c47a50\" stroke-width=\"1.4\"\/>\n              <path d=\"M18 10v8l5 3\" stroke=\"#c47a50\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">6–8 Hour Wear<\/span>\n        <\/div>\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M12 20 Q15 13 18 17 Q21 21 24 15\" stroke=\"#c47a50\" stroke-width=\"1.4\" stroke-linecap=\"round\" fill=\"none\"\/>\n              <circle cx=\"26\" cy=\"25\" r=\"5\" fill=\"#f2ede8\" stroke=\"#c47a50\" stroke-width=\"1.4\"\/>\n              <path d=\"M23.8 25l1.4 1.4 2.8-2.8\" stroke=\"#c47a50\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">No Fine Line Settling<\/span>\n        <\/div>\n      <\/div>\n\n    <\/div>\n  <\/div>\n<\/div>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"scrolling_promotion_6Xj9FQ":{"type":"scrolling-promotion","blocks":{"announcement_QJYrYr":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_QJYrYr"],"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"image_with_text_X6KRyA":{"type":"image-with-text","blocks":{"heading_Y6bCpT":{"type":"heading","settings":{"heading":"Natural-Looking Freckles (No Skill, No Effort)","heading_size":"h1","heading_tag":"h2"}},"text_fXwrbU":{"type":"text","settings":{"text":"<p>Tired of <strong>uneven <\/strong>dots, streaky pencils, or freckles that look fake by lunchtime? This multi-point freckle stamp was built for real <strong>humans <\/strong>— not makeup artists.<\/p>","text_size":"typeset2","secondary_color":false}}},"block_order":["heading_Y6bCpT","text_fXwrbU"],"disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/73869677-F4A8-4401-8032-7FD4C16C25BD_1060x_0331b5a5-d549-4c42-aed4-bc24160e24f9.png","image_position":"center center","layout":"image_first","text_box_position":"middle","text_alignment":"left","image_ratio":"650px","enlarge_content":false,"full_width":false,"show_divider":false,"image_behavior":"none","mobile_layout":"image_first","mobile_text_alignment":"left","mobile_image_ratio":"auto","enable_video_looping":false,"video_url":"","use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","gradient_background":"","padding_top":36,"padding_bottom":36}},"scrolling_promotion_pD6Mdt":{"type":"scrolling-promotion","blocks":{"announcement_CR4hbT":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_CR4hbT"],"disabled":true,"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"custom_liquid_QWbLRi":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .faq-section {\n    background: #fff;\n    padding: 48px 24px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    max-width: 800px;\n    margin: 0 auto;\n    box-sizing: border-box;\n  }\n  .faq-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 38px);\n    color: #c9836a;\n    text-align: center;\n    margin: 0 0 36px;\n  }\n  .faq-list {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .faq-item {\n    background: #faf3ef;\n    border-radius: 12px;\n    overflow: hidden;\n  }\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 20px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    cursor: pointer;\n    text-align: left;\n    gap: 16px;\n  }\n  .faq-question span {\n    font-size: 15px;\n    font-weight: 600;\n    color: #222;\n    line-height: 1.4;\n  }\n  .faq-icon {\n    font-size: 22px;\n    color: #aaa;\n    font-weight: 300;\n    flex-shrink: 0;\n    transition: transform 0.25s ease;\n    line-height: 1;\n  }\n  .faq-item.open .faq-icon {\n    transform: rotate(45deg);\n    color: #c9836a;\n  }\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease, padding 0.3s ease;\n    padding: 0 20px;\n  }\n  .faq-item.open .faq-answer {\n    max-height: 300px;\n    padding: 0 20px 18px;\n  }\n  .faq-answer p {\n    font-size: 14px;\n    color: #555;\n    line-height: 1.7;\n    margin: 0;\n  }\n<\/style>\n\n<div class=\"faq-section\">\n  <h2 class=\"faq-title\">frequently asked questions<\/h2>\n  <div class=\"faq-list\">\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How does the Jolie Signature Lipstick find my shade?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>The formula contains a pH-reactive pigment that responds to your lips' natural chemistry — so as you apply it, it shifts into a color that's uniquely yours. No swatching, no guessing. Every single time, it's exactly right for you.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>My lips are really dry — will this make it worse?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Not at all — it does the opposite. The Jolie Signature Lipstick is enriched with Squalane, Hyaluronic Acid, and Vitamin E, so it wears like a tinted balm. Comfortable, soft, and deeply nourishing all day. Your lips stay hydrated, not just colored.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How long does it actually last?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Around 6 to 8 hours. It holds through coffee, meals, and water without needing a touch-up. And when it does fade, it does so evenly — no patchy marks, no settling into fine lines.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Will it bleed into the lines around my lips?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>No. The hydrating formula keeps your lips plump and smooth, so the color stays exactly where you put it. No bleeding, no feathering, no settling — even hours after application.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Is the Jolie Signature Lipstick safe for sensitive lips?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Yes. It's dermatologist tested, paraben-free, and free from harsh artificial fragrance — just a light, pleasant scent. The formula is specifically made to be gentle, so even sensitive lips can wear it comfortably every day.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Can I build more color intensity?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Absolutely. One layer gives a natural, effortless finish. Two to three layers deepen the color for a bolder look — without ever feeling thick, heavy, or overdone. You're always in control of how much you want.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<script>\n  function toggleFaq(btn) {\n    const item = btn.closest('.faq-item');\n    const isOpen = item.classList.contains('open');\n    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));\n    if (!isOpen) item.classList.add('open');\n  }\n<\/script>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"custom_liquid_PyWqQE":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  * { box-sizing: border-box; }\n  .reviews-section {\n    background: #ffffff;\n    padding: 48px 16px 60px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    text-align: center;\n    width: 100%;\n    overflow-x: hidden;\n  }\n  .reviews-hearts {\n    color: #c9836a;\n    font-size: 18px;\n    letter-spacing: 6px;\n    margin-bottom: 12px;\n  }\n  .reviews-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(22px, 5vw, 40px);\n    color: #c9836a;\n    margin: 0 0 36px;\n  }\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    max-width: 1200px;\n    margin: 0 auto;\n    width: 100%;\n  }\n  .review-card {\n    background: #faf3ef;\n    border: 1.5px solid #e8e8e8;\n    border-radius: 12px;\n    text-align: left;\n    display: flex;\n    flex-direction: column;\n    width: 100%;\n    min-width: 0;\n  }\n  .review-body {\n    padding: 20px 16px 24px;\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    flex: 1;\n    min-width: 0;\n  }\n  .review-verified {\n    font-size: 11px;\n    font-weight: 700;\n    color: #c9836a;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    white-space: normal;\n    word-break: break-word;\n  }\n  .review-title {\n    font-size: clamp(13px, 2vw, 15px);\n    font-weight: 800;\n    color: #111111;\n    line-height: 1.3;\n    margin: 0;\n    word-break: break-word;\n    white-space: normal;\n  }\n  .review-text {\n    font-size: clamp(12px, 1.8vw, 13px);\n    color: #444444;\n    line-height: 1.6;\n    margin: 0;\n    word-break: break-word;\n    white-space: normal;\n    overflow-wrap: break-word;\n  }\n  .review-stars {\n    color: #c9836a;\n    font-size: 14px;\n    letter-spacing: 2px;\n    margin-bottom: 2px;\n  }\n  .reviews-toggle {\n    margin-top: 32px;\n    background: none;\n    border: 2px solid #c9836a;\n    color: #c9836a;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    padding: 12px 32px;\n    border-radius: 100px;\n    cursor: pointer;\n    transition: background 0.2s, color 0.2s;\n  }\n  .reviews-toggle:hover {\n    background: #c9836a;\n    color: #ffffff;\n  }\n  @media (max-width: 820px) {\n    .reviews-grid { grid-template-columns: repeat(2, 1fr); }\n  }\n  @media (max-width: 520px) {\n    .reviews-grid { grid-template-columns: 1fr; }\n    .review-body { padding: 18px 14px 20px; }\n    .review-title { font-size: 14px; }\n    .review-text { font-size: 13px; }\n  }\n<\/style>\n\n<section class=\"reviews-section\">\n  <div class=\"reviews-hearts\">♥ ♥ ♥ ♥ ♥<\/div>\n  <h2 class=\"reviews-title\">Loved by Over 4,300 Women<\/h2>\n\n  <div class=\"reviews-grid\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">My lips but better<\/p>\n        <p class=\"review-text\">I was skeptical about a color-changing lipstick but this genuinely works. It shifted into the most flattering shade the second I applied it. No more drawers full of wrong colors — this is the only one I need.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Feels like a balm, looks like a lipstick<\/p>\n        <p class=\"review-text\">My lips are chronically dry and every lipstick I've tried makes it worse. This one actually hydrates them. Wore it all day through meals and coffee — still looked perfect at 7pm. Genuinely obsessed.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">No more fine line issues<\/p>\n        <p class=\"review-text\">I'm in my 50s and lipstick always bled into the lines around my mouth by midday. This one stays exactly where I put it, hours later. My daughter borrowed it and now she wants her own tube.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <div class=\"reviews-grid\" id=\"extraReviews\" style=\"display:none; margin-top: 16px;\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">So comfortable I forget I'm wearing it<\/p>\n        <p class=\"review-text\">Lightweight, non-sticky, and it smells wonderful. I put it on in the morning and don't think about it again until evening. That never happens with lipstick. Already on my second one.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Worth every penny<\/p>\n        <p class=\"review-text\">I've tried every \"long-lasting\" lipstick out there and they all fade patchy or dry out my lips. This fades evenly and keeps my lips soft all day. The color it adapts to on me is honestly perfect.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Gifted it to three friends already<\/p>\n        <p class=\"review-text\">Everyone who sees me wearing it asks what I have on. I've sent this to my mom, my sister, and my best friend. The pH color thing sounds gimmicky but the shade it creates is genuinely stunning on everyone.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <button class=\"reviews-toggle\" id=\"reviewsToggle\" onclick=\"toggleReviews()\">\n    See More Reviews ▾\n  <\/button>\n<\/section>\n\n<script>\n  function toggleReviews() {\n    var extra = document.getElementById('extraReviews');\n    var btn = document.getElementById('reviewsToggle');\n    if (extra.style.display === 'none') {\n      extra.style.display = 'grid';\n      btn.textContent = 'Show Less ▴';\n    } else {\n      extra.style.display = 'none';\n      btn.textContent = 'See More Reviews ▾';\n    }\n  }\n<\/script>","full_width":true,"show_divider":false,"padding_top":36,"padding_bottom":36}}},"order":["empty-space","main","product-recommendations","custom_liquid_cqKTNy","scrolling_promotion_6Xj9FQ","image_with_text_X6KRyA","scrolling_promotion_pD6Mdt","custom_liquid_QWbLRi","custom_liquid_PyWqQE"]}