  font-weight: 800;\n    color: #111111;\n    margin: 0 0 36px;\n    letter-spacing: -0.02em;\n  }\n\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 16px;\n    max-width: 1200px;\n    margin: 0 auto;\n  }\n\n  .review-card {\n    background: #ffffff;\n    border: 1.5px solid #e8e8e8;\n    border-radius: 12px;\n    overflow: hidden;\n    text-align: left;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .review-card img {\n    width: 100%;\n    aspect-ratio: 3 \/ 4;\n    object-fit: cover;\n    display: block;\n  }\n\n  .review-body {\n    padding: 16px;\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n  }\n\n  .review-verified {\n    font-size: 11px;\n    font-weight: 700;\n    color: #c0329a;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .review-title {\n    font-size: 16px;\n    font-weight: 800;\n    color: #111111;\n    line-height: 1.3;\n    margin: 0;\n  }\n\n  .review-text {\n    font-size: 13px;\n    color: #444444;\n    line-height: 1.6;\n    margin: 0;\n  }\n\n  \/* Tablet: 2 columns *\/\n  @media (max-width: 900px) {\n    .reviews-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  \/* Mobile: 1 column *\/\n  @media (max-width: 500px) {\n    .reviews-section {\n      padding: 36px 14px 48px;\n      overflow-x: hidden;\n    }\n\n    .reviews-grid {\n      grid-template-columns: 1fr;\n      width: 100%;\n      max-width: 100%;\n      box-sizing: border-box;\n    }\n\n    .review-card {\n      width: 100%;\n      max-width: 100%;\n      box-sizing: border-box;\n      overflow: hidden;\n    }\n\n    .review-text,\n    .review-title {\n      word-break: break-word;\n      overflow-wrap: break-word;\n      white-space: normal;\n    }\n\n    .review-card img {\n      aspect-ratio: 4 \/ 3;\n      width: 100%;\n    }\n  }\n\n  .review-body--textonly {\n    padding: 24px 20px 28px;\n    flex: 1;\n  }\n\n  .review-stars {\n    color: #c0329a;\n    font-size: 16px;\n    letter-spacing: 2px;\n    margin-bottom: 4px;\n  }\n\n  .reviews-toggle {\n    margin-top: 32px;\n    background: none;\n    border: 2px solid #c0329a;\n    color: #c0329a;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    padding: 12px 32px;\n    border-radius: 100px;\n    cursor: pointer;\n    transition: background 0.2s, color 0.2s;\n  }\n\n  .reviews-toggle:hover {\n    background: #c0329a;\n    color: #ffffff;\n  }\n<\/style>\n\n<section class=\"reviews-section\">\n\n  <div class=\"reviews-hearts\">♥ ♥ ♥ ♥ ♥<\/div>\n  <h2 class=\"reviews-title\">Loved by Over 15,000 Women<\/h2>\n\n  <div class=\"reviews-grid\">\n\n    <div class=\"review-card\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0957\/2981\/1738\/files\/711kI_NTtIL.jpg?v=1775991788\" alt=\"Customer review photo 1\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">Verified Customer<\/span>\n        <p class=\"review-title\">Get it immediately<\/p>\n        <p class=\"review-text\">This pen works on Black women! Finally found a pen that shows on my skin and stays on until you literally scrub it off with a makeup wipe. Very much smudge proof! I even cried and it didn't come off.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0957\/2981\/1738\/files\/71Vb_jg_waL.webp?v=1775991788\" alt=\"Customer review photo 2\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">Verified Customer<\/span>\n        <p class=\"review-title\">Dreams Come True!<\/p>\n        <p class=\"review-text\">I love these!! Having 2 shades is so great and I can make my freckles look even more natural by mixing the shades! They last me all day long even though I've got a pretty oily face.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0957\/2981\/1738\/files\/61sa_3o1rRL.webp?v=1775991788\" alt=\"Customer review photo 3\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">Verified Customer<\/span>\n        <p class=\"review-title\">Pens great will repurchase<\/p>\n        <p class=\"review-text\">These are so good I love the way they look good especially in the summer months when I'm a tan. Gotta blend good lots of patting haven't tried them with a full face yet.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0957\/2981\/1738\/files\/619PtJYfmeL.webp?v=1775991788\" alt=\"Customer review photo 4\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">Verified Customer<\/span>\n        <p class=\"review-title\">Buy 2!! Love it<\/p>\n        <p class=\"review-text\">Girl I love my freckles!! The pen is perfect. Get two I love it very pigmented<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <!-- More reviews (hidden by default) -->\n  <div class=\"reviews-grid reviews-extra\" id=\"extraReviews\" style=\"display:none; margin-top: 16px;\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Obsessed with this product<\/p>\n        <p class=\"review-text\">I use this every single day. My coworkers thought my freckles were real and couldn't believe it when I told them. Absolutely love how natural it looks — will never stop buying this.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Perfect for summer<\/p>\n        <p class=\"review-text\">Wore this to the beach and it stayed on through water and sunscreen. Looked so natural the whole day. This is the only freckle product I'll ever use from now on.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Game changer honestly<\/p>\n        <p class=\"review-text\">I tried so many freckle pens before and they all looked fake or faded after an hour. This one lasts all day and actually looks like real sun freckles. Worth every penny.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">Verified Customer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">My go-to every morning<\/p>\n        <p class=\"review-text\">Takes me 30 seconds and makes such a big difference. I feel so much more confident with freckles on. Already on my third order and have gifted it to two friends!<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <!-- Show More Button -->\n  <button class=\"reviews-toggle\" id=\"reviewsToggle\" onclick=\"toggleReviews()\">\n    See More Reviews ▾\n  <\/button>\n\n<\/section>\n\n<script>\n  function toggleReviews() {\n    var extra = document.getElementById('extraReviews');\n    var btn = document.getElementById('reviewsToggle');\n    if (extra.style.display === 'none') {\n      extra.style.display = 'grid';\n      btn.textContent = 'Show Less ▴';\n    } else {\n      extra.style.display = 'none';\n      btn.textContent = 'See More Reviews ▾';\n    }\n  }\n<\/script>","full_width":true,"show_divider":false,"padding_top":36,"padding_bottom":36}}},"order":["empty-space","main","product-recommendations","custom_liquid_cqKTNy","image_with_text_EcxpFh","scrolling_promotion_6Xj9FQ","image_with_text_X6KRyA","scrolling_promotion_pD6Mdt","custom_liquid_Pa48xK","custom_liquid_PyWqQE"]}