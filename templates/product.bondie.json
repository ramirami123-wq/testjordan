        "custom_liquid": "<style>\n  .dr-wrap {\n    padding: 64px 20px;\n    background: linear-gradient(180deg, #ffffff 0%, #FBF6F8 50%, #ffffff 100%);\n    font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;\n  }\n\n  .dr-inner {\n    max-width: 640px;\n    margin: 0 auto;\n    text-align: center;\n  }\n\n  .dr-badge-wrap {\n    display: flex;\n    justify-content: center;\n    margin-bottom: 22px;\n  }\n\n  .dr-badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    background: #FFFFFF;\n    border: 1.5px solid #EFD9E3;\n    box-shadow: 0 10px 26px -14px rgba(139, 58, 98, 0.35);\n    border-radius: 100px;\n    padding: 8px 18px 8px 14px;\n    opacity: 0;\n    transform: translateY(10px);\n    transition: opacity 0.6s ease, transform 0.6s ease;\n  }\n\n  .dr-badge.dr-in { opacity: 1; transform: translateY(0); }\n\n  .dr-badge svg { width: 18px; height: 18px; }\n\n  .dr-badge-text {\n    font-size: 11.5px;\n    font-weight: 700;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    color: #6B1F45;\n  }\n\n  .dr-eyebrow {\n    font-size: 12px;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: #A8577A;\n    font-weight: 600;\n    margin: 0 0 14px;\n  }\n\n  .dr-heading {\n    font-family: 'Fraunces', Georgia, serif;\n    font-weight: 500;\n    font-style: italic;\n    font-size: clamp(26px, 4vw, 36px);\n    color: #2B1B26;\n    line-height: 1.2;\n    margin: 0 0 28px;\n  }\n\n  .dr-quote-card {\n    background: #fff;\n    border: 1.5px solid #F1E4EA;\n    border-radius: 20px;\n    padding: 34px 30px;\n    opacity: 0;\n    transform: translateY(16px);\n    transition: opacity 0.6s ease, transform 0.6s ease;\n  }\n\n  .dr-quote-card.dr-in { opacity: 1; transform: translateY(0); }\n\n  .dr-stars {\n    display: flex;\n    justify-content: center;\n    gap: 4px;\n    margin-bottom: 16px;\n  }\n\n  .dr-stars svg { width: 18px; height: 18px; }\n\n  .dr-quote-text {\n    font-size: 16px;\n    line-height: 1.55;\n    color: #3A2A34;\n    margin: 0 0 22px;\n  }\n\n  .dr-attribution {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n  }\n\n  .dr-avatar {\n    width: 42px;\n    height: 42px;\n    border-radius: 50%;\n    background: #8B3A62;\n    color: #fff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .dr-avatar svg { width: 20px; height: 20px; }\n\n  .dr-attr-text { text-align: left; }\n\n  .dr-attr-name {\n    font-size: 13.5px;\n    font-weight: 700;\n    color: #2B1B26;\n  }\n\n  .dr-attr-role {\n    font-size: 12px;\n    color: #9C9793;\n  }\n\n  .dr-source {\n    display: block;\n    font-size: 11px;\n    color: #B7AFAC;\n    margin-top: 18px;\n  }\n</style>\n\n<div class=\"dr-wrap\">\n  <div class=\"dr-inner\">\n\n    <div class=\"dr-badge-wrap\">\n      <span class=\"dr-badge\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 3l2.2 5.6 6 .5-4.6 4 1.4 5.9-4.8-3.6-4.8 3.6L8.8 13l-4.6-4 6-.5L12 3z\" stroke=\"#8B3A62\" stroke-width=\"1.5\" stroke-linejoin=\"round\"/></svg>\n        <span class=\"dr-badge-text\">Customer Favorite</span>\n      </span>\n    </div>\n\n    <p class=\"dr-eyebrow\">Real Reviews</p>\n    <h2 class=\"dr-heading\">What Customers<br>Keep Saying</h2>\n\n    <div class=\"dr-quote-card\">\n      <div class=\"dr-stars\">\n        <svg viewBox=\"0 0 20 20\" fill=\"#8B3A62\"><path d=\"M10 1l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.1L4.6 17.3l1.3-6L1.3 7.2l6.1-.6L10 1z\"/></svg>\n        <svg viewBox=\"0 0 20 20\" fill=\"#8B3A62\"><path d=\"M10 1l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.1L4.6 17.3l1.3-6L1.3 7.2l6.1-.6L10 1z\"/></svg>\n        <svg viewBox=\"0 0 20 20\" fill=\"#8B3A62\"><path d=\"M10 1l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.1L4.6 17.3l1.3-6L1.3 7.2l6.1-.6L10 1z\"/></svg>\n        <svg viewBox=\"0 0 20 20\" fill=\"#8B3A62\"><path d=\"M10 1l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.1L4.6 17.3l1.3-6L1.3 7.2l6.1-.6L10 1z\"/></svg>\n        <svg viewBox=\"0 0 20 20\" fill=\"#8B3A62\"><path d=\"M10 1l2.6 5.6 6.1.6-4.6 4.1 1.3 6-5.4-3.1L4.6 17.3l1.3-6L1.3 7.2l6.1-.6L10 1z\"/></svg>\n      </div>\n      <p class=\"dr-quote-text\">Across hundreds of reviews, the most common themes are the same: it holds through sweat and movement, doesn't stain clothing, and comes off easily with soap and water &mdash; without the sting of pulling off tape.</p>\n      <div class=\"dr-attribution\">\n        <span class=\"dr-avatar\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 20c0-4.4 3.6-7 8-7s8 2.6 8 7\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\"/><circle cx=\"12\" cy=\"8\" r=\"4\" stroke=\"#fff\" stroke-width=\"1.8\"/></svg>\n        </span>\n        <span class=\"dr-attr-text\">\n          <span class=\"dr-attr-name\">4.8 / 5 average rating</span><br>\n          <span class=\"dr-attr-role\">93% of reviewers rated 5 stars</span>\n        </span>\n      </div>\n      <span class=\"dr-source\">Based on aggregate customer reviews, not an individual quote.</span>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  (function() {\n    var els = document.querySelectorAll('.dr-badge, .dr-quote-card');\n    var observer = new IntersectionObserver(function(entries) {\n      entries.forEach(function(entry, i) {\n        if (entry.isIntersecting) {\n          setTimeout(function() { entry.target.classList.add('dr-in'); }, i * 150);\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { threshold: 0.3 });\n    els.forEach(function(el) { observer.observe(el); });\n  })();\n</script>",
