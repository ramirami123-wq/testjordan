      "settings": {
        "custom_liquid": "<style>\n  .gt-wrap {\n    padding: 56px 20px 60px;\n    background: #ffffff;\n    font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;\n  }\n\n  .gt-inner { max-width: 980px; margin: 0 auto; }\n\n  .gt-eyebrow {\n    font-size: 12px;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: #A8577A;\n    font-weight: 600;\n    text-align: center;\n    margin: 0 0 14px;\n  }\n\n  .gt-heading {\n    font-family: 'Fraunces', Georgia, serif;\n    font-weight: 500;\n    font-style: italic;\n    font-size: clamp(26px, 4vw, 36px);\n    color: #2B1B26;\n    text-align: center;\n    line-height: 1.2;\n    margin: 0 0 40px;\n  }\n\n  .gt-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 18px;\n  }\n\n  .gt-card {\n    background: #FBF6F8;\n    border: 1.5px solid #F1E4EA;\n    border-radius: 18px;\n    padding: 28px 20px;\n    text-align: center;\n    opacity: 0;\n    transform: translateY(16px);\n    transition: opacity 0.55s ease, transform 0.55s ease, box-shadow 0.25s ease, border-color 0.25s ease;\n  }\n\n  .gt-card.gt-in { opacity: 1; transform: translateY(0); }\n\n  .gt-card:hover {\n    border-color: #EFD9E3;\n    box-shadow: 0 16px 34px -20px rgba(139, 58, 98, 0.4);\n  }\n\n  .gt-icon {\n    width: 52px;\n    height: 52px;\n    margin: 0 auto 16px;\n    border-radius: 50%;\n    background: #FFFFFF;\n    border: 1.5px solid #EFD9E3;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .gt-icon svg { width: 24px; height: 24px; }\n\n  .gt-title {\n    font-size: 14.5px;\n    font-weight: 700;\n    color: #2B1B26;\n    margin: 0 0 6px;\n  }\n\n  .gt-desc {\n    font-size: 12.5px;\n    line-height: 1.5;\n    color: #8A8582;\n    margin: 0;\n  }\n\n  @media (max-width: 860px) {\n    .gt-grid { grid-template-columns: repeat(2, 1fr); }\n  }\n\n  @media (max-width: 460px) {\n    .gt-grid { grid-template-columns: 1fr; }\n    .gt-card { padding: 24px 20px; }\n  }\n</style>\n\n<div class=\"gt-wrap\">\n  <div class=\"gt-inner\">\n    <p class=\"gt-eyebrow\">Why Shop With Confidence</p>\n    <h2 class=\"gt-heading\">Why Bondie Works</h2>\n\n    <div class=\"gt-grid\">\n\n      <div class=\"gt-card\">\n        <span class=\"gt-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 3c5 6.5 8 11 8 14.5C20 22 16.5 26 12 26\" stroke=\"#8B3A62\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M12 3c-5 6.5-8 11-8 14.5C4 22 7.5 26 12 26\" stroke=\"#8B3A62\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </span>\n        <p class=\"gt-title\">Sweat &amp; Water Resistant</p>\n        <p class=\"gt-desc\">Formulated to hold through movement, dancing, and light water exposure.</p>\n      </div>\n\n      <div class=\"gt-card\">\n        <span class=\"gt-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"10\" cy=\"10\" r=\"6.5\" stroke=\"#8B3A62\" stroke-width=\"1.6\"/><path d=\"M7 10l2 2 3.5-3.5\" stroke=\"#4CAF82\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </span>\n        <p class=\"gt-title\">Hypoallergenic &amp; Fabric-Safe</p>\n        <p class=\"gt-desc\">Made to be gentle on skin and safe for use on your clothing.</p>\n      </div>\n\n      <div class=\"gt-card\">\n        <span class=\"gt-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 20c0-4 3-6.5 6-6.5s6 2.5 6 6.5M14 20c0-3 2-5 4-5s4 2 4 5\" stroke=\"#8B3A62\" stroke-width=\"1.6\" stroke-linecap=\"round\"/><circle cx=\"10\" cy=\"8\" r=\"3.5\" stroke=\"#8B3A62\" stroke-width=\"1.6\"/><circle cx=\"18\" cy=\"9.5\" r=\"2.8\" stroke=\"#8B3A62\" stroke-width=\"1.6\"/></svg>\n        </span>\n        <p class=\"gt-title\">Trusted by 100,000+</p>\n        <p class=\"gt-desc\">Loved by over 100,000 women, with a 4.8/5 average rating.</p>\n      </div>\n\n      <div class=\"gt-card\">\n        <span class=\"gt-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 4h6v6H4V4zM14 4h6v6h-6V4zM4 14h6v6H4v-6z\" stroke=\"#8B3A62\" stroke-width=\"1.6\" stroke-linejoin=\"round\"/><path d=\"M14.5 15.5l2 2 3.5-3.5\" stroke=\"#4CAF82\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </span>\n        <p class=\"gt-title\">Easy On, Easy Off</p>\n        <p class=\"gt-desc\">Non-staining, and removes cleanly with just soap and water.</p>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n  (function() {\n    var cards = document.querySelectorAll('.gt-card');\n    var observer = new IntersectionObserver(function(entries) {\n      entries.forEach(function(entry) {\n        if (entry.isIntersecting) {\n          var idx = Array.from(cards).indexOf(entry.target);\n          setTimeout(function() { entry.target.classList.add('gt-in'); }, idx * 100);\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { threshold: 0.2 });\n    cards.forEach(function(card) { observer.observe(card); });\n  })();\n</script>",
