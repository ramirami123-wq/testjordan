      "settings": {
        "custom_liquid": "<style>\n  .fq-wrap {\n    padding: 64px 20px 72px;\n    background: #ffffff;\n    font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;\n  }\n\n  .fq-inner { max-width: 680px; margin: 0 auto; }\n\n  .fq-eyebrow {\n    font-size: 12px;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: #A8577A;\n    font-weight: 600;\n    text-align: center;\n    margin: 0 0 14px;\n  }\n\n  .fq-heading {\n    font-family: 'Fraunces', Georgia, serif;\n    font-weight: 500;\n    font-style: italic;\n    font-size: clamp(28px, 4vw, 38px);\n    color: #2B1B26;\n    text-align: center;\n    line-height: 1.15;\n    margin: 0 0 40px;\n  }\n\n  .fq-list { display: flex; flex-direction: column; gap: 12px; }\n\n  .fq-item {\n    background: #fff;\n    border: 1.5px solid #F1E4EA;\n    border-radius: 16px;\n    opacity: 0;\n    transform: translateY(14px);\n    transition: opacity 0.55s ease, transform 0.55s ease, border-color 0.25s ease, box-shadow 0.25s ease;\n    overflow: hidden;\n  }\n\n  .fq-item.fq-in { opacity: 1; transform: translateY(0); }\n\n  .fq-item.fq-open {\n    border-color: #EFD9E3;\n    box-shadow: 0 14px 30px -20px rgba(139, 58, 98, 0.4);\n  }\n\n  .fq-question {\n    width: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    background: none;\n    border: none;\n    text-align: left;\n    padding: 18px 20px;\n    cursor: pointer;\n    font-family: inherit;\n  }\n\n  .fq-question-text {\n    font-size: 14.5px;\n    font-weight: 600;\n    color: #2B1B26;\n  }\n\n  .fq-toggle {\n    width: 26px;\n    height: 26px;\n    border-radius: 50%;\n    background: #FBF0F4;\n    flex-shrink: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    position: relative;\n    transition: background 0.25s ease, transform 0.3s ease;\n  }\n\n  .fq-item.fq-open .fq-toggle {\n    background: #8B3A62;\n    transform: rotate(180deg);\n  }\n\n  .fq-toggle::before, .fq-toggle::after {\n    content: \"\";\n    position: absolute;\n    background: #8B3A62;\n    border-radius: 2px;\n    transition: background 0.25s ease;\n  }\n\n  .fq-toggle::before { width: 10px; height: 1.6px; }\n  .fq-toggle::after { width: 1.6px; height: 10px; }\n\n  .fq-item.fq-open .fq-toggle::before,\n  .fq-item.fq-open .fq-toggle::after {\n    background: #fff;\n  }\n\n  .fq-item.fq-open .fq-toggle::after { transform: scaleY(0); }\n\n  .fq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.35s ease;\n  }\n\n  .fq-answer-inner {\n    padding: 0 20px 20px;\n    font-size: 13.5px;\n    line-height: 1.6;\n    color: #6B6560;\n  }\n\n  .fq-footer {\n    text-align: center;\n    margin-top: 32px;\n    font-size: 13px;\n    color: #9C9793;\n  }\n\n  .fq-footer a {\n    color: #A8577A;\n    font-weight: 600;\n    text-decoration: underline;\n  }\n</style>\n\n<div class=\"fq-wrap\">\n  <div class=\"fq-inner\">\n    <p class=\"fq-eyebrow\">Good To Know</p>\n    <h2 class=\"fq-heading\">Frequently Asked<br>Questions</h2>\n\n    <div class=\"fq-list\">\n\n      <div class=\"fq-item\">\n        <button class=\"fq-question\" type=\"button\">\n          <span class=\"fq-question-text\">How do I use Bondie?</span>\n          <span class=\"fq-toggle\"></span>\n        </button>\n        <div class=\"fq-answer\">\n          <div class=\"fq-answer-inner\">Apply a thin, even layer to clean, dry skin. Let it sit for about 30&ndash;60 seconds until it turns tacky, then press your clothing, straps, or fabric firmly against the skin and hold for a few seconds.</div>\n        </div>\n      </div>\n\n      <div class=\"fq-item\">\n        <button class=\"fq-question\" type=\"button\">\n          <span class=\"fq-question-text\">Will it hold up through sweat, dancing, or water?</span>\n          <span class=\"fq-toggle\"></span>\n        </button>\n        <div class=\"fq-answer\">\n          <div class=\"fq-answer-inner\">Yes &mdash; Bondie is formulated to be sweat and water resistant, so it's built to keep clothing in place through movement, dancing, and light exposure to water.</div>\n        </div>\n      </div>\n\n      <div class=\"fq-item\">\n        <button class=\"fq-question\" type=\"button\">\n          <span class=\"fq-question-text\">What can I use it on?</span>\n          <span class=\"fq-toggle\"></span>\n        </button>\n        <div class=\"fq-answer\">\n          <div class=\"fq-answer-inner\">It's commonly used for tops, dresses, bikinis, straps, costumes, garters, high socks, and bike shorts &mdash; anywhere you want fabric to stay put against skin.</div>\n        </div>\n      </div>\n\n      <div class=\"fq-item\">\n        <button class=\"fq-question\" type=\"button\">\n          <span class=\"fq-question-text\">Is it safe for sensitive skin?</span>\n          <span class=\"fq-toggle\"></span>\n        </button>\n        <div class=\"fq-answer\">\n          <div class=\"fq-answer-inner\">Bondie is formulated to be hypoallergenic and fabric-safe. As with any new skin-contact product, we recommend a small patch test first if you have particularly sensitive or reactive skin.</div>\n        </div>\n      </div>\n\n      <div class=\"fq-item\">\n        <button class=\"fq-question\" type=\"button\">\n          <span class=\"fq-question-text\">How do I remove it, and will it stain my clothes?</span>\n          <span class=\"fq-toggle\"></span>\n        </button>\n        <div class=\"fq-answer\">\n          <div class=\"fq-answer-inner\">Bondie is non-staining. To remove, gently peel the fabric away, then wash your skin with soap and water. Launder or hand-wash the clothing as usual.</div>\n        </div>\n      </div>\n\n      <div class=\"fq-item\">\n        <button class=\"fq-question\" type=\"button\">\n          <span class=\"fq-question-text\">What's your return policy?</span>\n          <span class=\"fq-toggle\"></span>\n        </button>\n        <div class=\"fq-answer\">\n          <div class=\"fq-answer-inner\">Because Bondie is a skin-contact product, all sales are final and returns aren't accepted for hygiene and safety reasons. If you subscribe, note the subscription includes a minimum 3-month commitment at 15% off.</div>\n        </div>\n      </div>\n\n    </div>\n\n  </div>\n</div>\n\n<script>\n  (function() {\n    var items = document.querySelectorAll('.fq-item');\n\n    // scroll reveal\n    var observer = new IntersectionObserver(function(entries) {\n      entries.forEach(function(entry, i) {\n        if (entry.isIntersecting) {\n          var idx = Array.from(items).indexOf(entry.target);\n          setTimeout(function() { entry.target.classList.add('fq-in'); }, idx * 80);\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { threshold: 0.2 });\n    items.forEach(function(item) { observer.observe(item); });\n\n    // accordion toggle\n    items.forEach(function(item) {\n      var btn = item.querySelector('.fq-question');\n      var answer = item.querySelector('.fq-answer');\n\n      btn.addEventListener('click', function() {\n        var isOpen = item.classList.contains('fq-open');\n\n        items.forEach(function(other) {\n          other.classList.remove('fq-open');\n          other.querySelector('.fq-answer').style.maxHeight = null;\n        });\n\n        if (!isOpen) {\n          item.classList.add('fq-open');\n          answer.style.maxHeight = answer.scrollHeight + 'px';\n        }\n      });\n    });\n  })();\n</script>",
