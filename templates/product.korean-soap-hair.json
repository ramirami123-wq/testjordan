        "custom_liquid_YMTnpV": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n  .yc-faq {\n    all: initial;\n    display: block;\n    background: #FFFFFF;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n    max-width: 700px;\n    margin: 0 auto;\n    padding: 1rem;\n    box-sizing: border-box;\n  }\n\n  .yc-faq *,\n  .yc-faq *::before,\n  .yc-faq *::after {\n    box-sizing: border-box;\n    font-family: inherit;\n  }\n\n  .yc-faq .yc-faq-item {\n    border-bottom: 1px solid #E4E0D8;\n  }\n\n  .yc-faq .yc-faq-item:first-child {\n    border-top: 1px solid #E4E0D8;\n  }\n\n  .yc-faq .yc-faq-question {\n    width: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 1rem;\n    background: none;\n    border: none;\n    cursor: pointer;\n    text-align: left;\n    padding: 1.2rem 0.25rem;\n    font-size: 1.3rem;\n    color: #2B2A28;\n  }\n\n  .yc-faq .yc-faq-question:hover {\n    color: #55483a;\n  }\n\n  .yc-faq .yc-faq-icon {\n    flex-shrink: 0;\n    width: 18px;\n    height: 18px;\n    position: relative;\n  }\n\n  .yc-faq .yc-faq-icon::before,\n  .yc-faq .yc-faq-icon::after {\n    content: \"\";\n    position: absolute;\n    background: #2B2A28;\n    top: 50%;\n    left: 50%;\n    transition: transform 0.25s ease;\n  }\n\n  .yc-faq .yc-faq-icon::before {\n    width: 100%;\n    height: 2px;\n    transform: translate(-50%, -50%);\n  }\n\n  .yc-faq .yc-faq-icon::after {\n    width: 2px;\n    height: 100%;\n    transform: translate(-50%, -50%);\n  }\n\n  .yc-faq .yc-faq-item.yc-open .yc-faq-icon::after {\n    transform: translate(-50%, -50%) rotate(90deg);\n    opacity: 0;\n  }\n\n  .yc-faq .yc-faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease, padding 0.3s ease;\n    font-size: 1.2rem;\n    line-height: 1.6;\n    color: #4a4640;\n    padding: 0 0.25rem;\n  }\n\n  .yc-faq .yc-faq-item.yc-open .yc-faq-answer {\n    max-height: 400px;\n    padding: 0 0.25rem 1.2rem;\n  }\n\n  /* Mobile: keep text comfortably readable */\n  @media (max-width: 480px) {\n    .yc-faq {\n      padding: 0.75rem;\n    }\n    .yc-faq .yc-faq-question {\n      font-size: 1.35rem;\n      padding: 1.2rem 0.15rem;\n    }\n    .yc-faq .yc-faq-answer {\n      font-size: 1.25rem;\n    }\n    .yc-faq .yc-faq-icon {\n      width: 22px;\n      height: 22px;\n    }\n  }\n</style>\n\n<div class=\"yc-faq\">\n\n  <div class=\"yc-faq-item\">\n    <button class=\"yc-faq-question\" type=\"button\">\n      How does it work?\n      <span class=\"yc-faq-icon\"></span>\n    </button>\n    <div class=\"yc-faq-answer\">\n      Our concentrated solid bar delivers 12 fermented Korean herbs directly to your scalp at full strength — no water filler, no sulfates. A 60-second massage ritual that clears buildup, calms inflammation, and wakes up follicles your liquid shampoo put to sleep.\n    </div>\n  </div>\n\n  <div class=\"yc-faq-item\">\n    <button class=\"yc-faq-question\" type=\"button\">\n      Is it safe to use?\n      <span class=\"yc-faq-icon\"></span>\n    </button>\n    <div class=\"yc-faq-answer\">\n      Our bar is made with 100% natural, plant-derived ingredients. No pharmaceuticals, no hormones, no synthetic chemicals. Safe during pregnancy and breastfeeding.\n    </div>\n  </div>\n\n  <div class=\"yc-faq-item\">\n    <button class=\"yc-faq-question\" type=\"button\">\n      How long does one bar last?\n      <span class=\"yc-faq-icon\"></span>\n    </button>\n    <div class=\"yc-faq-answer\">\n      40–60 washes (approximately 1–2 months). That's roughly $0.42 per wash — less than a single-use serum packet.\n    </div>\n  </div>\n\n  <div class=\"yc-faq-item\">\n    <button class=\"yc-faq-question\" type=\"button\">\n      Can I use it with my existing serums?\n      <span class=\"yc-faq-icon\"></span>\n    </button>\n    <div class=\"yc-faq-answer\">\n      Not only can you — you should. Our bar is the missing first step. By clearing scalp buildup and opening follicles, it allows your serums (The Ordinary, Vegamour, etc.) to actually reach the scalp and absorb properly. Most women find their existing products finally start working.\n    </div>\n  </div>\n\n</div>\n\n<script>\n  (function () {\n    var items = document.querySelectorAll('.yc-faq .yc-faq-item');\n    items.forEach(function (item) {\n      var btn = item.querySelector('.yc-faq-question');\n      btn.addEventListener('click', function () {\n        item.classList.toggle('yc-open');\n      });\n    });\n  })();\n</script>"
          }
        }
