      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .yc-reviews {\n    all: initial;\n    display: block;\n    background: #FFFFFF;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n    padding: 2rem 1.25rem;\n    box-sizing: border-box;\n  }\n\n  .yc-reviews *,\n  .yc-reviews *::before,\n  .yc-reviews *::after {\n    box-sizing: border-box;\n    font-family: inherit;\n  }\n\n  .yc-reviews .yc-r-wrap {\n    max-width: 1200px;\n    margin: 0 auto;\n  }\n\n  /* Summary bar */\n  .yc-reviews .yc-r-summary {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    flex-wrap: wrap;\n    gap: 1rem;\n    margin-bottom: 1.75rem;\n  }\n\n  .yc-reviews .yc-r-rating {\n    display: flex;\n    align-items: center;\n    gap: 0.6rem;\n  }\n\n  .yc-reviews .yc-r-stars {\n    color: #D4A94C;\n    font-size: 1.6rem;\n    letter-spacing: 2px;\n  }\n\n  .yc-reviews .yc-r-score {\n    font-size: 1.3rem;\n    color: #1c1c1c;\n    font-weight: 600;\n    display: flex;\n    align-items: center;\n    gap: 0.3rem;\n  }\n\n  .yc-reviews .yc-r-filter-btn {\n    width: 46px;\n    height: 46px;\n    border-radius: 8px;\n    border: 1px solid #E0DCD4;\n    background: #fff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    color: #1c1c1c;\n  }\n\n  .yc-reviews .yc-r-filter-btn svg {\n    width: 20px;\n    height: 20px;\n  }\n\n  /* Grid */\n  .yc-reviews .yc-r-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 1.25rem;\n  }\n\n  .yc-reviews .yc-r-card {\n    background: #FAF9F6;\n    border: 1px solid #EFEBE3;\n    border-radius: 14px;\n    padding: 1.4rem 1.4rem 1.6rem;\n    display: none;\n  }\n\n  .yc-reviews .yc-r-card.yc-r-visible {\n    display: block;\n  }\n\n  .yc-reviews .yc-r-name-row {\n    display: flex;\n    align-items: center;\n    gap: 0.4rem;\n    font-weight: 700;\n    font-size: 1.25rem;\n    color: #1c1c1c;\n    margin-bottom: 0.4rem;\n  }\n\n  .yc-reviews .yc-r-verified {\n    display: inline-flex;\n    align-items: center;\n    gap: 0.3rem;\n    color: #6b6259;\n    font-weight: 500;\n    font-size: 1.05rem;\n  }\n\n  .yc-reviews .yc-r-verified svg {\n    width: 16px;\n    height: 16px;\n    color: #3F5B4A;\n    flex-shrink: 0;\n  }\n\n  .yc-reviews .yc-r-card-stars {\n    color: #D4A94C;\n    font-size: 1.2rem;\n    letter-spacing: 1.5px;\n    margin-bottom: 0.7rem;\n  }\n\n  .yc-reviews .yc-r-text {\n    font-size: 1.15rem;\n    line-height: 1.6;\n    color: #3a3733;\n    margin: 0;\n  }\n\n  /* See more button */\n  .yc-reviews .yc-r-seemore-wrap {\n    display: flex;\n    justify-content: center;\n    margin-top: 2rem;\n  }\n\n  .yc-reviews .yc-r-seemore-btn {\n    background: #FFFFFF;\n    border: 1.5px solid #33443A;\n    color: #33443A;\n    border-radius: 999px;\n    padding: 0.9rem 2.2rem;\n    font-size: 1.15rem;\n    font-weight: 600;\n    cursor: pointer;\n  }\n\n  .yc-reviews .yc-r-seemore-btn:hover {\n    background: #33443A;\n    color: #ffffff;\n  }\n\n  .yc-reviews .yc-r-seemore-btn.yc-r-hidden {\n    display: none;\n  }\n\n  /* Tablet */\n  @media (max-width: 960px) {\n    .yc-reviews .yc-r-grid {\n      grid-template-columns: 1fr 1fr;\n    }\n  }\n\n  /* Mobile: single column, big readable text */\n  @media (max-width: 560px) {\n    .yc-reviews {\n      padding: 1.5rem 1rem;\n    }\n    .yc-reviews .yc-r-summary {\n      flex-direction: column;\n      align-items: flex-start;\n    }\n    .yc-reviews .yc-r-stars {\n      font-size: 1.8rem;\n    }\n    .yc-reviews .yc-r-score {\n      font-size: 1.45rem;\n    }\n    .yc-reviews .yc-r-grid {\n      grid-template-columns: 1fr;\n      gap: 1.1rem;\n    }\n    .yc-reviews .yc-r-card {\n      padding: 1.5rem 1.4rem 1.75rem;\n    }\n    .yc-reviews .yc-r-name-row {\n      font-size: 1.35rem;\n    }\n    .yc-reviews .yc-r-verified {\n      font-size: 1.1rem;\n    }\n    .yc-reviews .yc-r-card-stars {\n      font-size: 1.3rem;\n    }\n    .yc-reviews .yc-r-text {\n      font-size: 1.3rem;\n      line-height: 1.65;\n    }\n    .yc-reviews .yc-r-seemore-btn {\n      width: 100%;\n      font-size: 1.25rem;\n      padding: 1rem 1.5rem;\n    }\n  }\n</style>\n\n<div class=\"yc-reviews\">\n  <div class=\"yc-r-wrap\">\n\n    <!-- Summary bar -->\n    <div class=\"yc-r-summary\">\n      <div class=\"yc-r-rating\">\n        <span class=\"yc-r-stars\">★★★★★</span>\n        <span class=\"yc-r-score\">4.7 ▾</span>\n      </div>\n      <button class=\"yc-r-filter-btn\" type=\"button\" aria-label=\"Filter reviews\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M4 6h16M7 12h10M10 18h4\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n        </svg>\n      </button>\n    </div>\n\n    <!-- Review grid -->\n    <div class=\"yc-r-grid\" id=\"ycReviewGrid\">\n\n      <div class=\"yc-r-card yc-r-visible\">\n        <div class=\"yc-r-name-row\">Ava B.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">Was skeptical — it's a shampoo bar, how much can it really do? But my scalp feels completely different now. Less itchy, less flaky, and my hair genuinely feels thicker.</p>\n      </div>\n\n      <div class=\"yc-r-card yc-r-visible\">\n        <div class=\"yc-r-name-row\">Mia H.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">The shape is so satisfying to use — you can really massage it into your scalp. My hair already looks fuller after three weeks.</p>\n      </div>\n\n      <div class=\"yc-r-card yc-r-visible\">\n        <div class=\"yc-r-name-row\">Isabella C.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">I started seeing new growth after just 3–4 weeks of using this every 2–3 days. My hair was thinning from stress but this really made a difference.</p>\n      </div>\n\n      <div class=\"yc-r-card yc-r-visible\">\n        <div class=\"yc-r-name-row\">Evelyn K.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">I was skeptical. A shampoo bar? Really? But after just a few weeks I started noticing tiny baby hairs along my part.</p>\n      </div>\n\n      <div class=\"yc-r-card yc-r-visible\">\n        <div class=\"yc-r-name-row\">Mathew D.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">I've been using it for a few months now and I've seen so much new hair growth. The thin patches on my scalp have gradually filled in.</p>\n      </div>\n\n      <div class=\"yc-r-card yc-r-visible\">\n        <div class=\"yc-r-name-row\">Ashley R.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">I started seeing new growth after just 3–4 weeks of using this every 2–3 days. My hair was thinning from stress but this really made the difference.</p>\n      </div>\n\n      <div class=\"yc-r-card\">\n        <div class=\"yc-r-name-row\">Grace L.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">My scalp used to feel tight and irritated no matter what I used. This is the first thing that's actually calmed it down within a week.</p>\n      </div>\n\n      <div class=\"yc-r-card\">\n        <div class=\"yc-r-name-row\">Daniel P.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">Lasts way longer than I expected for the price. One bar has gotten me through almost two months of regular use.</p>\n      </div>\n\n      <div class=\"yc-r-card\">\n        <div class=\"yc-r-name-row\">Sophia T.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">My serums finally seem to be absorbing instead of just sitting on top of buildup. Wish I'd started using this sooner.</p>\n      </div>\n\n      <div class=\"yc-r-card\">\n        <div class=\"yc-r-name-row\">Noah W.</div>\n        <div class=\"yc-r-verified\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg>\n          Verified\n        </div>\n        <div class=\"yc-r-card-stars\">★★★★★</div>\n        <p class=\"yc-r-text\">The tingle after massaging it in is oddly satisfying and my scalp genuinely feels cleaner by the end of the week.</p>\n      </div>\n\n    </div>\n\n    <!-- See more -->\n    <div class=\"yc-r-seemore-wrap\">\n      <button class=\"yc-r-seemore-btn\" id=\"ycSeeMoreBtn\" type=\"button\">See more reviews</button>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  (function () {\n    var btn = document.getElementById('ycSeeMoreBtn');\n    var grid = document.getElementById('ycReviewGrid');\n    btn.addEventListener('click', function () {\n      var hidden = grid.querySelectorAll('.yc-r-card:not(.yc-r-visible)');\n      hidden.forEach(function (card) {\n        card.classList.add('yc-r-visible');\n      });\n      btn.classList.add('yc-r-hidden');\n    });\n  })();\n</script>",
