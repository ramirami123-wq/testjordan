    "custom_liquid_QWbLRi": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .faq-section {\n    background: #fff;\n    padding: 48px 24px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    max-width: 800px;\n    margin: 0 auto;\n    box-sizing: border-box;\n  }\n  .faq-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 38px);\n    color: #c9836a;\n    text-align: center;\n    margin: 0 0 36px;\n  }\n  .faq-list {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .faq-item {\n    background: #faf3ef;\n    border-radius: 12px;\n    overflow: hidden;\n  }\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 20px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    cursor: pointer;\n    text-align: left;\n    gap: 16px;\n  }\n  .faq-question span {\n    font-size: 15px;\n    font-weight: 600;\n    color: #222;\n    line-height: 1.4;\n  }\n  .faq-icon {\n    font-size: 22px;\n    color: #aaa;\n    font-weight: 300;\n    flex-shrink: 0;\n    transition: transform 0.25s ease;\n    line-height: 1;\n  }\n  .faq-item.open .faq-icon {\n    transform: rotate(45deg);\n    color: #c9836a;\n  }\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease, padding 0.3s ease;\n    padding: 0 20px;\n  }\n  .faq-item.open .faq-answer {\n    max-height: 300px;\n    padding: 0 20px 18px;\n  }\n  .faq-answer p {\n    font-size: 14px;\n    color: #555;\n    line-height: 1.7;\n    margin: 0;\n  }\n</style>\n\n<div class=\"faq-section\">\n  <h2 class=\"faq-title\">frequently asked questions</h2>\n  <div class=\"faq-list\">\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How often should I use the Scalp Scrub?</span>\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>We recommend using the Scalp Scrub 1–3 times a week, depending on your scalp's needs. Massage it in before shampooing, let it sit for a few minutes, then rinse thoroughly. Start with once a week if you have sensitive skin and build up from there.</p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Is it suitable for sensitive or irritated scalps?</span>\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>Yes. The formula is gentle enough for scalps prone to conditions like eczema, psoriasis, and dandruff, and it's free from sulfates, parabens, and steroids. We always recommend a patch test first, as individual reactions can vary.</p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Will it dry out my scalp or strip my hair color?</span>\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>No. The exfoliating granules are balanced with nourishing plant oils, so it clears buildup without over-drying. It's also color-safe, making it a good fit for treated or color-treated hair.</p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>What's the best way to apply the Scalp Scrub?</span>\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>Apply to wet hair before shampooing. Section your hair and massage the scrub directly onto your scalp using your fingertips in small circular motions. Let it sit for 2–3 minutes so the ingredients can work, then rinse well and follow with your regular shampoo.</p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How long does one jar last?</span>\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>With regular use of 1–3 times a week, one jar typically lasts around 4–8 weeks, depending on your hair length and how much product you use per application.</p>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  function toggleFaq(btn) {\n    const item = btn.closest('.faq-item');\n    const isOpen = item.classList.contains('open');\n    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));\n    if (!isOpen) item.classList.add('open');\n  }\n</script>",
        "full_width": false,
        "show_divider": false,
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "custom_liquid_PyWqQE": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .reviews-section {\n    background: #ffffff;\n    padding: 48px 20px 60px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    text-align: center;\n    box-sizing: border-box;\n  }\n\n  .reviews-hearts {\n    color: #c9836a;\n    font-size: 18px;\n    letter-spacing: 6px;\n    margin-bottom: 12px;\n  }\n\n  .reviews-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 40px);\n    color: #c9836a;\n    margin: 0 0 36px;\n  }\n\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    max-width: 1200px;\n    margin: 0 auto;\n    box-sizing: border-box;\n  }\n\n  .review-card {\n    background: #ffffff;\n    border: 1.5px solid #e8e8e8;\n    border-radius: 12px;\n    overflow: hidden;\n    text-align: left;\n    display: flex;\n    flex-direction: column;\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .review-card img {\n    width: 100%;\n    height: auto;\n    object-fit: contain;\n    display: block;\n    background: #faf3ef;\n  }\n\n  .review-body {\n    padding: 16px;\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    box-sizing: border-box;\n  }\n\n  .review-verified {\n    font-size: 11px;\n    font-weight: 700;\n    color: #c9836a;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .review-title {\n    font-size: 15px;\n    font-weight: 800;\n    color: #111111;\n    line-height: 1.3;\n    margin: 0;\n    word-break: break-word;\n  }\n\n  .review-text {\n    font-size: 13px;\n    color: #444444;\n    line-height: 1.6;\n    margin: 0;\n    word-break: break-word;\n    white-space: normal;\n  }\n\n  .review-body--textonly {\n    padding: 24px 20px 28px;\n    flex: 1;\n  }\n\n  .review-stars {\n    color: #c9836a;\n    font-size: 16px;\n    letter-spacing: 2px;\n    margin-bottom: 4px;\n  }\n\n  .reviews-toggle {\n    margin-top: 32px;\n    background: none;\n    border: 2px solid #c9836a;\n    color: #c9836a;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    padding: 12px 32px;\n    border-radius: 100px;\n    cursor: pointer;\n    transition: background 0.2s, color 0.2s;\n  }\n\n  .reviews-toggle:hover {\n    background: #c9836a;\n    color: #ffffff;\n  }\n\n  @media (max-width: 900px) {\n    .reviews-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 500px) {\n    .reviews-section {\n      padding: 36px 16px 48px;\n      width: 100%;\n      overflow-x: hidden;\n    }\n    .reviews-grid {\n      grid-template-columns: 1fr;\n      width: 100%;\n    }\n    .review-card {\n      width: 100%;\n      max-width: 100%;\n    }\n  }\n</style>\n\n<section class=\"reviews-section\">\n\n  <div class=\"reviews-hearts\">♥ ♥ ♥ ♥ ♥</div>\n  <h2 class=\"reviews-title\">Loved by Over 676 Customers</h2>\n\n  <div class=\"reviews-grid\">\n\n    <div class=\"review-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0742/4068/8311/files/14.webp?v=1783361927\" alt=\"Customer before and after photo 1\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">A total life changer</p>\n        <p class=\"review-text\">I wanted to share my before and after results after using the scalp scrub for a little over a month now. This stuff is amazing — a total life changer. I am much more confident now. — Nour</p>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0742/4068/8311/files/15_1.webp?v=1783361928\" alt=\"Customer before and after photo 2\">\n      <div class=\"review-body\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">Better than my prescriptions</p>\n        <p class=\"review-text\">I was super skeptical since I'd been using 3 different prescriptions for my scalp psoriasis, including a steroid. My husband and daughter both commented on how much better it looks. — Rania</p>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">Finally feel like myself again</p>\n        <p class=\"review-text\">After years of constant flaking, nothing ever worked — but ever since starting this scrub, the flakes are gone and my confidence is back. — Layal</p>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"reviews-grid\" id=\"extraReviews\" style=\"display:none; margin-top: 16px;\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">Freedom after years of struggle</p>\n        <p class=\"review-text\">My scalp has been a mess for years — embarrassed to wear black tops because of the flakes. Three weeks in, my scalp feels normal again, barely any flakes. — Karine</p>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">Soothes the itch</p>\n        <p class=\"review-text\">Makes my psoriasis itch less — genuinely noticeable difference within the first couple of uses. — Mirna</p>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Customer</span>\n        <div class=\"review-stars\">★★★★★</div>\n        <p class=\"review-title\">Helps with eczema flakes</p>\n        <p class=\"review-text\">This product is helping with my eczema scalp flakes as well as dry scalp issues. — Joyce</p>\n      </div>\n    </div>\n\n  </div>\n\n  <button class=\"reviews-toggle\" id=\"reviewsToggle\" onclick=\"toggleReviews()\">\n    See More Reviews ▾\n  </button>\n\n</section>\n\n<script>\n  function toggleReviews() {\n    var extra = document.getElementById('extraReviews');\n    var btn = document.getElementById('reviewsToggle');\n    if (extra.style.display === 'none') {\n      extra.style.display = 'grid';\n      btn.textContent = 'Show Less ▴';\n    } else {\n      extra.style.display = 'none';\n      btn.textContent = 'See More Reviews ▾';\n    }\n  }\n</script>",
