      "settings": {
        "custom_liquid": "<style>\n  .yc-hero-split {\n    all: initial;\n    display: block;\n    background: #FAF7F1;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n    padding: 2.5rem 1.5rem;\n    box-sizing: border-box;\n  }\n\n  .yc-hero-split *,\n  .yc-hero-split *::before,\n  .yc-hero-split *::after {\n    box-sizing: border-box;\n    font-family: inherit;\n  }\n\n  .yc-hero-split .yc-hs-wrap {\n    max-width: 1200px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 3rem;\n    align-items: center;\n  }\n\n  .yc-hero-split .yc-hs-image {\n    width: 100%;\n    height: 100%;\n    max-height: 620px;\n    object-fit: cover;\n    border-radius: 20px;\n    display: block;\n  }\n\n  .yc-hero-split .yc-hs-heading {\n    font-family: Georgia, \"Times New Roman\", serif;\n    font-size: 2.4rem;\n    color: #1c1c1c;\n    margin: 0 0 1rem 0;\n    line-height: 1.2;\n  }\n\n  .yc-hero-split .yc-hs-subheading {\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: #1c1c1c;\n    margin: 0 0 1rem 0;\n  }\n\n  .yc-hero-split .yc-hs-paragraph {\n    font-size: 1.05rem;\n    line-height: 1.65;\n    color: #3a3733;\n    margin: 0 0 1.5rem 0;\n  }\n\n  .yc-hero-split .yc-hs-pills {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 0.75rem;\n  }\n\n  .yc-hero-split .yc-hs-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 0.4rem;\n    background: #F0E4D6;\n    border: 1px solid #E0CBAE;\n    color: #3F5B4A;\n    padding: 0.55rem 1.1rem;\n    border-radius: 999px;\n    font-size: 0.95rem;\n    white-space: nowrap;\n  }\n\n  .yc-hero-split .yc-hs-pill svg {\n    width: 14px;\n    height: 14px;\n    flex-shrink: 0;\n  }\n\n  /* Tablet: stack, image on top */\n  @media (max-width: 860px) {\n    .yc-hero-split .yc-hs-wrap {\n      grid-template-columns: 1fr;\n      gap: 1.75rem;\n    }\n    .yc-hero-split .yc-hs-image {\n      max-height: 420px;\n    }\n  }\n\n  /* Mobile: bigger, comfortable text */\n  @media (max-width: 480px) {\n    .yc-hero-split {\n      padding: 1.75rem 1rem;\n    }\n    .yc-hero-split .yc-hs-image {\n      max-height: 340px;\n      border-radius: 16px;\n    }\n    .yc-hero-split .yc-hs-heading {\n      font-size: 2rem;\n    }\n    .yc-hero-split .yc-hs-subheading {\n      font-size: 1.25rem;\n    }\n    .yc-hero-split .yc-hs-paragraph {\n      font-size: 1.2rem;\n      line-height: 1.65;\n    }\n    .yc-hero-split .yc-hs-pill {\n      font-size: 1.1rem;\n      padding: 0.6rem 1.15rem;\n    }\n    .yc-hero-split .yc-hs-pill svg {\n      width: 16px;\n      height: 16px;\n    }\n  }\n</style>\n\n<div class=\"yc-hero-split\">\n  <div class=\"yc-hs-wrap\">\n\n    <img class=\"yc-hs-image\"\n         src=\"https://yoracare.com/cdn/shop/files/hf_20260417_165748_84847bda-55c6-4379-8191-b358cae706e6.webp?v=1776445985&width=1200\"\n         alt=\"Man running fingers through healthy hair\">\n\n    <div class=\"yc-hs-content\">\n      <h2 class=\"yc-hs-heading\">Thicker hair starts at the scalp.</h2>\n      <p class=\"yc-hs-subheading\">Perfect for men and women of all hair types.</p>\n      <p class=\"yc-hs-paragraph\">\n        Western haircare treats your hair. Korean haircare starts at the scalp. Our 12-Herb Fermented Scalp Revival Bar brings centuries of Korean scalp science to your shower in just 60 seconds. No water fillers. No sulfates. Just concentrated fermented botanicals that nourish your scalp and create the ideal environment for stronger, thicker, healthier hair to grow.\n      </p>\n      <div class=\"yc-hs-pills\">\n        <span class=\"yc-hs-pill\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M4 12.5l5 5L20 7\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n          Visible results in 6–8 weeks\n        </span>\n        <span class=\"yc-hs-pill\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M4 12.5l5 5L20 7\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n          100% natural ingredients\n        </span>\n      </div>\n    </div>\n\n  </div>\n</div>",
