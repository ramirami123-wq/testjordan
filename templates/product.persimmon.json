mer__colon\">:<\/div>\n      <div class=\"sale-timer__box\" id=\"st-secs\">00<\/div>\n    <\/div>\n  <\/div>\n\n  <script>\n    (function () {\n      const durationHours = 12; \/\/ change if needed\n      const endAt = Date.now() + durationHours * 60 * 60 * 1000;\n\n      const h = document.getElementById(\"st-hours\");\n      const m = document.getElementById(\"st-mins\");\n      const s = document.getElementById(\"st-secs\");\n\n      const pad = n => String(n).padStart(2, \"0\");\n\n      function update(){\n        let diff = endAt - Date.now();\n        if(diff < 0) diff = 0;\n\n        const total = Math.floor(diff \/ 1000);\n        h.textContent = pad(Math.floor(total \/ 3600));\n        m.textContent = pad(Math.floor((total % 3600) \/ 60));\n        s.textContent = pad(total % 60);\n\n        if(diff === 0) clearInterval(timer);\n      }\n\n      update();\n      const timer = setInterval(update, 1000);\n    })();\n  <\/script>\n<\/section>"}},"text_XfnRxT":{"type":"text","disabled":true,"settings":{"icon":"none","text":"Transform your face with this vegan, cruelty-free foundation designed to deliver the perfect match of your skin tone.","text_style":"body"}},"custom_liquid_H9DXEK":{"type":"custom_liquid","settings":{"custom_liquid":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" \/>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" \/>\n<title>Swarva Persimmon Soap Features Bar<\/title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    background: #fff;\n  }\n\n  .lv-features-wrap {\n    padding: 28px 20px 24px;\n    background: #fff;\n    border-bottom: 1px solid #e8e8e8;\n  }\n\n  .lv-tagline {\n    font-size: 15px;\n    color: #333;\n    line-height: 1.55;\n    margin-bottom: 24px;\n    max-width: 520px;\n  }\n\n  .lv-features {\n    display: flex;\n    gap: 0;\n    flex-wrap: nowrap;\n  }\n\n  .lv-fe