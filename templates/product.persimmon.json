enter;\n  }\n  .mms-icon-circle svg {\n    width: 34px;\n    height: 34px;\n  }\n  .mms-icon-label {\n    font-size: 13px;\n    color: #5C4033;\n    text-align: center;\n    font-weight: 500;\n  }\n  @media (max-width: 700px) {\n    .mms-icon-circle {\n      width: 60px;\n      height: 60px;\n    }\n    .mms-icon-circle svg {\n      width: 28px;\n      height: 28px;\n    }\n  }\n<\/style>\n\n<div class=\"mms-section\">\n  <div class=\"mms-inner\">\n    <div class=\"mms-content\">\n\n      <h2 class=\"mms-heading\">Fresh, Clean<br>Skin Again<\/h2>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">Washes away \"old age\" smell at the source.<\/p>\n        <p class=\"mms-block-desc\">Our real persimmon formula targets the oily odor that builds up with age — the kind regular soap can't break down. It lifts the smell away instead of just covering it up, so you feel clean and fresh from the very first wash.<\/p>\n      <\/div>\n\n      <div class=\"mms-block\">\n        <p class=\"mms-block-title\">Soft skin, not dry or tight.<\/p>\n        <p class=\"mms-block-desc\">Coconut oil, hyaluronic acid, and collagen wash and care for your skin at the same time. No harsh, drying soap feeling — just skin that feels smooth, soft, and looked-after every day.<\/p>\n      <\/div>\n\n      <div class=\"mms-icons\">\n\n        <!-- Removes Odor -->\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M6 14h15a3.5 3.5 0 1 0-3.5-3.5\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n              <path d=\"M6 19h20a3.5 3.5 0 1 1-3.5 3.5\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n              <path d=\"M6 25h11a3 3 0 1 1-3 3\" stroke=\"#c47a50\" stroke-width=\"1.3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.55\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">Removes Odor<\/span>\n        <\/div>\n\n        <!-- Real Persimmon -->\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M18 11c5 0 9 3.5 9 9.5S23 30 18 30 9 26.5 9 20.5 13 11 18 11z\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n              <path d=\"M13 11c1.3-1.7 3.2-2.5 5-2.5s3.7.8 5 2.5\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n              <path d=\"M18 8.5V11\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">Real Persimmon<\/span>\n        <\/div>\n\n        <!-- Softens Skin -->\n        <div class=\"mms-icon-item\">\n          <div class=\"mms-icon-circle\">\n            <svg viewBox=\"0 0 36 36\" fill=\"none\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M18 7c4 5 7.5 8.5 7.5 13a7.5 7.5 0 1 1-15 0c0-4.5 3.5-8 7.5-13z\" stroke=\"#c47a50\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n              <path d=\"M14.5 21a3.5 3.5 0 0 0 3.5 3.5\" stroke=\"#c47a50\" stroke-width=\"1.3\" stroke-linecap=\"round\" opacity=\"0.6\"\/>\n            <\/svg>\n          <\/div>\n          <span class=\"mms-icon-label\">Softens Skin<\/span>\n        <\/div>\n\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"scrolling_promotion_6Xj9FQ":{"type":"scrolling-promotion","blocks":{"announcement_QJYrYr":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_QJYrYr"],"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"image_with_text_X6KRyA":{"type":"image-with-text","blocks":{"heading_Y6bCpT":{"type":"heading","settings":{"heading":"Natural-Looking Freckles (No Skill, No Effort)","heading_size":"h1","heading_tag":"h2"}},"text_fXwrbU":{"type":"text","settings":{"text":"<p>Tired of <strong>uneven <\/strong>dots, streaky pencils, or freckles that look fake by lunchtime? This multi-point freckle stamp was built for real <strong>humans <\/strong>— not makeup artists.<\/p>","text_size":"typeset2","secondary_color":false}}},"block_order":["heading_Y6bCpT","text_fXwrbU"],"disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/73869677-F4A8-4401-8032-7FD4C16C25BD_1060x_0331b5a5-d549-4c42-aed4-bc24160e24f9.png","image_position":"center center","layout":"image_first","text_box_position":"middle","text_alignment":"left","image_ratio":"650px","enlarge_content":false,"full_width":false,"show_divider":false,"image_behavior":"none","mobile_layout":"image_first","mobile_text_alignment":"left","mobile_image_ratio":"auto","enable_video_looping":false,"video_url":"","use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","gradient_background":"","padding_top":36,"padding_bottom":36}},"scrolling_promotion_pD6Mdt":{"type":"scrolling-promotion","blocks":{"announcement_CR4hbT":{"type":"announcement","settings":{"icon":"none","icon_size":"medium","custom_icon":"","text":"FREE DELIVERY ALL OVER LEBANON","text_size":20,"link":""}}},"block_order":["announcement_CR4hbT"],"disabled":true,"name":"t:sections.scrolling-promotion.presets.name","settings":{"direction":"left","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#ffffff","colors_text":"#000000","colors_background":"#e7d5c7","gradient_background":"","padding_top":20,"padding_bottom":20}},"custom_liquid_QWbLRi":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .faq-section {\n    background: #FFFDF9;\n    padding: 48px 24px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    max-width: 800px;\n    margin: 0 auto;\n    box-sizing: border-box;\n  }\n  .faq-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 38px);\n    color: #c9836a;\n    text-align: center;\n    margin: 0 0 36px;\n  }\n  .faq-list {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .faq-item {\n    background: #F3E7DC;\n    border-radius: 12px;\n    overflow: hidden;\n  }\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 20px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    cursor: pointer;\n    text-align: left;\n    gap: 16px;\n  }\n  .faq-question span {\n    font-size: 15px;\n    font-weight: 600;\n    color: #5C4033;\n    line-height: 1.4;\n  }\n  .faq-icon {\n    font-size: 22px;\n    color: #c9836a;\n    font-weight: 300;\n    flex-shrink: 0;\n    transition: transform 0.25s ease;\n    line-height: 1;\n  }\n  .faq-item.open .faq-icon {\n    transform: rotate(45deg);\n    color: #5C4033;\n  }\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease, padding 0.3s ease;\n    padding: 0 20px;\n  }\n  .faq-item.open .faq-answer {\n    max-height: 400px;\n    padding: 0 20px 18px;\n  }\n  .faq-answer p {\n    font-size: 14px;\n    color: #5C4033;\n    line-height: 1.7;\n    margin: 0;\n  }\n<\/style>\n\n<div class=\"faq-section\">\n  <h2 class=\"faq-title\">frequently asked questions<\/h2>\n  <div class=\"faq-list\">\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>When will I start seeing results?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Most people feel cleaner and fresher from the very first wash. The persimmon works right away to lift the odor instead of just covering it up. For the best results, use it every day — most customers say they feel fresh and more confident within the first few days.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How long does one bar last?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Each bar lasts about 4 weeks with daily use. To make it last longer, keep it on a dry soap dish between showers so it doesn't sit in water. Let it dry out fully between uses and it'll hold up much better.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>What is the \"old age\" smell, and why won't regular soap remove it?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>As we get older, the skin makes more of an oily compound that causes that musty, stuffy \"old person\" smell. Because it's oil-based, normal soap and water just can't break it down — no matter how hard you scrub. Persimmon works on it directly, like a degreaser for odor, so it washes away instead of clinging to your skin.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Will it dry out my skin?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>No — the opposite. It's made with coconut oil, hyaluronic acid, and collagen, so it cleans and cares for your skin at the same time. No harsh, tight, dried-out feeling. Most customers say their skin feels softer than it has in years.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Where on my body should I use it?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Use it all over in the shower, and pay extra attention to the spots that hold odor most — underarms, chest, back, and feet. Work up a lather, let it sit for about 30 seconds, then rinse well. Gentle enough for daily use.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Is it safe for sensitive or mature skin?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Yes. It's a gentle, moisturizing formula made with older and sensitive skin in mind — no harsh stripping. If your skin is very sensitive, start every other day and build up to daily use. A quick patch test is always a good idea.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Can I buy it for a parent or partner without making it awkward?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>Many customers do exactly that. It looks and feels like a nice, premium soap — there's nothing on it that screams \"odor problem.\" A lot of people simply swap it into the shower, and the smell quietly goes away. It's a kind, no-pressure way to help someone you love feel fresh and confident.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>What if it doesn't work for me?<\/span>\n        <span class=\"faq-icon\">+<\/span>\n      <\/button>\n      <div class=\"faq-answer\">\n        <p>You're covered by our 60-night money-back guarantee. If you don't feel the difference after using it daily, just contact us for a full refund — no questions asked.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<script>\n  function toggleFaq(btn) {\n    const item = btn.closest('.faq-item');\n    const isOpen = item.classList.contains('open');\n    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));\n    if (!isOpen) item.classList.add('open');\n  }\n<\/script>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"custom_liquid_PyWqQE":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .reviews-section {\n    background: #FFFDF9;\n    padding: 48px 20px 60px;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    text-align: center;\n    box-sizing: border-box;\n    width: 100%;\n    overflow-x: hidden;\n  }\n\n  .reviews-hearts {\n    color: #c9836a;\n    font-size: 18px;\n    letter-spacing: 6px;\n    margin-bottom: 12px;\n  }\n\n  .reviews-title {\n    font-family: Georgia, 'Times New Roman', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(24px, 4vw, 40px);\n    color: #c9836a;\n    margin: 0 0 36px;\n  }\n\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    max-width: 1100px;\n    margin: 0 auto;\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .review-card {\n    background: #ffffff;\n    border: 1.5px solid #E8D8C9;\n    border-radius: 12px;\n    overflow: hidden;\n    text-align: left;\n    display: flex;\n    flex-direction: column;\n    box-sizing: border-box;\n    width: 100%;\n    min-width: 0;\n  }\n\n  .review-card img {\n    width: 100%;\n    aspect-ratio: 3 \/ 4;\n    object-fit: cover;\n    display: block;\n  }\n\n  .review-body {\n    padding: 16px;\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    box-sizing: border-box;\n    min-width: 0;\n  }\n\n  .review-verified {\n    font-size: 11px;\n    font-weight: 700;\n    color: #c9836a;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .review-title {\n    font-size: 15px;\n    font-weight: 800;\n    color: #5C4033;\n    line-height: 1.3;\n    margin: 0;\n    overflow-wrap: break-word;\n  }\n\n  .review-text {\n    font-size: 13px;\n    color: #5C4033;\n    line-height: 1.6;\n    margin: 0;\n    overflow-wrap: break-word;\n    white-space: normal;\n  }\n\n  .review-name {\n    font-size: 13px;\n    font-weight: 700;\n    color: #5C4033;\n    margin: 4px 0 0;\n  }\n\n  .review-body--textonly {\n    padding: 24px 20px 28px;\n    flex: 1;\n  }\n\n  .review-stars {\n    color: #c9836a;\n    font-size: 16px;\n    letter-spacing: 2px;\n    margin-bottom: 4px;\n  }\n\n  .reviews-toggle {\n    margin-top: 32px;\n    background: none;\n    border: 2px solid #c9836a;\n    color: #c9836a;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    padding: 12px 32px;\n    border-radius: 100px;\n    cursor: pointer;\n    transition: background 0.2s, color 0.2s;\n  }\n\n  .reviews-toggle:hover {\n    background: #c9836a;\n    color: #ffffff;\n  }\n\n  @media (max-width: 900px) {\n    .reviews-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 560px) {\n    .reviews-section {\n      padding: 36px 16px 48px;\n    }\n    .reviews-grid {\n      grid-template-columns: 1fr;\n      width: 100%;\n    }\n    .review-card {\n      width: 100%;\n      max-width: 100%;\n    }\n    .reviews-title {\n      font-size: clamp(22px, 6vw, 32px);\n    }\n  }\n<\/style>\n\n<section class=\"reviews-section\">\n\n  <div class=\"reviews-hearts\">♥ ♥ ♥ ♥ ♥<\/div>\n  <h2 class=\"reviews-title\">Real Stories from Real Customers<\/h2>\n\n  <div class=\"reviews-grid\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">My daughter says I smell wonderful<\/p>\n        <p class=\"review-text\">I'm 67 and don't think I have the smell yet, but I remember it from my grandmother's house. I started using Swarva just in case. My daughter says I smell wonderful, and I have total peace of mind now.<\/p>\n        <p class=\"review-name\">— Janet R.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">I quietly switched his soap — the smell is gone<\/p>\n        <p class=\"review-text\">My husband showers every day, but he was starting to smell like an old man and I didn't know how to tell him. I just switched his soap to Swarva. The smell is completely gone and he says his skin feels better than it has in years.<\/p>\n        <p class=\"review-name\">— Diane K.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">Gone after just one use<\/p>\n        <p class=\"review-text\">I'm 71 and kept noticing a faint smell a fresh shower couldn't fix. I was skeptical but desperate. After one use of Swarva the difference was remarkable. The odor is gone and stays gone. Wish I'd found this sooner.<\/p>\n        <p class=\"review-name\">— Christine M.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <div class=\"reviews-grid\" id=\"extraReviews\" style=\"display:none; margin-top: 16px;\">\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">She smells fresh and feels dignified<\/p>\n        <p class=\"review-text\">I care for my 82-year-old mother and was desperate about that lingering smell. I thought she just needed more showers — I didn't know it was a chemical change. Swarva worked within days. She smells fresh and feels dignified again.<\/p>\n        <p class=\"review-name\">— Elena T.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">No heavy perfume, not drying<\/p>\n        <p class=\"review-text\">We love it. No more odor worries and it feels so nice to use. There's no heavy perfume covering things up, and it isn't harsh or drying like other soaps I've tried. It just leaves me feeling clean.<\/p>\n        <p class=\"review-name\">— Victoria M.<\/p>\n      <\/div>\n    <\/div>\n\n    <div class=\"review-card\">\n      <div class=\"review-body review-body--textonly\">\n        <span class=\"review-verified\">✓ Verified Buyer<\/span>\n        <div class=\"review-stars\">★★★★★<\/div>\n        <p class=\"review-title\">My skin feels softer than it has in years<\/p>\n        <p class=\"review-text\">I expected a soap that just dealt with odor, but my skin actually feels softer and more hydrated after every wash. No tight, dried-out feeling at all. I'm on my second bar and I'm not going back to regular soap.<\/p>\n        <p class=\"review-name\">— Robert H.<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <button class=\"reviews-toggle\" id=\"reviewsToggle\" onclick=\"toggleReviews()\">\n    See More Reviews ▾\n  <\/button>\n\n<\/section>\n\n<script>\n  function toggleReviews() {\n    var extra = document.getElementById('extraReviews');\n    var btn = document.getElementById('reviewsToggle');\n    if (extra.style.display === 'none') {\n      extra.style.display = 'grid';\n      btn.textContent = 'Show Less ▴';\n    } else {\n      extra.style.display = 'none';\n      btn.textContent = 'See More Reviews ▾';\n    }\n  }\n<\/script>","full_width":true,"show_divider":false,"padding_top":36,"padding_bottom":36}}},"order":["empty-space","main","product-recommendations","custom_liquid_cqKTNy","scrolling_promotion_6Xj9FQ","image_with_text_X6KRyA","scrolling_promotion_pD6Mdt","custom_liquid_QWbLRi","custom_liquid_PyWqQE"]}