4 6 0 4-4 6 0 4 4 6 0 4-4 6 0\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <path d=\"M6 30c2-3 4-3 6 0s4 3 6 0 4-3 6 0 4 3 6 0 4-3 6 0\" stroke=\"#1a1a1a\" stroke-width=\"1\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.35\"/>\n          <path d=\"M6 14c2-3 4-3 6 0s4 3 6 0 4-3 6 0 4 3 6 0 4-3 6 0\" stroke=\"#1a1a1a\" stroke-width=\"1\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.35\"/>\n        </svg>\n      </div>\n      <span class=\"lv-label\">Quietly Working<br>Around the Clock</span>\n    </div>\n\n    <!-- No Chemicals -->\n    <div class=\"lv-feat\">\n      <div class=\"lv-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- No-drop / ban icon -->\n          <circle cx=\"22\" cy=\"22\" r=\"14\" stroke=\"#1a1a1a\" stroke-width=\"1.6\"/>\n          <path d=\"M12 12l20 20\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n          <path d=\"M22 12c3.5 4 5 7 5 10s-1.5 6-5 10c-3.5-4-5-7-5-10s1.5-6 5-10z\" stroke=\"#1a1a1a\" stroke-width=\"1.2\" opacity=\"0.5\"/>\n        </svg>\n      </div>\n      <span class=\"lv-label\">Zero Sprays<br>Zero Poison</span>\n    </div>\n\n    <!-- No Traps -->\n    <div class=\"lv-feat\">\n      <div class=\"lv-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Trash / discard icon (retiring the trap) -->\n          <path d=\"M14 16h16l-1.4 18.5a2 2 0 01-2 1.5H17.4a2 2 0 01-2-1.5L14 16z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linejoin=\"round\"/>\n          <path d=\"M11 16h22\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n          <path d=\"M18 10h8l1.5 6h-11z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linejoin=\"round\"/>\n          <line x1=\"19\" y1=\"21\" x2=\"19\" y2=\"30\" stroke=\"#1a1a1a\" stroke-width=\"1\" opacity=\"0.4\"/>\n          <line x1=\"25\" y1=\"21\" x2=\"25\" y2=\"30\" stroke=\"#1a1a1a\" stroke-width=\"1\" opacity=\"0.4\"/>\n        </svg>\n      </div>\n      <span class=\"lv-label\">No Traps to Set<br>or Empty</span>\n    </div>\n\n    <!-- Safe Around Family -->\n    <div class=\"lv-feat\">\n      <div class=\"lv-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Shield icon -->\n          <path d=\"M22 8l12 4v10c0 8-6 13-12 14-6-1-12-6-12-14V12l12-4z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linejoin=\"round\"/>\n          <path d=\"M17 22l4 4 8-8\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </div>\n      <span class=\"lv-label\">Safe Around<br>Kids &amp; Pets</span>\n    </div>\n\n  </div>\n</div>\n\n</body>\n</html>"
