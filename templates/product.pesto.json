      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<title>PestLab™ Pest Repeller</title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --black: #111827;\n    --white: #ffffff;\n    --gray-light: #f5f6f7;\n    --gray-mid: #e0e0e0;\n    --gray-text: #666;\n    --accent: #1a7f5a;\n    --accent-dark: #145f44;\n    --green: #1a7f5a;\n    --gold: #f4a261;\n    --font: 'Helvetica Neue', Arial, sans-serif;\n  }\n\n  body { font-family: var(--font); color: var(--black); background: var(--white); line-height: 1.6; }\n\n  /* ── CUSTOMER BANNER ── */\n  .customer-banner {\n    background: var(--black);\n    color: var(--white);\n    padding: 14px 20px;\n    text-align: center;\n    font-size: 14px;\n    font-weight: 600;\n    letter-spacing: 0.5px;\n    width: 100%;\n  }\n  .customer-banner span { color: var(--gold); }\n\n  /* ── SECTION TITLES ── */\n  .section-title {\n    font-size: 30px; font-weight: 800; text-align: center;\n    margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;\n  }\n  .section-subtitle {\n    text-align: center; color: var(--gray-text); font-size: 16px;\n    margin-bottom: 50px; max-width: 680px; margin-left: auto; margin-right: auto;\n  }\n\n  /* ── GET YOUR HOME BACK ── */\n  .feel-section { padding: 80px 5%; background: var(--white); }\n  .feel-inner {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;\n  }\n  .feel-img { border-radius: 14px; overflow: hidden; height: 520px; background: linear-gradient(135deg,#eef6f2,#f8fbfa); display:flex; align-items:center; justify-content:center; }\n  .feel-img svg { width: 70%; height: 70%; }\n  .feel-text h2 { font-size: 32px; font-weight: 800; margin-bottom: 20px; line-height: 1.2; }\n  .feel-text p { font-size: 16px; color: #444; margin-bottom: 20px; line-height: 1.7; }\n  .feel-text ul { list-style: none; padding: 0; }\n  .feel-text ul li {\n    padding: 10px 0; font-size: 15px; border-bottom: 1px solid var(--gray-mid);\n    display: flex; align-items: flex-start; gap: 10px;\n  }\n  .feel-text ul li::before {\n    content: \"✓\"; color: var(--green); font-weight: 900; font-size: 17px;\n    flex-shrink: 0; margin-top: 1px;\n  }\n\n  /* ── TIP CALLOUT (replaces fabricated testimonial) ── */\n  .quote-box {\n    background: var(--gray-light); border-left: 5px solid var(--accent);\n    padding: 24px 28px; border-radius: 0 12px 12px 0; margin-top: 32px;\n  }\n  .quote-box p { font-size: 15px; color: #333; line-height: 1.6; }\n  .quote-box strong { color: var(--accent-dark); }\n\n  /* ── HOW IT WORKS (dark) ── */\n  .how-section { background: var(--black); padding: 80px 5%; color: var(--white); }\n  .how-section .section-title { color: var(--white); }\n  .how-section .section-subtitle { color: rgba(255,255,255,0.6); }\n  .how-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 28px; }\n  .how-card {\n    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);\n    border-radius: 14px; padding: 32px 24px; text-align: center;\n  }\n  .how-card .icon-wrap {\n    width: 64px; height: 64px; background: var(--accent); border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    margin: 0 auto 20px; font-size: 28px;\n  }\n  .how-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 10px; color: var(--white); text-transform: uppercase; letter-spacing: 0.5px; }\n  .how-card p { font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.6; }\n\n  /* ── PESTLAB VS TRADITIONAL METHODS ── */\n  .upgrade-section { background: var(--gray-light); padding: 80px 5%; }\n  .upgrade-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 40px; }\n  .upgrade-card { background: var(--white); border-radius: 14px; overflow: hidden; border: 2px solid var(--gray-mid); }\n  .upgrade-card.winner { border-color: var(--black); }\n  .upgrade-card-header { padding: 18px 24px; font-size: 18px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; background: var(--gray-mid); color: var(--black); }\n  .upgrade-card.winner .upgrade-card-header { background: var(--black); color: var(--white); }\n  .upgrade-card .card-visual { height: 180px; display:flex; align-items:center; justify-content:center; background:#fafafa; }\n  .upgrade-card .card-visual svg { width: 88px; height: 88px; }\n  .upgrade-list { list-style: none; padding: 20px 24px; }\n  .upgrade-list li { padding: 9px 0; font-size: 14px; border-bottom: 1px solid #f0f0f0; display: flex; align-items: center; gap: 10px; }\n  .upgrade-list li:last-child { border-bottom: none; }\n  .check-green { color: var(--green); font-weight: 900; font-size: 16px; }\n  .check-red   { color: #c0392b; font-weight: 900; font-size: 16px; }\n\n  /* ── SPECS ── */\n  .results-section { padding: 80px 5%; background: var(--white); }\n  .results-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }\n  .results-img { border-radius: 14px; height: 500px; background: linear-gradient(135deg,#f5f6f7,#ffffff); display:flex; align-items:center; justify-content:center; }\n  .results-img svg { width: 65%; height: 65%; }\n  .stats-list { display: flex; flex-direction: column; gap: 28px; }\n  .stat-item { display: flex; align-items: flex-start; gap: 20px; }\n  .stat-number { font-size: 44px; font-weight: 900; color: var(--accent); line-height: 1; flex-shrink: 0; min-width: 110px; }\n  .stat-desc { font-size: 15px; color: #444; padding-top: 10px; line-height: 1.5; }\n  .stat-note { font-size: 12px; color: var(--gray-text); margin-top: 24px; font-style: italic; }\n\n  /* ── GUARANTEE ── */\n  .guarantee-section { background: var(--black); color: var(--white); padding: 80px 5%; text-align: center; }\n  .guarantee-section h2 { font-size: 30px; font-weight: 800; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px; }\n  .guarantee-section > p { font-size: 17px; color: rgba(255,255,255,0.75); max-width: 680px; margin: 0 auto 48px; line-height: 1.7; }\n  .trust-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }\n  .trust-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; padding: 24px 16px; }\n  .trust-card .trust-icon { font-size: 32px; margin-bottom: 12px; }\n  .trust-card h4 { font-size: 14px; font-weight: 700; color: var(--white); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.3px; }\n  .trust-card p { font-size: 12px; color: rgba(255,255,255,0.5); margin: 0; }\n\n  /* ── RESPONSIVE ── */\n  @media (max-width: 900px) {\n    .feel-inner, .results-inner, .upgrade-grid { grid-template-columns: 1fr; }\n    .feel-img, .results-img { height: 320px; }\n    .how-grid { grid-template-columns: 1fr; }\n    .trust-grid { grid-template-columns: 1fr 1fr; gap: 14px; }\n    .section-title { font-size: 24px; }\n    .stat-number { font-size: 36px; }\n  }\n\n  @media (max-width: 480px) {\n    .feel-section, .how-section, .upgrade-section,\n    .results-section, .guarantee-section { padding: 50px 4%; }\n    .trust-grid { grid-template-columns: 1fr 1fr; gap: 12px; }\n    .trust-card { padding: 18px 12px; }\n    .trust-card .trust-icon { font-size: 26px; }\n    .trust-card h4 { font-size: 12px; }\n    .trust-card p { font-size: 11px; }\n    .guarantee-section h2 { font-size: 22px; }\n    .guarantee-section > p { font-size: 15px; }\n    .feel-text h2 { font-size: 24px; }\n    .stat-number { font-size: 32px; min-width: 90px; }\n  }\n</style>\n</head>\n<body>\n\n<!-- ── BANNER ── -->\n<div class=\"customer-banner\">🐭 No Chemicals. No Traps. Just <span>Plug In And Go</span>.</div>\n\n<!-- ── GET YOUR HOME BACK ── -->\n<section class=\"feel-section\">\n  <div class=\"feel-inner\">\n    <div class=\"feel-img\">\n      <svg viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M40 120L100 70L160 120V165H40V120Z\" stroke=\"#1a7f5a\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n        <rect x=\"60\" y=\"130\" width=\"25\" height=\"35\" stroke=\"#1a7f5a\" stroke-width=\"2.5\"/>\n        <circle cx=\"100\" cy=\"70\" r=\"6\" fill=\"#1a7f5a\"/>\n        <path d=\"M115 60c6-8 6-18 0-26\" stroke=\"#1a7f5a\" stroke-width=\"2.5\" stroke-linecap=\"round\" opacity=\"0.6\"/>\n        <path d=\"M128 52c9-11 9-27 0-38\" stroke=\"#1a7f5a\" stroke-width=\"2.5\" stroke-linecap=\"round\" opacity=\"0.35\"/>\n        <path d=\"M85 60c-6-8-6-18 0-26\" stroke=\"#1a7f5a\" stroke-width=\"2.5\" stroke-linecap=\"round\" opacity=\"0.6\"/>\n        <path d=\"M72 52c-9-11-9-27 0-38\" stroke=\"#1a7f5a\" stroke-width=\"2.5\" stroke-linecap=\"round\" opacity=\"0.35\"/>\n      </svg>\n    </div>\n    <div class=\"feel-text\">\n      <h2>Reclaim Every Room From Pests</h2>\n      <p>No more chewed wires, no more scratching in the walls, no more checking traps before you make breakfast. PestLab plugs into any outlet and gets to work right away — no setup, no mess.</p>\n      <p>It emits a variable ultrasonic frequency, above the range of human hearing, designed to make the plugged-in room an uncomfortable place for common household pests to settle in.</p>\n      <ul>\n        <li><div><strong>No chemicals or poison</strong> — nothing to keep away from kids or pets</div></li>\n        <li><div><strong>No traps to set, empty, or clean</strong></div></li>\n        <li><div><strong>No batteries or refills</strong> — just plug it in and leave it</div></li>\n        <li><div><strong>Silent to most human ears</strong> — runs continuously in the background</div></li>\n        <li><div><strong>One unit per room</strong> — add more for larger homes</div></li>\n      </ul>\n      <div class=\"quote-box\">\n        <p><strong>Good to know:</strong> Ultrasonic repellers work best as one part of a broader routine. Pair PestLab with sealing obvious entry points and removing exposed food sources for the most complete results.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ── HOW IT WORKS ── -->\n<section class=\"how-section\">\n  <p class=\"section-title\">How PestLab Works</p>\n  <p class=\"section-subtitle\">A simple, low-maintenance approach to an unwanted problem.</p>\n  <div class=\"how-grid\">\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">🔊</div>\n      <h3>Ultrasonic Frequency</h3>\n      <p>Emits a shifting high-frequency sound, generally in the 20–65kHz range, well above what most humans can hear.</p>\n    </div>\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">🔌</div>\n      <h3>Plug-In Simplicity</h3>\n      <p>Works in any standard outlet. No wiring, no app, no manual to read — just plug it in and it's running.</p>\n    </div>\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">♾️</div>\n      <h3>Runs Continuously</h3>\n      <p>No batteries to replace and no refills to buy. Leave it plugged in and move it room to room as needed.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── PESTLAB VS TRADITIONAL METHODS ── -->\n<section class=\"upgrade-section\">\n  <p class=\"section-title\">PestLab vs. Traditional Methods</p>\n  <p class=\"section-subtitle\">How a plug-in repeller compares to sprays and traps.</p>\n  <div class=\"upgrade-grid\">\n    <div class=\"upgrade-card winner\">\n      <div class=\"upgrade-card-header\">✅ PestLab</div>\n      <div class=\"card-visual\">\n        <svg viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <rect x=\"30\" y=\"20\" width=\"40\" height=\"55\" rx=\"6\" stroke=\"#1a7f5a\" stroke-width=\"3\"/>\n          <line x1=\"42\" y1=\"80\" x2=\"42\" y2=\"90\" stroke=\"#1a7f5a\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n          <line x1=\"58\" y1=\"80\" x2=\"58\" y2=\"90\" stroke=\"#1a7f5a\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n          <path d=\"M75 35c5-4 5-10 0-14\" stroke=\"#1a7f5a\" stroke-width=\"2.5\" stroke-linecap=\"round\" opacity=\"0.6\"/>\n          <path d=\"M83 30c7-6 7-15 0-21\" stroke=\"#1a7f5a\" stroke-width=\"2.5\" stroke-linecap=\"round\" opacity=\"0.3\"/>\n        </svg>\n      </div>\n      <ul class=\"upgrade-list\">\n        <li><span class=\"check-green\">✓</span> No poison or chemicals in your home</li>\n        <li><span class=\"check-green\">✓</span> Nothing to trap, clean up, or dispose of</li>\n        <li><span class=\"check-green\">✓</span> Runs continuously, no daily monitoring</li>\n        <li><span class=\"check-green\">✓</span> One-time plug-in setup</li>\n        <li><span class=\"check-green\">✓</span> 90-day money-back guarantee</li>\n      </ul>\n    </div>\n    <div class=\"upgrade-card\">\n      <div class=\"upgrade-card-header\">Traditional Sprays & Traps</div>\n      <div class=\"card-visual\">\n        <svg viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" opacity=\"0.6\">\n          <rect x=\"35\" y=\"30\" width=\"18\" height=\"40\" rx=\"3\" stroke=\"#c0392b\" stroke-width=\"3\"/>\n          <rect x=\"40\" y=\"18\" width=\"8\" height=\"14\" stroke=\"#c0392b\" stroke-width=\"2.5\"/>\n          <rect x=\"58\" y=\"45\" width=\"28\" height=\"18\" rx=\"2\" stroke=\"#c0392b\" stroke-width=\"3\"/>\n        </svg>\n      </div>\n      <ul class=\"upgrade-list\">\n        <li><span class=\"check-red\">✗</span> Chemical sprays and baits</li>\n        <li><span class=\"check-red\">✗</span> Traps that need checking and emptying</li>\n        <li><span class=\"check-red\">✗</span> Ongoing cost of refills and replacements</li>\n        <li><span class=\"check-red\">✗</span> Regular upkeep required</li>\n        <li><span class=\"check-red\">✗</span> Return policy varies by retailer</li>\n      </ul>\n    </div>\n  </div>\n</section>\n\n<!-- ── SPECS ── -->\n<section class=\"results-section\">\n  <div class=\"results-inner\">\n    <div class=\"results-img\">\n      <svg viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect x=\"70\" y=\"60\" width=\"60\" height=\"90\" rx=\"8\" stroke=\"#1a7f5a\" stroke-width=\"3\"/>\n        <rect x=\"88\" y=\"140\" width=\"10\" height=\"14\" stroke=\"#1a7f5a\" stroke-width=\"2.5\"/>\n        <rect x=\"102\" y=\"140\" width=\"10\" height=\"14\" stroke=\"#1a7f5a\" stroke-width=\"2.5\"/>\n        <circle cx=\"100\" cy=\"90\" r=\"10\" stroke=\"#1a7f5a\" stroke-width=\"2.5\"/>\n        <path d=\"M100 60c0-15 20-15 20-30\" stroke=\"#1a7f5a\" stroke-width=\"2\" opacity=\"0.4\"/>\n      </svg>\n    </div>\n    <div>\n      <h2 style=\"font-size:30px;font-weight:800;margin-bottom:36px;text-transform:uppercase;letter-spacing:1px;\">The Basics</h2>\n      <div class=\"stats-list\">\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">300 ft²</div>\n          <p class=\"stat-desc\">Manufacturer-rated coverage per unit. Use one per room, and add more units for larger or multi-room spaces.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">90 Day</div>\n          <p class=\"stat-desc\">Full money-back guarantee if you decide PestLab isn't right for your home.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">0</div>\n          <p class=\"stat-desc\">Batteries, refills, or chemicals required — just plug it in.</p>\n        </div>\n      </div>\n      <p class=\"stat-note\">*Coverage figures are manufacturer specifications, not independently verified lab results.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── GUARANTEE ── -->\n<section class=\"guarantee-section\">\n  <h2>Simple To Use. Backed By Our Guarantee.</h2>\n  <p>PestLab is built to be a low-effort, low-maintenance addition to your home. Try it risk-free with our 90-day money-back guarantee.</p>\n  <div class=\"trust-grid\">\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">🛡️</div>\n      <h4>90-Day Guarantee</h4>\n      <p>Full refund if you're not satisfied within 90 days.</p>\n    </div>\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">🔌</div>\n      <h4>No Batteries Ever</h4>\n      <p>Just plug in and leave it — nothing to charge or replace.</p>\n    </div>\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">🏠</div>\n      <h4>Room-By-Room Coverage</h4>\n      <p>Designed to be used in each room where pests are a concern.</p>\n    </div>\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">💬</div>\n      <h4>Here To Help</h4>\n      <p>Our support team is ready to help with setup or questions.</p>\n    </div>\n  </div>\n</section>\n\n</body>\n</html>",
