erways -->\n    <div class=\"lv-feat\">\n      <div class=\"lv-icon\">\n        <svg viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Water droplet icon -->\n          <path d=\"M22 6c6 8 10 13.5 10 19a10 10 0 0 1-20 0c0-5.5 4-11 10-19z\" stroke=\"#1a1a1a\" stroke-width=\"1.6\" stroke-linejoin=\"round\"/>\n          <path d=\"M16 27a6 6 0 0 0 6 6\" stroke=\"#1a1a1a\" stroke-width=\"1.2\" stroke-linecap=\"round\" opacity=\"0.5\"/>\n        </svg>\n      </div>\n      <span class=\"lv-label\">Safe for Pipes<br>&amp; Nature</span>\n    </div>\n\n  </div>\n</div>\n\n</body>\n</html>"
