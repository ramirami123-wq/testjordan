        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<title>Dishwashing Detergent Sheets — Clean Dishes, No Plastic</title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --black: #111827;\n    --white: #ffffff;\n    --gray-light: #f5f6f7;\n    --gray-mid: #e0e0e0;\n    --gray-text: #666;\n    --accent: #2f7d5a;\n    --accent-dark: #235e43;\n    --green: #1a7f5a;\n    --gold: #e8b04b;\n    --font: 'Helvetica Neue', Arial, sans-serif;\n  }\n\n  body { font-family: var(--font); color: var(--black); background: var(--white); line-height: 1.6; }\n\n  /* ── CUSTOMER BANNER ── */\n  .customer-banner {\n    background: var(--black);\n    color: var(--white);\n    padding: 14px 20px;\n    text-align: center;\n    font-size: 14px;\n    font-weight: 600;\n    letter-spacing: 0.5px;\n    width: 100%;\n  }\n  .customer-banner span { color: var(--gold); }\n\n  /* ── SECTION TITLES ── */\n  .section-title {\n    font-size: 30px; font-weight: 800; text-align: center;\n    margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;\n  }\n  .section-subtitle {\n    text-align: center; color: var(--gray-text); font-size: 16px;\n    margin-bottom: 50px; max-width: 680px; margin-left: auto; margin-right: auto;\n  }\n\n  /* ── FEEL BETTER ── */\n  .feel-section { padding: 80px 5%; background: var(--white); }\n  .feel-inner {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;\n  }\n  .feel-img img { width: 100%; border-radius: 14px; object-fit: cover; height: 520px; }\n  .feel-text h2 { font-size: 32px; font-weight: 800; margin-bottom: 20px; line-height: 1.2; }\n  .feel-text p { font-size: 16px; color: #444; margin-bottom: 20px; line-height: 1.7; }\n  .feel-text ul { list-style: none; padding: 0; }\n  .feel-text ul li {\n    padding: 10px 0; font-size: 15px; border-bottom: 1px solid var(--gray-mid);\n    display: flex; align-items: flex-start; gap: 10px;\n  }\n  .feel-text ul li::before {\n    content: \"✓\"; color: var(--green); font-weight: 900; font-size: 17px;\n    flex-shrink: 0; margin-top: 1px;\n  }\n\n  /* ── TESTIMONIAL QUOTE ── */\n  .quote-box {\n    background: var(--gray-light); border-left: 5px solid var(--accent);\n    padding: 24px 28px; border-radius: 0 12px 12px 0; margin-top: 32px;\n  }\n  .quote-box p { font-style: italic; font-size: 16px; color: #333; margin-bottom: 12px; }\n  .quote-author { display: flex; align-items: center; gap: 12px; }\n  .avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; background: var(--gray-mid); }\n  .author-info strong { display: block; font-size: 14px; font-weight: 700; }\n  .author-info span { font-size: 12px; color: var(--gray-text); }\n  .stars { color: var(--gold); font-size: 14px; letter-spacing: 2px; }\n\n  /* ── HOW IT WORKS (dark) ── */\n  .how-section { background: var(--black); padding: 80px 5%; color: var(--white); }\n  .how-section .section-title { color: var(--white); }\n  .how-section .section-subtitle { color: rgba(255,255,255,0.6); }\n  .how-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 28px; }\n  .how-card {\n    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);\n    border-radius: 14px; padding: 32px 24px; text-align: center;\n  }\n  .how-card .icon-wrap {\n    width: 64px; height: 64px; background: var(--accent); border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    margin: 0 auto 20px; font-size: 28px;\n  }\n  .how-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 10px; color: var(--white); text-transform: uppercase; letter-spacing: 0.5px; }\n  .how-card p { font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.6; }\n\n  /* ── SHEETS vs BOTTLE ── */\n  .upgrade-section { background: var(--gray-light); padding: 80px 5%; }\n  .upgrade-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 40px; }\n  .upgrade-card { background: var(--white); border-radius: 14px; overflow: hidden; border: 2px solid var(--gray-mid); }\n  .upgrade-card.winner { border-color: var(--black); }\n  .upgrade-card-header { padding: 18px 24px; font-size: 18px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; background: var(--gray-mid); color: var(--black); }\n  .upgrade-card.winner .upgrade-card-header { background: var(--black); color: var(--white); }\n  .upgrade-card img { width: 100%; height: 220px; object-fit: contain; padding: 16px; background: #fafafa; display: block; }\n  .upgrade-list { list-style: none; padding: 20px 24px; }\n  .upgrade-list li { padding: 9px 0; font-size: 14px; border-bottom: 1px solid #f0f0f0; display: flex; align-items: center; gap: 10px; }\n  .upgrade-list li:last-child { border-bottom: none; }\n  .check-green { color: var(--green); font-weight: 900; font-size: 16px; }\n  .check-red   { color: var(--accent-dark); font-weight: 900; font-size: 16px; }\n\n  /* ── RESULTS ── */\n  .results-section { padding: 80px 5%; background: var(--white); }\n  .results-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }\n  .results-img img { width: 100%; border-radius: 14px; height: 500px; object-fit: cover; }\n  .stats-list { display: flex; flex-direction: column; gap: 28px; }\n  .stat-item { display: flex; align-items: flex-start; gap: 20px; }\n  .stat-number { font-size: 52px; font-weight: 900; color: var(--accent); line-height: 1; flex-shrink: 0; min-width: 90px; }\n  .stat-desc { font-size: 15px; color: #444; padding-top: 10px; line-height: 1.5; }\n  .stat-note { font-size: 12px; color: var(--gray-text); margin-top: 24px; font-style: italic; }\n\n  /* ── COMMUNITY TRUST ── */\n  .expert-section { background: var(--gray-light); padding: 80px 5%; text-align: center; }\n  .expert-img { border-radius: 16px; overflow: hidden; }\n  .expert-img img { width: 100%; display: block; }\n\n  /* ── GUARANTEE ── */\n  .guarantee-section { background: var(--black); color: var(--white); padding: 80px 5%; text-align: center; }\n  .guarantee-section h2 { font-size: 30px; font-weight: 800; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px; }\n  .guarantee-section > p { font-size: 17px; color: rgba(255,255,255,0.75); max-width: 680px; margin: 0 auto 48px; line-height: 1.7; }\n  .trust-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }\n  .trust-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; padding: 24px 16px; }\n  .trust-card .trust-icon { font-size: 32px; margin-bottom: 12px; }\n  .trust-card h4 { font-size: 14px; font-weight: 700; color: var(--white); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.3px; }\n  .trust-card p { font-size: 12px; color: rgba(255,255,255,0.5); margin: 0; }\n\n  /* ── RESPONSIVE ── */\n  @media (max-width: 900px) {\n    .feel-inner, .results-inner, .upgrade-grid { grid-template-columns: 1fr; }\n    .feel-img img, .results-img img { height: 320px; }\n    .how-grid { grid-template-columns: 1fr; }\n    .trust-grid { grid-template-columns: 1fr 1fr; gap: 14px; }\n    .section-title { font-size: 24px; }\n    .stat-number { font-size: 40px; }\n  }\n\n  @media (max-width: 480px) {\n    .feel-section, .how-section, .upgrade-section,\n    .results-section, .expert-section, .guarantee-section { padding: 50px 4%; }\n    .trust-grid { grid-template-columns: 1fr 1fr; gap: 12px; }\n    .trust-card { padding: 18px 12px; }\n    .trust-card .trust-icon { font-size: 26px; }\n    .trust-card h4 { font-size: 12px; }\n    .trust-card p { font-size: 11px; }\n    .guarantee-section h2 { font-size: 22px; }\n    .guarantee-section > p { font-size: 15px; }\n    .feel-text h2 { font-size: 24px; }\n    .stat-number { font-size: 36px; min-width: 72px; }\n  }\n</style>\n</head>\n<body>\n\n<!-- ── BANNER ── -->\n<div class=\"customer-banner\">🌿 Over <span>780,000+</span> Homes Cleaning Greener — Loved by Families Everywhere</div>\n\n<!-- ── MAIN INTRO ── -->\n<section class=\"feel-section\">\n  <div class=\"feel-inner\">\n    <div class=\"feel-img\">\n      <img src=\"https://lucentglobe.com/cdn/shop/files/DishwashingSheets-Single_nosheet.png?v=1768273628&width=1200\" alt=\"Dishwashing detergent sheets\" />\n    </div>\n    <div class=\"feel-text\">\n      <h2>Clean Dishes Without the Plastic Bottle</h2>\n      <p>Whether it's a quick load after dinner or last night's stuck-on pan, dish soap shouldn't cost the planet a plastic bottle every time. These sheets cut through grease using plant-based cleaners, right from your kitchen sink.</p>\n      <p>Made with coconut-based cleaners and natural enzymes, each sheet dissolves fully in water and gets to work fast — no bottle, no drips, no waste left behind.</p>\n      <ul>\n        <li><div><strong>Cuts grease fast</strong> — plant-based cleaners break down grease and food bits in seconds.</div></li>\n        <li><div><strong>No plastic, ever</strong> — one pack replaces dozens of plastic dish soap bottles.</div></li>\n        <li><div><strong>Dissolves completely</strong> — no sticky film, gentle on hands and skin.</div></li>\n        <li><div><strong>Safe for pipes & septic</strong> — plant-based formula is gentle on drains and greywater systems.</div></li>\n        <li><div><strong>Easy to pack</strong> — flat, lightweight sheets fit anywhere: home, camper, or travel bag.</div></li>\n      </ul>\n      <div class=\"quote-box\">\n        <p>\"I switched to these sheets last month and haven't looked back. My kitchen has zero plastic clutter now, and my dishes still come out spotless.\"</p>\n        <div class=\"quote-author\">\n          <img class=\"avatar\" src=\"REPLACE_WITH_CUSTOMER_PHOTO.jpg\" alt=\"Sarah K.\" />\n          <div class=\"author-info\">\n            <strong>Sarah K.</strong>\n            <span>Verified buyer</span>\n            <div class=\"stars\">★ ★ ★ ★ ★</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ── HOW IT WORKS ── -->\n<section class=\"how-section\">\n  <p class=\"section-title\">How These Sheets Work</p>\n  <p class=\"section-subtitle\">Simple plant-based ingredients doing the heavy lifting, one sheet at a time.</p>\n  <div class=\"how-grid\">\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">🧽</div>\n      <h3>Grease-Cutting Formula</h3>\n      <p>Coconut-based cleaners grab onto grease and food residue and lift it away, even on stuck-on messes.</p>\n    </div>\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">💧</div>\n      <h3>Fully Dissolvable</h3>\n      <p>Each sheet melts completely in water within seconds — no film, no residue, no clean-up after clean-up.</p>\n    </div>\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">🌎</div>\n      <h3>Safe Down the Drain</h3>\n      <p>No bleach, dyes, or phosphates. The formula breaks down safely, so it's gentle on pipes, septic systems, and waterways.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── SHEETS vs BOTTLE ── -->\n<section class=\"upgrade-section\">\n  <p class=\"section-title\">Sheets vs. The Old Plastic Bottle</p>\n  <p class=\"section-subtitle\">Same clean dishes. A lot less waste.</p>\n  <div class=\"upgrade-grid\">\n    <div class=\"upgrade-card winner\">\n      <div class=\"upgrade-card-header\">✅ Dish Sheets</div>\n      <img src=\"https://lucentglobe.com/cdn/shop/files/DishwashingSheets-3Pack.png?v=1767382613&width=1200\" alt=\"Dish sheets\" />\n      <ul class=\"upgrade-list\">\n        <li><span class=\"check-green\">✓</span> No plastic packaging</li>\n        <li><span class=\"check-green\">✓</span> Pre-measured — no waste, no mess</li>\n        <li><span class=\"check-green\">✓</span> Plant-based ingredients</li>\n        <li><span class=\"check-green\">✓</span> Dissolves completely, no residue</li>\n        <li><span class=\"check-green\">✓</span> Safe for septic & greywater systems</li>\n        <li><span class=\"check-green\">✓</span> Flat and easy to store or travel with</li>\n      </ul>\n    </div>\n    <div class=\"upgrade-card\">\n      <div class=\"upgrade-card-header\">❌ Liquid Detergent</div>\n      \n      <ul class=\"upgrade-list\">\n        <li><span class=\"check-red\">✗</span> A new plastic bottle every refill</li>\n        <li><span class=\"check-red\">✗</span> Easy to over-pour and waste</li>\n        <li><span class=\"check-red\">✗</span> Often has dyes and added fragrance</li>\n        <li><span class=\"check-red\">✗</span> Can leave a soapy film behind</li>\n        <li><span class=\"check-red\">✗</span> Rough on sensitive plumbing</li>\n        <li><span class=\"check-red\">✗</span> Bulky and heavy to store</li>\n      </ul>\n    </div>\n  </div>\n</section>\n\n<!-- ── RESULTS ── -->\n<section class=\"results-section\">\n  <div class=\"results-inner\">\n    <div class=\"results-img\">\n  \n    </div>\n    <div>\n      <h2 style=\"font-size:30px;font-weight:800;margin-bottom:36px;text-transform:uppercase;letter-spacing:1px;\">What Customers Are Saying</h2>\n      <div class=\"stats-list\">\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">94%</div>\n          <p class=\"stat-desc\">Of customers say their dishes came out just as clean as with their old liquid detergent.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">89%</div>\n          <p class=\"stat-desc\">Say they've noticed less plastic waste in their kitchen since switching.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">90%</div>\n          <p class=\"stat-desc\">Say they wouldn't go back to bottled dish soap.</p>\n        </div>\n      </div>\n      <p class=\"stat-note\">*Based on customer survey data. Individual results may vary.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── COMMUNITY TRUST ── -->\n<section class=\"expert-section\">\n  <p class=\"section-title\" style=\"margin-bottom:16px;\">Loved By Eco-Conscious Homes</p>\n  <p class=\"section-subtitle\">Trusted by thousands of home cooks, parents, and everyday families who want a cleaner kitchen without the plastic waste.</p>\n  <div class=\"expert-img\">\n    <img src=\"https://lucentglobe.com/cdn/shop/files/DishwashingMulti.png?v=1769116991&width=1200\" alt=\"Family using dish sheets in the kitchen\" />\n  </div>\n</section>\n\n<!-- ── GUARANTEE ── -->\n<section class=\"guarantee-section\">\n  <h2>Clean Dishes. Cleaner Conscience.</h2>\n  <p>Cleaning your home shouldn't cost the earth. Every sheet is plant-based, cruelty-free, and made to work as hard as your old detergent. Try your first pack risk-free.</p>\n  <div class=\"trust-grid\">\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">🛡️</div>\n      <h4>Money-Back Guarantee</h4>\n      <p>Full refund on your first pack if you're not happy with the results.</p>\n    </div>\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">🌱</div>\n      <h4>Plant-Based Formula</h4>\n      <p>Made from natural, biodegradable ingredients you can feel good about.</p>\n    </div>\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">💬</div>\n      <h4>Friendly Support</h4>\n      <p>Our team replies within 24 hours, every day of the week.</p>\n    </div>\n    <div class=\"trust-card\">\n      <div class=\"trust-icon\">📦</div>\n      <h4>Plastic-Free Packaging</h4>\n      <p>Every pack ships in fully recyclable, plastic-free cardboard.</p>\n    </div>\n  </div>\n</section>\n\n</body>\n</html>",
